---
import { getCollection } from "astro:content";

interface Props {
  lang?: "zh" | "en";
}
const { lang = "zh" } = Astro.props;
const en = lang === "en";

const allVideos = await getCollection("videos");
const videos = allVideos.sort((a, b) => {
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});
const pubs = await getCollection("publications");
const pubBySlug = new Map(pubs.map((p) => [p.slug, p]));

// 凝結爆衝：影片＋數據圖並排特別區塊（從一般影片格與照片組抽出）
const CONDENSATION_PUB = "2024-hsu-condensation-shock";
const featuredVideo =
  videos.find((v) => v.data.related_pub === CONDENSATION_PUB) ?? null;
const gridVideos = videos.filter((v) => v !== featuredVideo);
const featuredFigure = {
  zh: "無薄膜時的壓力訊號時間序列與冷熱端溫度：加熱過程中自發起振，最大 p′ ≈ 1285 Pa（t ≈ 328 s）後衰減",
  en: "Pressure time series with hot/cold-end temperatures for the no-membrane case: self-excited oscillation during heating, peaking at p′ ≈ 1285 Pa (t ≈ 328 s) before decaying",
  src: "/images/media/condensation-shock-timeseries.jpg",
};
const featuredPub = pubBySlug.get(CONDENSATION_PUB) ?? null;
const featuredUrl = featuredPub
  ? featuredPub.data.url ||
    (featuredPub.data.doi ? `https://doi.org/${featuredPub.data.doi}` : null)
  : null;
const featuredVenue = featuredPub
  ? en
    ? (featuredPub.data.venue_en ??
      featuredPub.data.venue_short ??
      featuredPub.data.venue)
    : (featuredPub.data.venue_short ?? featuredPub.data.venue)
  : null;

// 照片區依研究主軸分組（中英標題；pub 可選，連結對應論文）
const photoGroups = [
  {
    zh: "非線性動力學：起振、分歧與飽和",
    en: "Nonlinear dynamics: onset, bifurcation & saturation",
    photos: [
      {
        src: "/images/media/subcritical-hopf-triggering.jpg",
        zh: "亞臨界霍普夫分歧的觸發（ΔT = 340 K）：間歇擾動觸發後成長為極限環，以史特勞–朗道模型擬合",
        en: "Triggering across a subcritical Hopf bifurcation (ΔT = 340 K): intermittent perturbations grow into a limit cycle, fitted with a Stuart–Landau model",
        pub: "2024-lai-hopf-bifurcation",
      },
      {
        src: "/images/media/subcritical-hopf-saturation.jpg",
        zh: "極限環振幅飽和（ΔT = 347 K）：振幅成長至飽和，成長率 d(ln|A|)/dt 對 |A|² 呈史特勞–朗道相圖（R² = 0.99）",
        en: "Limit-cycle amplitude saturation (ΔT = 347 K): amplitude grows to saturation; growth rate d(ln|A|)/dt versus |A|² gives the Stuart–Landau phase portrait (R² = 0.99)",
        pub: "2024-lai-hopf-bifurcation",
      },
      {
        src: "/images/media/onset-stability-curve.jpg",
        zh: "發振安定曲線：起振溫差 T_H − T_C 與頻率隨電負載 R_L 變化，比較有無外殼之實驗與理論",
        en: "Onset (marginal-stability) curve: onset temperature difference T_H − T_C and frequency versus electrical load R_L, comparing experiment and theory with/without housing",
        pub: "2023-hsu-onset-conditions",
      },
    ],
  },
  {
    zh: "熱聲引擎與蓄熱器",
    en: "Thermoacoustic engines & regenerators",
    photos: [
      {
        src: "/images/media/speaker-load-onset-setup.jpg",
        zh: "負載揚聲器之環形管熱聲史特靈引擎發振條件量測配置",
        en: "Looped-tube thermoacoustic Stirling engine loaded with a loudspeaker — onset-condition measurement setup",
        pub: "2023-hsu-onset-conditions",
      },
      {
        src: "/images/media/effective-radius-setup.jpg",
        zh: "堆疊金屬絲網蓄熱器等效流路半徑之雙揚聲器聲學量測裝置",
        en: "Two-driver acoustic setup for the effective flow radius of a stacked-screen regenerator",
        pub: "2017-hsu-stacked-screen-modeling",
      },
      {
        src: "/images/awards/2023-liquid-load-apparatus.jpg",
        zh: "液柱負載與多蓄熱器熱聲引擎實驗裝置",
        en: "Liquid-column-loaded multi-regenerator thermoacoustic engine",
      },
      {
        src: "/images/media/impedance-matching.jpg",
        zh: "阻抗匹配決定作動條件：不同水柱體積之負載阻抗 Z_load 與引擎阻抗 Z_TA 的實部、虛部隨頻率變化，交點對應實測作動點",
        en: "Impedance matching sets the operating condition: real and imaginary parts of the load impedance Z_load (various water-column volumes) and engine impedance Z_TA versus frequency; their crossing matches the measured operating point",
        pub: "2024-hsu-impedance-matching",
      },
    ],
  },
  {
    zh: "顆粒流",
    en: "Granular flow",
    photos: [
      {
        src: "/images/media/rotating-drum-coffee.jpg",
        zh: "旋轉滾筒咖啡豆顆粒流實驗機（透明壓克力滾筒）",
        en: "Rotating-drum coffee-bean granular-flow rig (transparent acrylic drum)",
      },
      {
        src: "/images/awards/2022-coffee-drum-piv.png",
        zh: "咖啡豆顆粒流 PIV 速度場疊加圖",
        en: "Coffee-bean granular-flow PIV velocity field",
      },
    ],
  },
];

const L = {
  videos: en ? "Videos" : "影片",
  photos: en ? "Photos" : "照片",
  paper: en ? "Related paper" : "對應論文",
  play: en ? "Play video" : "播放影片",
  featured: en ? "Featured" : "特別收錄",
  footage: en ? "Experiment footage" : "實驗影片",
  data: en ? "Measured data" : "量測數據",
};
const vtitle = (v: (typeof videos)[number]) =>
  en ? (v.data.title_en ?? v.data.title) : (v.data.title_zh ?? v.data.title);
const vdesc = (v: (typeof videos)[number]) =>
  en ? (v.data.description_en ?? v.data.description) : v.data.description;
---

<div class="mg" data-mg>
  {
    featuredVideo && (
      <section class="mb-12 rounded-xl border border-brand-100 bg-brand-50/40 p-5 sm:p-6">
        <p class="text-xs uppercase tracking-[0.3em] text-brand-500">{L.featured}</p>
        <h2 class="mt-1 text-2xl font-semibold text-brand-900">{vtitle(featuredVideo)}</h2>
        <div class="mt-5 grid items-start gap-5 lg:grid-cols-2">
          <figure class="overflow-hidden rounded-lg border border-brand-100 bg-white shadow-sm">
            <button
              type="button"
              class="group relative block aspect-video w-full bg-black"
              data-yt={featuredVideo.data.youtube_id}
              data-title={vtitle(featuredVideo)}
              aria-label={`${L.play}: ${vtitle(featuredVideo)}`}
            >
              <img
                src={`https://i.ytimg.com/vi/${featuredVideo.data.youtube_id}/hqdefault.jpg`}
                alt={vtitle(featuredVideo)}
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition group-hover:opacity-90"
              />
              <span class="absolute inset-0 flex items-center justify-center">
                <span class="flex h-12 w-12 items-center justify-center rounded-full bg-white/85 shadow transition group-hover:scale-110">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="#dc2626" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </span>
            </button>
            <figcaption class="p-4">
              <p class="text-xs uppercase tracking-widest text-brand-500">{L.footage}</p>
              {vdesc(featuredVideo) && (
                <p class="mt-1 text-sm text-gray-700">{vdesc(featuredVideo)}</p>
              )}
            </figcaption>
          </figure>
          <figure class="overflow-hidden rounded-lg border border-brand-100 bg-white shadow-sm">
            <button
              type="button"
              class="group block aspect-video w-full bg-white"
              data-img={featuredFigure.src}
              data-caption={en ? featuredFigure.en : featuredFigure.zh}
              aria-label={en ? featuredFigure.en : featuredFigure.zh}
            >
              <img
                src={featuredFigure.src}
                alt={en ? featuredFigure.en : featuredFigure.zh}
                loading="lazy"
                class="h-full w-full object-contain transition group-hover:opacity-90"
              />
            </button>
            <figcaption class="p-4">
              <p class="text-xs uppercase tracking-widest text-brand-500">{L.data}</p>
              <p class="mt-1 text-sm text-gray-700">{en ? featuredFigure.en : featuredFigure.zh}</p>
            </figcaption>
          </figure>
        </div>
        {featuredPub && (
          <p class="mt-4 text-sm">
            <span class="text-brand-600">{L.paper}：</span>
            {featuredUrl ? (
              <a href={featuredUrl} target="_blank" rel="noopener noreferrer" class="text-accent-600 underline hover:text-accent-700">
                {featuredVenue} ({featuredPub.data.year}) <span class="text-xs">↗</span>
              </a>
            ) : (
              <span class="text-gray-700">{featuredVenue} ({featuredPub.data.year})</span>
            )}
          </p>
        )}
      </section>
    )
  }
  {
    gridVideos.length > 0 && (
      <section>
        <h2 class="text-2xl font-semibold text-brand-900">{L.videos}</h2>
        <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {gridVideos.map((v) => {
            const pub = v.data.related_pub ? pubBySlug.get(v.data.related_pub) : null;
            const url = pub
              ? pub.data.url || (pub.data.doi ? `https://doi.org/${pub.data.doi}` : null)
              : null;
            return (
              <figure class="overflow-hidden rounded-lg border border-brand-100 bg-white shadow-sm transition hover:border-brand-300">
                <button
                  type="button"
                  class="group relative block aspect-video w-full bg-black"
                  data-yt={v.data.youtube_id}
                  data-title={vtitle(v)}
                  aria-label={`${L.play}: ${vtitle(v)}`}
                >
                  <img
                    src={`https://i.ytimg.com/vi/${v.data.youtube_id}/hqdefault.jpg`}
                    alt={vtitle(v)}
                    loading="lazy"
                    class="absolute inset-0 h-full w-full object-cover transition group-hover:opacity-90"
                  />
                  <span class="absolute inset-0 flex items-center justify-center">
                    <span class="flex h-12 w-12 items-center justify-center rounded-full bg-white/85 shadow transition group-hover:scale-110">
                      <svg viewBox="0 0 24 24" width="20" height="20" fill="#dc2626" aria-hidden="true">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </span>
                  </span>
                </button>
                <figcaption class="p-4">
                  {v.data.year && (
                    <p class="text-xs uppercase tracking-widest text-brand-500">{v.data.year}</p>
                  )}
                  <h3 class="mt-1 text-base font-semibold leading-snug text-brand-900">{vtitle(v)}</h3>
                  {vdesc(v) && <p class="mt-2 text-sm text-gray-700">{vdesc(v)}</p>}
                  {pub && (
                    <p class="mt-3 text-sm">
                      <span class="text-brand-600">{L.paper}：</span>
                      {url ? (
                        <a href={url} target="_blank" rel="noopener noreferrer" class="text-accent-600 underline hover:text-accent-700">
                          {pub.data.venue_short ?? pub.data.venue} ({pub.data.year}) <span class="text-xs">↗</span>
                        </a>
                      ) : (
                        <span class="text-gray-700">{pub.data.venue_short ?? pub.data.venue} ({pub.data.year})</span>
                      )}
                    </p>
                  )}
                </figcaption>
              </figure>
            );
          })}
        </div>
      </section>
    )
  }

  {
    photoGroups.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-semibold text-brand-900">{L.photos}</h2>
        {photoGroups.map((group) => (
          <div class="mt-8 first:mt-6">
            <h3 class="text-sm font-semibold uppercase tracking-widest text-brand-500">
              {en ? group.en : group.zh}
            </h3>
            <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {group.photos.map((p) => {
                const pub = "pub" in p && p.pub ? pubBySlug.get(p.pub) : null;
                const url = pub
                  ? pub.data.url || (pub.data.doi ? `https://doi.org/${pub.data.doi}` : null)
                  : null;
                const venue = pub
                  ? en
                    ? (pub.data.venue_en ?? pub.data.venue_short ?? pub.data.venue)
                    : (pub.data.venue_short ?? pub.data.venue)
                  : null;
                return (
                  <figure class="overflow-hidden rounded-lg border border-brand-100 bg-white shadow-sm transition hover:border-brand-300">
                    <button
                      type="button"
                      class="group block aspect-[4/3] w-full bg-brand-50"
                      data-img={p.src}
                      data-caption={en ? p.en : p.zh}
                      aria-label={en ? p.en : p.zh}
                    >
                      <img src={p.src} alt={en ? p.en : p.zh} loading="lazy" class="h-full w-full object-cover transition group-hover:opacity-90" />
                    </button>
                    <figcaption class="p-3 text-sm text-gray-700">
                      {en ? p.en : p.zh}
                      {pub && (
                        <span class="mt-2 block text-xs">
                          <span class="text-brand-600">{L.paper}：</span>
                          {url ? (
                            <a href={url} target="_blank" rel="noopener noreferrer" class="text-accent-600 underline hover:text-accent-700">
                              {venue} ({pub.data.year}) <span>↗</span>
                            </a>
                          ) : (
                            <span class="text-gray-700">{venue} ({pub.data.year})</span>
                          )}
                        </span>
                      )}
                    </figcaption>
                  </figure>
                );
              })}
            </div>
          </div>
        ))}
      </section>
    )
  }

  <div class="mg-lb" data-lb hidden>
    <button type="button" class="mg-close" data-close aria-label="Close">×</button>
    <div class="mg-stage" data-stage></div>
    <p class="mg-cap" data-cap></p>
  </div>
</div>

<style>
  .mg-lb {
    position: fixed; inset: 0; z-index: 100; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem;
    background: rgba(15, 23, 42, 0.88); backdrop-filter: blur(2px);
  }
  .mg-lb[hidden] { display: none; }
  .mg-stage {
    width: min(92vw, 1100px); max-height: 80vh; display: flex;
    align-items: center; justify-content: center;
  }
  .mg-stage :global(iframe) { width: min(92vw, 1100px); aspect-ratio: 16 / 9; border: 0; border-radius: 0.5rem; }
  .mg-stage :global(img) { max-width: 92vw; max-height: 80vh; border-radius: 0.5rem; }
  .mg-cap { color: #e2e8f0; font-size: 0.9rem; text-align: center; max-width: 92vw; }
  .mg-close {
    position: absolute; top: 1rem; right: 1.25rem; color: #fff; font-size: 2rem;
    line-height: 1; background: none; border: 0; cursor: pointer; opacity: 0.8;
  }
  .mg-close:hover { opacity: 1; }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-mg]").forEach((root) => {
    const lb = root.querySelector<HTMLElement>("[data-lb]");
    const stage = root.querySelector<HTMLElement>("[data-stage]");
    const cap = root.querySelector<HTMLElement>("[data-cap]");
    if (!lb || !stage || !cap) return;

    const open = (node: Node, caption: string) => {
      stage.replaceChildren(node);
      cap.textContent = caption;
      lb.hidden = false;
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      lb.hidden = true;
      stage.replaceChildren();
      document.body.style.overflow = "";
    };

    root.querySelectorAll<HTMLButtonElement>("[data-yt]").forEach((b) =>
      b.addEventListener("click", () => {
        const id = b.dataset.yt!;
        const f = document.createElement("iframe");
        f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
        f.title = b.dataset.title ?? "";
        f.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        f.setAttribute("allowfullscreen", "");
        f.setAttribute("referrerpolicy", "strict-origin-when-cross-origin");
        open(f, b.dataset.title ?? "");
      }),
    );
    root.querySelectorAll<HTMLButtonElement>("[data-img]").forEach((b) =>
      b.addEventListener("click", () => {
        const img = document.createElement("img");
        img.src = b.dataset.img!;
        img.alt = b.dataset.caption ?? "";
        open(img, b.dataset.caption ?? "");
      }),
    );
    lb.querySelector("[data-close]")?.addEventListener("click", close);
    lb.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lb.hidden) close();
    });
  });
</script>
