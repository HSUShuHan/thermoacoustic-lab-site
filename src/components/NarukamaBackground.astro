---
// Fixed-position narukama atmospheric background + white-tinted fade overlay.
// Render at the top of <body> on pages that want the persistent flame.
// Sections / Footer must use `relative z-10` (or higher) to layer above.
import NarukamaHero from "~/components/NarukamaHero.astro";
---

<div class="narukama-bg-figure" aria-hidden="true">
  <NarukamaHero />
</div>
<div class="narukama-bg-fade" aria-hidden="true"></div>

<style>
  /* Narukama centred on the news card column of the max-w-6xl layout
     (container 1152, padding 24, gap 48 → each col 528, news-card centre
     sits 288px right of container centre). On mobile / tablet (< 900px)
     the hero collapses to a single column, so centre the narukama instead. */
  .narukama-bg-figure {
    position: fixed;
    top: 50%;
    left: calc(50% + 288px);
    width: 440px;
    max-width: 42%;
    transform: translate(-50%, -50%);
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  @media (max-width: 900px) {
    .narukama-bg-figure {
      left: 50%;
      max-width: 70%;
      opacity: 0.35;
      filter: grayscale(1);
    }
  }
  .narukama-bg-figure :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  /* Fade overlay: on desktop, strong white on left (keeps hero copy crisp),
     transparent window over the news-card column. On mobile the narukama is
     centred, so the gradient is symmetric. */
  .narukama-bg-fade {
    position: fixed;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(255, 255, 255, 0.85) 30%,
        rgba(255, 255, 255, 0.50) 50%,
        rgba(255, 255, 255, 0.10) 68%,
        rgba(255, 255, 255, 0.30) 100%
      ),
      radial-gradient(
        ellipse 600px 500px at 68% 55%,
        rgba(255, 186, 89, 0.18) 0%,
        rgba(255, 122, 48, 0.10) 32%,
        rgba(232, 58, 26, 0.04) 55%,
        transparent 78%
      );
    pointer-events: none;
    z-index: 1;
  }
  @media (max-width: 900px) {
    /* Narukama is grayscale on mobile (see .narukama-bg-figure rule above);
       drop the warm halo from the overlay so it matches. Pure white wash
       keeps content readable. */
    .narukama-bg-fade {
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.55) 0%,
        rgba(255, 255, 255, 0.50) 40%,
        rgba(255, 255, 255, 0.55) 100%
      );
    }
  }
</style>
