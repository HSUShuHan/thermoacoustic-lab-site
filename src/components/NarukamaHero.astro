---
// Narukama (鳴釜) hero SVG — historical thermoacoustic apparatus.
// Wooden steamer (甑) atop iron cauldron (釜) on a stone hearth, with rice grains
// in the steamer, boiling water + rising bubbles in the cauldron, flames below,
// steam wisps above, and three plane wavefronts radiating from the steamer mouth.
// Ported from Claude Design's HeroFlame.jsx (538 lines), animations preserved.

const riceGrains = [
  { cx: 138, cy: 120, rx: 5, ry: 2.4, a: -12 }, { cx: 152, cy: 118, rx: 5, ry: 2.4, a: 8 },
  { cx: 166, cy: 121, rx: 5, ry: 2.4, a: -6 }, { cx: 180, cy: 117, rx: 5, ry: 2.4, a: 14 },
  { cx: 194, cy: 120, rx: 5, ry: 2.4, a: -10 }, { cx: 208, cy: 119, rx: 5, ry: 2.4, a: 6 },
  { cx: 222, cy: 121, rx: 5, ry: 2.4, a: -4 },
  { cx: 131, cy: 132, rx: 5, ry: 2.5, a: 6 }, { cx: 144, cy: 130, rx: 5, ry: 2.5, a: -14 },
  { cx: 159, cy: 133, rx: 5, ry: 2.5, a: 10 }, { cx: 173, cy: 131, rx: 5, ry: 2.5, a: -8 },
  { cx: 187, cy: 133, rx: 5, ry: 2.5, a: 12 }, { cx: 201, cy: 130, rx: 5, ry: 2.5, a: -6 },
  { cx: 215, cy: 132, rx: 5, ry: 2.5, a: 8 }, { cx: 229, cy: 131, rx: 5, ry: 2.5, a: -12 },
  { cx: 137, cy: 144, rx: 5, ry: 2.5, a: -10 }, { cx: 151, cy: 142, rx: 5, ry: 2.5, a: 14 },
  { cx: 165, cy: 145, rx: 5, ry: 2.5, a: -4 }, { cx: 179, cy: 143, rx: 5, ry: 2.5, a: 8 },
  { cx: 193, cy: 145, rx: 5, ry: 2.5, a: -12 }, { cx: 207, cy: 142, rx: 5, ry: 2.5, a: 10 },
  { cx: 221, cy: 144, rx: 5, ry: 2.5, a: -8 },
  { cx: 130, cy: 156, rx: 5, ry: 2.5, a: 12 }, { cx: 144, cy: 154, rx: 5, ry: 2.5, a: -6 },
  { cx: 158, cy: 157, rx: 5, ry: 2.5, a: 8 }, { cx: 172, cy: 155, rx: 5, ry: 2.5, a: -14 },
  { cx: 186, cy: 157, rx: 5, ry: 2.5, a: 4 }, { cx: 200, cy: 154, rx: 5, ry: 2.5, a: -10 },
  { cx: 214, cy: 156, rx: 5, ry: 2.5, a: 6 }, { cx: 228, cy: 155, rx: 5, ry: 2.5, a: -8 },
  { cx: 138, cy: 168, rx: 5, ry: 2.5, a: -4 }, { cx: 152, cy: 166, rx: 5, ry: 2.5, a: 10 },
  { cx: 166, cy: 169, rx: 5, ry: 2.5, a: -12 }, { cx: 180, cy: 167, rx: 5, ry: 2.5, a: 6 },
  { cx: 194, cy: 169, rx: 5, ry: 2.5, a: -8 }, { cx: 208, cy: 166, rx: 5, ry: 2.5, a: 14 },
  { cx: 222, cy: 168, rx: 5, ry: 2.5, a: -6 },
  { cx: 132, cy: 180, rx: 5, ry: 2.5, a: 8 }, { cx: 146, cy: 178, rx: 5, ry: 2.5, a: -10 },
  { cx: 160, cy: 181, rx: 5, ry: 2.5, a: 4 }, { cx: 174, cy: 179, rx: 5, ry: 2.5, a: -14 },
  { cx: 188, cy: 181, rx: 5, ry: 2.5, a: 10 }, { cx: 202, cy: 178, rx: 5, ry: 2.5, a: -6 },
  { cx: 216, cy: 180, rx: 5, ry: 2.5, a: 12 }, { cx: 230, cy: 179, rx: 5, ry: 2.5, a: -4 },
];

const bubbles = [
  { cx: 158, r: 2.5, delay: 0,   dur: 2.6 },
  { cx: 170, r: 3.0, delay: 0.8, dur: 3.0 },
  { cx: 186, r: 2.2, delay: 1.4, dur: 2.4 },
  { cx: 198, r: 3.4, delay: 0.3, dur: 3.2 },
  { cx: 210, r: 2.6, delay: 2.0, dur: 2.8 },
  { cx: 165, r: 2.0, delay: 2.6, dur: 2.2 },
  { cx: 195, r: 2.8, delay: 1.9, dur: 3.0 },
  { cx: 180, r: 3.2, delay: 3.1, dur: 2.6 },
];

const perforations = [130, 142, 154, 166, 178, 190, 202, 214, 226];
---

<svg viewBox="0 0 360 510" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="ironBody" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#4a5564"/>
      <stop offset="40%"  stop-color="#1d242f"/>
      <stop offset="75%"  stop-color="#161c25"/>
      <stop offset="100%" stop-color="#3a4250"/>
    </linearGradient>
    <linearGradient id="ironRim" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"  stop-color="#6b7686"/>
      <stop offset="55%" stop-color="#2a3340"/>
      <stop offset="100%" stop-color="#13181f"/>
    </linearGradient>
    <linearGradient id="cavityFill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#0a0e15" stop-opacity="0.92"/>
      <stop offset="100%" stop-color="#1a0d08" stop-opacity="0.92"/>
    </linearGradient>
    <linearGradient id="waterFill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#1a3344"/>
      <stop offset="60%"  stop-color="#3a1a14"/>
      <stop offset="100%" stop-color="#7a2a10"/>
    </linearGradient>
    <linearGradient id="waterSurface" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#ffba59" stop-opacity="0"/>
      <stop offset="30%"  stop-color="#ffe7a8" stop-opacity="0.55"/>
      <stop offset="50%"  stop-color="#ffffff" stop-opacity="0.7"/>
      <stop offset="70%"  stop-color="#ffe7a8" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="#ffba59" stop-opacity="0"/>
    </linearGradient>
    <radialGradient id="ironUnderglow" cx="50%" cy="100%" r="55%">
      <stop offset="0%"   stop-color="#ffba59" stop-opacity="0.85"/>
      <stop offset="45%"  stop-color="#ff7a30" stop-opacity="0.45"/>
      <stop offset="80%"  stop-color="#e83a1a" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="#e83a1a" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="ironHighlight" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#ffffff" stop-opacity="0"/>
      <stop offset="50%"  stop-color="#ffe7a8" stop-opacity="0.35"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </linearGradient>

    <linearGradient id="woodLight" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#6a4327"/>
      <stop offset="100%" stop-color="#3d2515"/>
    </linearGradient>
    <linearGradient id="woodMid" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#5a3820"/>
      <stop offset="100%" stop-color="#2c1a0e"/>
    </linearGradient>
    <linearGradient id="woodDark" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#3d2515"/>
      <stop offset="100%" stop-color="#1d100a"/>
    </linearGradient>

    <radialGradient id="hearth" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#ff7a30" stop-opacity="0.5"/>
      <stop offset="50%"  stop-color="#e83a1a" stop-opacity="0.22"/>
      <stop offset="100%" stop-color="#7a160a" stop-opacity="0"/>
    </radialGradient>

    <radialGradient id="flameO" cx="50%" cy="80%" r="60%">
      <stop offset="0%"   stop-color="#ff7a30" stop-opacity="0.6"/>
      <stop offset="50%"  stop-color="#e83a1a" stop-opacity="0.35"/>
      <stop offset="100%" stop-color="#7a160a" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="flameM" cx="50%" cy="80%" r="55%">
      <stop offset="0%"   stop-color="#ffba59" stop-opacity="0.95"/>
      <stop offset="55%"  stop-color="#ff7a30" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#e83a1a" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="flameC" cx="50%" cy="75%" r="50%">
      <stop offset="0%"   stop-color="#ffe7a8" stop-opacity="1"/>
      <stop offset="60%"  stop-color="#ffba59" stop-opacity="0.85"/>
      <stop offset="100%" stop-color="#ff7a30" stop-opacity="0"/>
    </radialGradient>

    <radialGradient id="steam" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#ffffff" stop-opacity="0.55"/>
      <stop offset="60%"  stop-color="#ffffff" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>

    <clipPath id="cauldronClip">
      <path d="M 108 220 C 104 268, 100 340, 118 388 C 134 414, 154 422, 180 422 C 206 422, 226 414, 242 388 C 260 340, 256 268, 252 220 Z"/>
    </clipPath>
    <clipPath id="steamerClip">
      <rect x="122" y="108" width="116" height="86"/>
    </clipPath>

    <filter id="bigBlur" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="14"/></filter>
    <filter id="medBlur" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="6"/></filter>
    <filter id="softBlur" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3"/></filter>

    <filter id="waveDistort" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.030 0.075" numOctaves="2" seed="3" result="turb">
        <animate attributeName="seed" dur="0.35s" values="3;7;12;5;3" repeatCount="indefinite"/>
      </feTurbulence>
      <feDisplacementMap in="SourceGraphic" in2="turb" scale="2.4" xChannelSelector="R" yChannelSelector="G">
        <animate attributeName="scale" dur="0.55s" values="1.8;3.2;2.0;2.8;1.8" keyTimes="0;0.25;0.5;0.75;1" repeatCount="indefinite"/>
      </feDisplacementMap>
    </filter>
  </defs>

  <!-- Ambient hearth glow -->
  <ellipse cx="180" cy="450" rx="180" ry="36" fill="url(#hearth)" filter="url(#bigBlur)"/>

  <!-- Plane wavefronts radiating from the open end (top of steamer) -->
  <g class="soundwave">
    {[0, 1, 2].map((i) => (
      <g class={`wavefront wf-${i}`}>
        <path d="M 90 80 Q 180 78, 270 80" stroke="#ffba59" stroke-width="1.4" stroke-linecap="round" fill="none" opacity="0">
          <animate attributeName="opacity" values="0;0.7;0.7;0" keyTimes="0;0.15;0.75;1" dur="4.5s" begin={`${i * 1.5}s`} repeatCount="indefinite"/>
          <animateTransform attributeName="transform" type="translate" values="0 8;0 -76" dur="4.5s" begin={`${i * 1.5}s`} repeatCount="indefinite"/>
        </path>
        <path d="M 78 84 Q 180 80, 282 84" stroke="#ff7a30" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0">
          <animate attributeName="opacity" values="0;0.35;0.35;0" keyTimes="0;0.2;0.75;1" dur="4.5s" begin={`${i * 1.5}s`} repeatCount="indefinite"/>
          <animateTransform attributeName="transform" type="translate" values="0 8;0 -76" dur="4.5s" begin={`${i * 1.5}s`} repeatCount="indefinite"/>
        </path>
      </g>
    ))}
  </g>

  <!-- Apparatus — wrapped in wave-distortion filter so wall, water, rice shimmer -->
  <g filter="url(#waveDistort)">
    <!-- Steam wisps drifting up from steamer vent -->
    <g class="steam">
      <ellipse class="steam-wisp s1" cx="160" cy="62"  rx="22" ry="11" fill="url(#steam)"/>
      <ellipse class="steam-wisp s2" cx="195" cy="46"  rx="18" ry="9"  fill="url(#steam)"/>
      <ellipse class="steam-wisp s3" cx="175" cy="32"  rx="14" ry="7"  fill="url(#steam)"/>
      <ellipse class="steam-wisp s4" cx="148" cy="40"  rx="12" ry="6"  fill="url(#steam)"/>
    </g>

    <!-- Steamer (甑) — cutaway with rice -->
    <!-- Lid -->
    <rect x="115" y="100" width="130" height="8" rx="1" fill="url(#woodLight)" stroke="#7a5030" stroke-width="0.4" stroke-opacity="0.7"/>
    <rect x="115" y="108" width="130" height="2" fill="#1d100a"/>
    <rect x="170" y="102" width="20" height="3" fill="#0a0500" opacity="0.85"/>
    <!-- Left wall -->
    <rect x="115" y="110" width="9" height="88" fill="url(#woodDark)"/>
    <rect x="115" y="110" width="9" height="88" fill="url(#woodMid)" opacity="0.35"/>
    <!-- Right wall -->
    <rect x="236" y="110" width="9" height="88" fill="url(#woodDark)"/>
    <rect x="236" y="110" width="9" height="88" fill="url(#woodMid)" opacity="0.35"/>
    <!-- Front face faint -->
    <rect x="124" y="110" width="112" height="88" fill="url(#woodMid)" opacity="0.18"/>
    <line x1="124" y1="138" x2="236" y2="138" stroke="#1d100a" stroke-width="0.6" opacity="0.55"/>
    <line x1="124" y1="168" x2="236" y2="168" stroke="#1d100a" stroke-width="0.6" opacity="0.55"/>

    <!-- Rice grains -->
    <g clip-path="url(#steamerClip)" class="rice-grains">
      {riceGrains.map((g, i) => (
        <ellipse cx={g.cx} cy={g.cy} rx={g.rx} ry={g.ry} transform={`rotate(${g.a} ${g.cx} ${g.cy})`} fill="#f0e2bf" opacity={0.85 + ((i * 0.07) % 0.15)}/>
      ))}
      {riceGrains.slice(0, 24).map((g) => (
        <ellipse cx={g.cx} cy={g.cy - 0.8} rx={g.rx * 0.7} ry={g.ry * 0.5} transform={`rotate(${g.a} ${g.cx} ${g.cy})`} fill="#fff7e0" opacity="0.55"/>
      ))}
      <ellipse cx="160" cy="118" rx="14" ry="5" fill="url(#steam)" opacity="0.4"/>
      <ellipse cx="200" cy="124" rx="12" ry="4" fill="url(#steam)" opacity="0.35"/>
      <ellipse cx="180" cy="142" rx="16" ry="5" fill="url(#steam)" opacity="0.35"/>
    </g>

    <!-- Perforated false-bottom of steamer -->
    <line x1="124" y1="196" x2="236" y2="196" stroke="#1d100a" stroke-width="1.2"/>
    {perforations.map((x) => (
      <circle cx={x} cy="196.5" r="1.1" fill="#ff7a30" opacity="0.55"/>
    ))}
    <rect x="115" y="198" width="130" height="4" fill="#0a0500"/>
    <path d="M 124 202 L 102 210 L 258 210 L 236 202 Z" fill="#0a0500" opacity="0.6"/>

    <!-- Cauldron rim -->
    <ellipse cx="180" cy="212" rx="78" ry="10" fill="url(#ironRim)"/>
    <ellipse cx="180" cy="210" rx="78" ry="9"  fill="#070a10"/>
    <ellipse cx="180" cy="210" rx="71" ry="5"  fill="#020407"/>

    <!-- Cauldron body -->
    <g>
      <path d="M 112 220 C 108 268, 104 340, 122 386 C 138 412, 156 418, 180 418 C 204 418, 222 412, 238 386 C 256 340, 252 268, 248 220 Z" fill="url(#cavityFill)"/>
      <path d="M 108 220 C 104 268, 100 340, 118 388 C 134 414, 154 422, 180 422 C 206 422, 226 414, 242 388 C 260 340, 256 268, 252 220 Z" fill="url(#ironBody)" fill-opacity="0.42" stroke="#6b7686" stroke-width="1.4" stroke-opacity="0.85"/>
      <path d="M 112 220 C 108 268, 104 340, 122 386 C 138 412, 156 418, 180 418 C 204 418, 222 412, 238 386 C 256 340, 252 268, 248 220 Z" fill="none" stroke="#3a4250" stroke-width="0.6" stroke-opacity="0.7"/>

      <!-- Water + bubbles inside cauldron -->
      <g clip-path="url(#cauldronClip)">
        <rect x="96" y="304" width="168" height="120" fill="url(#waterFill)"/>
        <ellipse cx="180" cy="400" rx="78" ry="14" fill="#ffba59" opacity="0.32" filter="url(#softBlur)"/>
        <ellipse cx="180" cy="394" rx="58" ry="8"  fill="#ffe7a8" opacity="0.30" filter="url(#softBlur)"/>
        <g class="bubbles">
          {bubbles.map((b) => (
            <circle cx={b.cx} cy="392" r={b.r} fill="none" stroke="#ffe7a8" stroke-width="0.8" opacity="0">
              <animate attributeName="cy"      values="392;304" dur={`${b.dur}s`} begin={`${b.delay}s`} repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.85;0.85;0" keyTimes="0;0.2;0.85;1" dur={`${b.dur}s`} begin={`${b.delay}s`} repeatCount="indefinite"/>
              <animate attributeName="r"       values={`${b.r * 0.6};${b.r}`} dur={`${b.dur}s`} begin={`${b.delay}s`} repeatCount="indefinite"/>
            </circle>
          ))}
        </g>
        <g>
          <rect x="96" y="300" width="168" height="6" fill="url(#waterSurface)" opacity="0.85"/>
          <path d="M 106 304 Q 130 300, 154 304 T 202 304 T 254 304" stroke="#ffe7a8" stroke-width="0.8" fill="none" opacity="0.85">
            <animate attributeName="d" dur="2.2s" values="M 106 304 Q 130 300, 154 304 T 202 304 T 254 304;M 106 304 Q 130 308, 154 304 T 202 304 T 254 304;M 106 304 Q 130 300, 154 304 T 202 304 T 254 304" repeatCount="indefinite"/>
          </path>
          <path d="M 106 306 Q 140 302, 174 306 T 246 306" stroke="#ffba59" stroke-width="0.6" fill="none" opacity="0.6">
            <animate attributeName="d" dur="2.8s" values="M 106 306 Q 140 302, 174 306 T 246 306;M 106 306 Q 140 310, 174 306 T 246 306;M 106 306 Q 140 302, 174 306 T 246 306" repeatCount="indefinite"/>
          </path>
        </g>
      </g>

      <!-- External warm under-lighting on belly -->
      <ellipse cx="180" cy="408" rx="76" ry="34" fill="url(#ironUnderglow)" filter="url(#medBlur)"/>
      <ellipse cx="180" cy="408" rx="50" ry="16" fill="#ffba59" opacity="0.40" filter="url(#softBlur)"/>
      <ellipse cx="132" cy="244" rx="20" ry="8" fill="url(#ironHighlight)" opacity="0.7" filter="url(#softBlur)" transform="rotate(-22 132 244)"/>
    </g>
  </g>

  <!-- Flames under cauldron — outside wave filter -->
  <g>
    <g class="flame-outer">
      <path d="M 130 408 C 110 432, 102 462, 116 484 C 124 496, 140 500, 160 498 C 175 496, 188 492, 200 496 C 220 498, 236 496, 244 484 C 258 462, 250 432, 230 408 Z" fill="url(#flameO)" filter="url(#bigBlur)"/>
    </g>
    <g class="flame-mid">
      <path d="M 142 416 C 128 434, 122 462, 134 478 C 142 488, 154 492, 168 488 C 178 484, 188 484, 200 486 C 214 488, 226 484, 232 472 C 240 456, 232 432, 218 416 Z" fill="url(#flameM)" filter="url(#softBlur)"/>
    </g>
    <g class="flame-core">
      <path d="M 158 420 C 150 438, 148 460, 158 472 C 162 476, 166 476, 168 472 C 176 460, 174 438, 168 420 Z" fill="url(#flameC)"/>
      <path d="M 182 424 C 176 442, 176 464, 184 472 C 188 476, 192 474, 194 470 C 200 460, 198 442, 192 424 Z" fill="url(#flameC)" opacity="0.9"/>
      <path d="M 204 418 C 196 438, 196 462, 206 470 C 210 472, 214 470, 216 466 C 222 454, 218 434, 212 418 Z" fill="url(#flameC)" opacity="0.85"/>
    </g>
    <circle cx="163" cy="462" r="2.5" fill="#ffffff" opacity="0.95">
      <animate attributeName="opacity" values="0.5;1;0.5" dur="1.2s" repeatCount="indefinite"/>
    </circle>
    <circle cx="200" cy="462" r="2.5" fill="#ffffff" opacity="0.85">
      <animate attributeName="opacity" values="0.7;0.4;0.7" dur="1.4s" repeatCount="indefinite"/>
    </circle>
  </g>

  <!-- (Hearth stones slab removed — was reading as an unwanted dark bar
       under the flames on a light background.) -->
</svg>

<style>
  /* Flame breathing — CSS animations on the flame groups */
  :global(.flame-outer) {
    transform-origin: 50% 100%;
    animation: flame-breath-outer 3.2s ease-in-out infinite;
  }
  :global(.flame-mid) {
    transform-origin: 50% 100%;
    animation: flame-breath-mid 2.4s ease-in-out infinite;
  }
  :global(.flame-core) {
    transform-origin: 50% 100%;
    animation: flame-breath-core 1.8s ease-in-out infinite;
  }
  @keyframes flame-breath-outer {
    0%, 100% { transform: scale(1, 1); opacity: 0.95; }
    50%      { transform: scale(1.05, 1.08); opacity: 1; }
  }
  @keyframes flame-breath-mid {
    0%, 100% { transform: scale(1, 1); opacity: 0.92; }
    50%      { transform: scale(0.96, 1.06); opacity: 1; }
  }
  @keyframes flame-breath-core {
    0%, 100% { transform: scale(1, 1); }
    50%      { transform: scale(1.03, 1.1); }
  }

  /* Steam wisps — drifting up */
  :global(.steam-wisp) {
    animation: steam-rise 5s ease-out infinite;
    opacity: 0;
    transform-origin: 50% 100%;
  }
  :global(.steam-wisp.s1) { animation-delay: 0s; }
  :global(.steam-wisp.s2) { animation-delay: 0.6s; }
  :global(.steam-wisp.s3) { animation-delay: 1.4s; }
  :global(.steam-wisp.s4) { animation-delay: 2.2s; }
  @keyframes steam-rise {
    0%   { opacity: 0;   transform: translateY(8px) scale(0.7); }
    20%  { opacity: 0.6; }
    60%  { opacity: 0.5; }
    100% { opacity: 0;   transform: translateY(-40px) scale(1.2); }
  }
</style>
