---
import { useTranslations, ui, type Lang } from "~/i18n/ui";

interface Props {
  lang?: Lang;
}

const { lang = "zh" } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const titleZh = "熱聲實驗室";
const titleEn = "Thermoacoustic Lab";
const addressLines = ui[lang]["footer.address_lines"];
const contactHref = lang === "en" ? "/en/contact" : "/contact";
---

<footer class="mt-24 bg-brand-900 text-brand-100">
  <div
    class="mx-auto grid max-w-6xl gap-8 px-6 py-12 md:grid-cols-3 md:gap-12"
  >
    <div>
      <p class="text-lg font-semibold text-white">
        {lang === "en" ? titleEn : titleZh}
      </p>
      <p class="text-sm uppercase tracking-widest text-brand-300">
        {lang === "en" ? titleZh : titleEn}
      </p>
      <p class="mt-4 text-sm leading-relaxed">
        {addressLines.map((line, i) => (
          <>
            {line}
            {i < addressLines.length - 1 && <br />}
          </>
        ))}
      </p>
    </div>

    <div>
      <p class="text-sm font-medium text-white">{t("footer.contact")}</p>
      <p class="mt-3 text-sm leading-relaxed">
        📞 (02) 2771-2171 #2086<br />
        📧 <a
          href="mailto:bookhsu@ntut.edu.tw"
          class="underline transition hover:text-accent-400"
        >
          bookhsu@ntut.edu.tw
        </a>
      </p>
      <p class="mt-3 text-sm">
        <a
          href={contactHref}
          class="underline transition hover:text-accent-400"
        >
          {t("footer.contact_us")}
        </a>
      </p>
    </div>

    <div>
      <p class="text-sm font-medium text-white">{t("footer.external")}</p>
      <ul class="mt-3 space-y-1 text-sm">
        <li>
          <a
            href="https://orcid.org/0000-0002-3014-2013"
            target="_blank"
            rel="noopener"
            class="underline transition hover:text-accent-400"
          >
            ORCID
          </a>
        </li>
        <li>
          <a
            href="https://www.ntut.edu.tw/"
            target="_blank"
            rel="noopener"
            class="underline transition hover:text-accent-400"
          >
            {t("footer.ntut")}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-brand-700">
    <div
      class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 text-xs text-brand-300"
    >
      <p>© {year} {t("footer.copyright")}</p>
      <p class="font-mono">thermoacoustictw.org</p>
    </div>
  </div>
</footer>
