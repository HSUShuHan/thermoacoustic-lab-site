---
const navItems = [
  { href: "/", label: "首頁" },
  { href: "/research", label: "研究" },
  { href: "/publications", label: "發表" },
  { href: "/media", label: "影像" },
  { href: "/projects", label: "計畫" },
  { href: "/people", label: "成員" },
  { href: "/join-us", label: "加入我們" },
  { href: "/news", label: "近況" },
  { href: "/contact", label: "聯絡" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="border-b border-brand-100 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="group flex items-baseline gap-3">
      <span class="text-xl font-bold tracking-tight text-brand-800">
        熱聲實驗室
      </span>
      <span
        class="hidden text-xs uppercase tracking-widest text-brand-400 sm:inline"
      >
        Thermoacoustic Lab
      </span>
    </a>
    <nav>
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "transition",
                  isActive(item.href)
                    ? "border-b-2 border-accent-500 pb-0.5 font-medium text-brand-800"
                    : "text-gray-700 hover:text-brand-700",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
