---
// Traveling-wave Stirling / TASHE animation
// Physics ported from G. W. Swift's `Tashe.py` (LANL bookAnimations 2015)
// Three sub-modes: Stirling (s), isolated (i), thermoacoustic (t)
// LANL Disclaimer: LA-UR 99-895; permission granted to copy/use with notice + authorship reproduced
---

<figure class="tashe-anim not-prose" data-mode="thermoacoustic">
  <div class="ta-tabs" role="tablist" aria-label="模式選擇">
    <button type="button" data-mode="stirling" role="tab">
      (s)tirling 機械式
    </button>
    <button type="button" data-mode="isolated" role="tab">
      (i)solated 單活塞 + 聲學負載
    </button>
    <button
      type="button"
      data-mode="thermoacoustic"
      role="tab"
      aria-selected="true"
      class="active"
    >
      (t)hermoacoustic 純熱聲
    </button>
  </div>

  <svg
    class="ta-svg"
    viewBox="-30 0 830 720"
    role="img"
    aria-label="行波型 Stirling 熱聲引擎動畫"
    xmlns="http://www.w3.org/2000/svg"
  >
    <desc>
      氣塊在 closed-loop 中循環，經歷蓄熱器（regenerator）+ 熱端/冷端熱交換器；同步顯示 Stirling PV 軌跡、regenerator 內部氣塊溫度追蹤、p-u 同相相位圖。3 種 sub-mode：機械式 Stirling、隔離式、純熱聲。
    </desc>

    <defs>
      <!-- Heat arrow marker (same as v1) -->
      <marker
        id="tashe-heat"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="5"
        markerHeight="5"
        orient="auto"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#dc2626"></path>
      </marker>

      <!-- Axis arrowhead -->
      <marker
        id="tashe-axis-arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#1e3a5f"></path>
      </marker>

      <!-- Hot end gradient (right) -->
      <linearGradient id="tashe-grad-hot" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#fed7aa"></stop>
        <stop offset="100%" stop-color="#fca5a5"></stop>
      </linearGradient>
      <!-- Cold end gradient (left) -->
      <linearGradient id="tashe-grad-cold" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#bae6fd"></stop>
        <stop offset="100%" stop-color="#dbeafe"></stop>
      </linearGradient>
      <!-- Regenerator wall-T gradient (cold left → hot right) -->
      <linearGradient id="tashe-grad-reg" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#bae6fd"></stop>
        <stop offset="100%" stop-color="#fca5a5"></stop>
      </linearGradient>
    </defs>

    <!-- ═══════════ Panel (a): Loop topology ═══════════ -->
    <!-- Three mode-specific subgroups, each containing its own complete
         geometry. CSS [data-mode] selectors hide the inactive groups. -->
    <g id="tashe-loop" transform="translate(40, 60)">
      <text
        id="tashe-loop-title"
        x="360"
        y="-26"
        font-size="12"
        fill="#1e3a5f"
        text-anchor="middle"
        font-weight="600">(a) Loop 拓樸 · 純熱聲行波模式</text>

      <!-- ─────────────── (s) α-type Stirling — placeholder ─────────────── -->
      <g class="tashe-only-s">
        <rect x="0" y="40" width="720" height="160" fill="#f8fafc"
              stroke="#cbd5e1" stroke-width="1" rx="10"></rect>
        <text x="360" y="125" font-size="11" fill="#94a3b8" text-anchor="middle"
          >α 型 Stirling 引擎（下個迭代加上）</text>
      </g>

      <!-- ─────────────── (i) Isolated · 直管 + cold/buffer pistons ───────── -->
      <g class="tashe-only-i">
        <!-- Outline: single straight horizontal tube -->
        <rect x="60" y="130" width="540" height="60" fill="white"
              stroke="#1e3a5f" stroke-width="2"></rect>

        <!-- Cold HX (blue) -->
        <rect x="80" y="132" width="40" height="56" fill="url(#tashe-grad-cold)"
              stroke="#0e7490" stroke-width="0.5"></rect>
        <text x="100" y="208" font-size="10" fill="#0e7490" text-anchor="middle"
              font-weight="500">cold HX</text>

        <!-- Regenerator -->
        <g transform="translate(140, 132)">
          <rect width="120" height="56" fill="#f1f5f9"></rect>
          <g stroke="#475569" stroke-width="0.6" opacity="0.6">
            <line x1="0" y1="7" x2="120" y2="7"></line>
            <line x1="0" y1="14" x2="120" y2="14"></line>
            <line x1="0" y1="21" x2="120" y2="21"></line>
            <line x1="0" y1="28" x2="120" y2="28"></line>
            <line x1="0" y1="35" x2="120" y2="35"></line>
            <line x1="0" y1="42" x2="120" y2="42"></line>
            <line x1="0" y1="49" x2="120" y2="49"></line>
          </g>
        </g>
        <text x="200" y="208" font-size="10" fill="#475569" text-anchor="middle"
              font-weight="500">regenerator</text>

        <!-- Hot HX -->
        <rect x="280" y="132" width="40" height="56" fill="url(#tashe-grad-hot)"
              stroke="#b91c1c" stroke-width="0.5"></rect>
        <text x="300" y="208" font-size="10" fill="#b91c1c" text-anchor="middle"
              font-weight="500">hot HX</text>

        <text x="470" y="220" font-size="10" fill="#475569" text-anchor="middle"
          >thermal buffer tube</text>

        <!-- Cold piston -->
        <g>
          <rect id="tashe-i-leftpiston" x="36" y="132" width="22" height="56"
                fill="#16a34a" fill-opacity="0.85" stroke="#15803d"
                stroke-width="1"></rect>
          <text x="47" y="225" font-size="10" fill="#16a34a"
                text-anchor="middle" font-weight="500">cold piston</text>
        </g>
        <!-- Buffer piston -->
        <g>
          <rect id="tashe-i-bufpiston" x="560" y="132" width="22" height="56"
                fill="#475569" fill-opacity="0.85" stroke="#1e293b"
                stroke-width="1"></rect>
          <text x="571" y="225" font-size="10" fill="#475569"
                text-anchor="middle" font-weight="500">buffer piston</text>
        </g>

        <!-- Smoke tracers (i mode) -->
        <g class="tashe-smoke-i" stroke="#0891b2" stroke-width="1" opacity="0.7">
          <line class="tashe-smoke" data-x0="100" data-zone="cold"
                x1="100" y1="132" x2="100" y2="188"></line>
          <line class="tashe-smoke" data-x0="130" data-zone="cold"
                x1="130" y1="132" x2="130" y2="188"></line>
          <line class="tashe-smoke" data-x0="170" data-zone="reg"
                x1="170" y1="132" x2="170" y2="188"></line>
          <line class="tashe-smoke" data-x0="200" data-zone="reg"
                x1="200" y1="132" x2="200" y2="188"></line>
          <line class="tashe-smoke" data-x0="230" data-zone="reg"
                x1="230" y1="132" x2="230" y2="188"></line>
          <line class="tashe-smoke" data-x0="290" data-zone="hot"
                x1="290" y1="132" x2="290" y2="188"></line>
          <line class="tashe-smoke" data-x0="380" data-zone="buf"
                x1="380" y1="132" x2="380" y2="188"></line>
          <line class="tashe-smoke" data-x0="450" data-zone="buf"
                x1="450" y1="132" x2="450" y2="188"></line>
          <line class="tashe-smoke" data-x0="520" data-zone="buf"
                x1="520" y1="132" x2="520" y2="188"></line>
        </g>
      </g>

      <!-- ─────────────── (t) Thermoacoustic · TASHE racetrack ─────────────── -->
      <!-- Topology matches Swift Springer Handbook of Acoustics Fig 7.3c:
           bottom branch (active) holds T_A | regen | T_H | TBT | T_A;
           top branch is the feedback path. Q_A flows OUT at the two T_A's;
           Q_H flows IN at T_H. -->
      <g class="tashe-only-t">
        <!-- Outer racetrack: wider span (curves at x=90/630, channel width 60). -->
        <path
          d="M 90 190 H 630 A 80 80 0 0 0 630 30 H 90 A 80 80 0 0 0 90 190 Z"
          fill="white" stroke="#1e3a5f" stroke-width="2"></path>
        <!-- Inner cavity boundary -->
        <path
          d="M 90 130 H 630 A 20 20 0 0 0 630 90 H 90 A 20 20 0 0 0 90 130 Z"
          fill="#f8fafc" stroke="#1e3a5f" stroke-width="2"></path>

        <!-- Bottom channel components left-to-right (per Fig 7.3c):
             T_A | regenerator | T_H | thermal buffer tube | T_A -->
        <!-- Left T_A (ambient HX) -->
        <rect x="110" y="132" width="50" height="56" fill="url(#tashe-grad-cold)"
              stroke="#0e7490" stroke-width="0.5"></rect>
        <text x="135" y="208" font-size="10" fill="#0e7490" text-anchor="middle"
              font-weight="500">T<tspan dy="2" font-size="8">A</tspan></text>

        <!-- Regenerator (hatched) -->
        <g transform="translate(170, 132)">
          <rect width="200" height="56" fill="#f1f5f9"></rect>
          <g stroke="#475569" stroke-width="0.6" opacity="0.6">
            <line x1="0" y1="7" x2="200" y2="7"></line>
            <line x1="0" y1="14" x2="200" y2="14"></line>
            <line x1="0" y1="21" x2="200" y2="21"></line>
            <line x1="0" y1="28" x2="200" y2="28"></line>
            <line x1="0" y1="35" x2="200" y2="35"></line>
            <line x1="0" y1="42" x2="200" y2="42"></line>
            <line x1="0" y1="49" x2="200" y2="49"></line>
          </g>
        </g>
        <text x="270" y="208" font-size="10" fill="#475569" text-anchor="middle"
              font-weight="500">regenerator</text>

        <!-- T_H (hot HX) -->
        <rect x="380" y="132" width="50" height="56" fill="url(#tashe-grad-hot)"
              stroke="#b91c1c" stroke-width="0.5"></rect>
        <text x="405" y="208" font-size="10" fill="#b91c1c" text-anchor="middle"
              font-weight="500">T<tspan dy="2" font-size="8">H</tspan></text>

        <!-- Thermal buffer tube — plain channel section -->
        <text x="495" y="208" font-size="10" fill="#475569" text-anchor="middle"
          >thermal buffer tube</text>

        <!-- Right T_A (ambient HX) -->
        <rect x="560" y="132" width="50" height="56" fill="url(#tashe-grad-cold)"
              stroke="#0e7490" stroke-width="0.5"></rect>
        <text x="585" y="208" font-size="10" fill="#0e7490" text-anchor="middle"
              font-weight="500">T<tspan dy="2" font-size="8">A</tspan></text>

        <!-- Heat-flow arrows (Q̇_A out at the two T_A's; Q̇_H in at T_H) -->
        <g stroke="#dc2626" stroke-width="1.8" fill="none">
          <!-- Q̇_A out (left T_A) — arrow points OUT (downward, leaving tube) -->
          <line x1="135" y1="194" x2="135" y2="220"
                marker-end="url(#tashe-heat)"></line>
          <!-- Q̇_H in (T_H) — arrow points IN (upward, entering tube) -->
          <line x1="405" y1="220" x2="405" y2="194"
                marker-end="url(#tashe-heat)"></line>
          <!-- Q̇_A out (right T_A) -->
          <line x1="585" y1="194" x2="585" y2="220"
                marker-end="url(#tashe-heat)"></line>
        </g>
        <text x="135" y="234" font-size="9" fill="#dc2626" text-anchor="middle"
              font-style="italic">Q̇<tspan dy="2" font-size="7">A</tspan></text>
        <text x="405" y="234" font-size="9" fill="#dc2626" text-anchor="middle"
              font-style="italic">Q̇<tspan dy="2" font-size="7">H</tspan></text>
        <text x="585" y="234" font-size="9" fill="#dc2626" text-anchor="middle"
              font-style="italic">Q̇<tspan dy="2" font-size="7">A</tspan></text>

        <!-- Acoustic power output Ė_net (right side of loop) -->
        <line x1="640" y1="110" x2="680" y2="110" stroke="#d97706"
              stroke-width="2" marker-end="url(#tashe-heat)"></line>
        <text x="660" y="103" font-size="10" fill="#d97706" text-anchor="middle"
              font-style="italic" font-weight="500">Ė<tspan dy="2" font-size="7">net</tspan></text>

        <text x="360" y="225" font-size="10" fill="#475569" text-anchor="middle"
          >feedback path （上方）</text>

        <!-- Smoke tracers (t mode) — bottom (active) + top (feedback) -->
        <g stroke="#0891b2" stroke-width="1" opacity="0.7">
          <!-- Bottom: zones cold (left T_A), reg, hot (T_H), buf (TBT, right T_A) -->
          <line class="tashe-smoke" data-x0="135" data-zone="cold"
                x1="135" y1="132" x2="135" y2="188"></line>
          <line class="tashe-smoke" data-x0="200" data-zone="reg"
                x1="200" y1="132" x2="200" y2="188"></line>
          <line class="tashe-smoke" data-x0="270" data-zone="reg"
                x1="270" y1="132" x2="270" y2="188"></line>
          <line class="tashe-smoke" data-x0="340" data-zone="reg"
                x1="340" y1="132" x2="340" y2="188"></line>
          <line class="tashe-smoke" data-x0="405" data-zone="hot"
                x1="405" y1="132" x2="405" y2="188"></line>
          <line class="tashe-smoke" data-x0="470" data-zone="buf"
                x1="470" y1="132" x2="470" y2="188"></line>
          <line class="tashe-smoke" data-x0="525" data-zone="buf"
                x1="525" y1="132" x2="525" y2="188"></line>
          <line class="tashe-smoke" data-x0="585" data-zone="buf"
                x1="585" y1="132" x2="585" y2="188"></line>
          <!-- Top (feedback) -->
          <line class="tashe-smoke" data-x0="150" data-zone="fb"
                x1="150" y1="32" x2="150" y2="88"></line>
          <line class="tashe-smoke" data-x0="240" data-zone="fb"
                x1="240" y1="32" x2="240" y2="88"></line>
          <line class="tashe-smoke" data-x0="330" data-zone="fb"
                x1="330" y1="32" x2="330" y2="88"></line>
          <line class="tashe-smoke" data-x0="430" data-zone="fb"
                x1="430" y1="32" x2="430" y2="88"></line>
          <line class="tashe-smoke" data-x0="520" data-zone="fb"
                x1="520" y1="32" x2="520" y2="88"></line>
          <line class="tashe-smoke" data-x0="600" data-zone="fb"
                x1="600" y1="32" x2="600" y2="88"></line>
        </g>
      </g>
    </g>

    <!-- ═══════════ Panel (b): Stirling PV cycle ═══════════ -->
    <g id="tashe-pv" transform="translate(20, 320)">
      <text x="120" y="-26" font-size="12" fill="#1e3a5f" text-anchor="middle"
            font-weight="600">(b) 氣塊 Stirling PV 軌跡</text>
      <text x="120" y="-12" font-size="9" fill="#d97706" text-anchor="middle">
        ∮ <tspan font-style="italic">p</tspan> d<tspan font-style="italic">V</tspan> = <tspan font-style="italic">W</tspan>（一週期之功）
      </text>
      <line x1="0" y1="200" x2="0" y2="0" stroke="#1e3a5f" stroke-width="2"
            marker-end="url(#tashe-axis-arrow)"></line>
      <line x1="0" y1="200" x2="240" y2="200" stroke="#1e3a5f" stroke-width="2"
            marker-end="url(#tashe-axis-arrow)"></line>
      <text x="-18" y="100" font-size="11" fill="#1e3a5f" text-anchor="middle"
            font-weight="500" transform="rotate(-90 -18 100)"
        >壓力 <tspan font-style="italic">p</tspan></text>
      <text x="120" y="220" font-size="11" fill="#1e3a5f" text-anchor="middle"
        >體積 <tspan font-style="italic">V</tspan></text>

      <path
        id="tashe-pv-fill"
        d=""
        fill="#fcd34d"
        fill-opacity="0.18"
        stroke="none"></path>
      <path
        id="tashe-pv-loop"
        d=""
        fill="none"
        stroke="#d97706"
        stroke-width="1.8"></path>
      <circle id="tashe-pv-dot" cx="120" cy="100" r="5" fill="#d97706"></circle>
    </g>

    <!-- ═══════════ Panel (c): Lagrangian parcel close-up (Fig 7.3f) ═══════ -->
    <g id="tashe-reg" transform="translate(290, 320)">
      <text x="140" y="-26" font-size="12" fill="#1e3a5f" text-anchor="middle"
            font-weight="600">(c) Lagrangian 氣塊軌跡 · regenerator pore</text>
      <text x="140" y="-12" font-size="9" fill="#15803d" text-anchor="middle">
        4 步 Stirling 循環，pore size ≪ <tspan font-style="italic">δ</tspan><tspan dy="2" font-size="7">therm</tspan> → 氣塊 <tspan font-style="italic">T</tspan> ≡ 壁 <tspan font-style="italic">T</tspan>（isothermal）
      </text>

      <!-- Wall-T gradient background (cold-left → hot-right) -->
      <rect x="20" y="36" width="240" height="128" fill="url(#tashe-grad-reg)"
            opacity="0.5"></rect>

      <!-- Pore walls (top + bottom solid blocks representing the regenerator
           material between which gas oscillates). Hatched to suggest porous. -->
      <rect x="20" y="20" width="240" height="16" fill="#cbd5e1"
            stroke="#64748b" stroke-width="0.5"></rect>
      <rect x="20" y="164" width="240" height="16" fill="#cbd5e1"
            stroke="#64748b" stroke-width="0.5"></rect>

      <!-- T_A / T_H labels at the two ends -->
      <text x="20" y="14" font-size="10" fill="#0e7490" text-anchor="start"
            font-weight="500"
        ><tspan font-style="italic">T</tspan><tspan dy="2" font-size="8">A</tspan></text>
      <text x="260" y="14" font-size="10" fill="#b91c1c" text-anchor="end"
            font-weight="500"
        ><tspan font-style="italic">T</tspan><tspan dy="2" font-size="8">H</tspan></text>

      <!-- Four "ghost" parcel positions at the cycle corners (Fig 7.3f, 1–4).
           1: cold + compressed (narrow); 2: hot + compressed; 3: hot +
           expanded; 4: cold + expanded. JS will animate the live parcel
           through these. -->
      <g opacity="0.3" stroke="#0e7490" stroke-width="1" stroke-dasharray="2 2"
         fill="#0891b2" fill-opacity="0.2">
        <rect x="55" y="78" width="20" height="80" rx="2"></rect>
        <rect x="200" y="78" width="20" height="80" rx="2"></rect>
        <rect x="190" y="78" width="40" height="80" rx="2"></rect>
        <rect x="45" y="78" width="40" height="80" rx="2"></rect>
      </g>
      <g font-size="10" fill="#1e3a5f" font-weight="600" opacity="0.85">
        <text x="65" y="74" text-anchor="middle">1</text>
        <text x="210" y="74" text-anchor="middle">2</text>
        <text x="210" y="172" text-anchor="middle">3</text>
        <text x="65" y="172" text-anchor="middle">4</text>
      </g>

      <!-- Active parcel (JS animates x and width through the four steps). -->
      <rect id="tashe-reg-parcel" x="120" y="78" width="22" height="80" rx="2"
            fill="#0891b2" fill-opacity="0.85" stroke="#0e7490"
            stroke-width="1"></rect>

      <!-- Current step badge (JS sets text to 1/2/3/4 each frame). -->
      <g transform="translate(232, 50)">
        <circle r="14" fill="white" stroke="#1e3a5f" stroke-width="1.5"></circle>
        <text id="tashe-reg-step" x="0" y="4" font-size="14" fill="#1e3a5f"
              text-anchor="middle" font-weight="700">—</text>
      </g>
    </g>

    <!-- ═══════════ Panel (d): p-u phase diagram ═══════════ -->
    <g id="tashe-pu" transform="translate(580, 320)">
      <text x="100" y="-26" font-size="12" fill="#1e3a5f" text-anchor="middle"
            font-weight="600">(d) <tspan font-style="italic">p</tspan>–<tspan font-style="italic">u</tspan> 同相（行波）</text>
      <text x="100" y="-12" font-size="9" fill="#475569" text-anchor="middle">
        對照駐波 90° 相位差
      </text>

      {/* Skeleton — geometry coming in next iteration */}
      <rect
        x="0"
        y="0"
        width="200"
        height="200"
        fill="#f8fafc"
        stroke="#cbd5e1"
        stroke-width="1"
        rx="6"></rect>
      <text
        x="100"
        y="105"
        font-size="11"
        fill="#94a3b8"
        text-anchor="middle">[p-u phase diagram placeholder]</text>
    </g>
  </svg>

  <figcaption class="ta-caption">
    <p>
      <strong>圖：行波型 Stirling 熱聲引擎（TASHE，3 sub-mode）</strong>
      氣塊在 closed-loop 中循環，依序經過冷端熱交換器、regenerator、熱端熱交換器、buffer tube，回到起點。下方面板同步顯示 Stirling PV 軌跡、regenerator 內氣塊溫度追蹤、<i>p</i>–<i>u</i> 同相相位圖。可切換 (s) 機械式 Stirling、(i) 隔離式、(t) 純熱聲三種模式。
    </p>
    <p class="ta-attrib">
      物理參數沿用 G. W. Swift LANL bookAnimations 之
      <code>Tashe.py</code>
      （LA-UR 99-895；Condensed Matter and Thermal Physics Group, Los Alamos National Laboratory）。
      本實作為網頁原生重製，依 LANL 授權聲明使用。
    </p>
  </figcaption>
</figure>

<style>
  .tashe-anim {
    margin: 2.5rem 0;
    padding: 1.25rem 1rem 0.5rem;
    border: 1px solid var(--color-brand-100);
    border-radius: 0.5rem;
    background: linear-gradient(180deg, #fcfdff 0%, #f8fafc 100%);
  }

  .tashe-anim .ta-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tashe-anim .ta-tabs button {
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--color-brand-200);
    background: white;
    color: var(--color-brand-700);
    font-size: 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
    font-family: inherit;
  }
  .tashe-anim .ta-tabs button:hover {
    border-color: var(--color-brand-500);
    color: var(--color-brand-900);
  }
  .tashe-anim .ta-tabs button.active {
    background: var(--color-brand-800);
    border-color: var(--color-brand-800);
    color: white;
  }

  .tashe-anim .ta-svg {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    background: white;
    border-radius: 0.25rem;
  }

  /* Sub-mode visibility rules. Each tashe-only-{s,i,t} element shows only in
     the matching mode. CSS attribute selectors do this declaratively. */
  .tashe-anim .tashe-only-s,
  .tashe-anim .tashe-only-i,
  .tashe-anim .tashe-only-t {
    display: none;
  }
  .tashe-anim[data-mode="stirling"] .tashe-only-s {
    display: inline;
  }
  .tashe-anim[data-mode="isolated"] .tashe-only-i {
    display: inline;
  }
  .tashe-anim[data-mode="thermoacoustic"] .tashe-only-t {
    display: inline;
  }

  .tashe-anim .ta-caption {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.55;
  }
  .tashe-anim .ta-caption p {
    margin: 0.5rem 0;
  }
  .tashe-anim .ta-caption strong {
    color: var(--color-brand-900);
    font-weight: 600;
  }
  .tashe-anim .ta-attrib {
    font-size: 0.75rem;
    color: #64748b;
    border-top: 1px solid var(--color-brand-100);
    padding-top: 0.5rem;
    margin-top: 0.75rem !important;
  }
  .tashe-anim .ta-attrib code {
    background: white;
    padding: 1px 4px;
    border-radius: 2px;
    font-size: 0.7rem;
  }
</style>

<script>
  // ── Sub-mode → label map ──────────────────────────────────────────────
  type Mode = "stirling" | "isolated" | "thermoacoustic";

  // Phasor parameters from Swift's Tashe.py (re/im components for cos/sin
  // amplitudes of pressure and displacement at various points around the loop)
  const TASHE_PHYS = {
    reph: 7.0,
    imph: 0.0, // hot pressure phasor
    repc: 9.0,
    impc: -0.35, // cold pressure phasor
    rexh: -0.8,
    imxh: -1.4, // hot piston / hot HX gas displacement
    rexc: 1.0,
    imxc: -0.5, // cold piston / cold HX gas displacement
    rexb: -2.5,
    imxb: -1.4, // buffer piston gas displacement
  };

  const PERIOD = 5.0; // seconds for one ωt = 2π
  const TWO_PI = Math.PI * 2;

  function initTASHE(root: HTMLElement) {
    const tabs = root.querySelectorAll<HTMLButtonElement>("[data-mode]");
    let mode: Mode =
      (root.getAttribute("data-mode") as Mode) ?? "thermoacoustic";

    const titleByMode: Record<Mode, string> = {
      stirling: "(a) Loop 拓樸 · 機械式 Stirling 模式（雙活塞）",
      isolated: "(a) Loop 拓樸 · 單活塞 + 聲學負載（無回饋管）",
      thermoacoustic: "(a) Loop 拓樸 · 純熱聲行波模式（無活塞）",
    };
    const loopTitle = root.querySelector<SVGTextElement>("#tashe-loop-title")!;

    // Refs: i-mode pistons (anchor x positions in panel-local coords)
    const iLeftPiston = root.querySelector<SVGRectElement>("#tashe-i-leftpiston");
    const iBufPiston = root.querySelector<SVGRectElement>("#tashe-i-bufpiston");
    const smokeLines = root.querySelectorAll<SVGLineElement>(".tashe-smoke");

    // Anchor x coords (where each piston's left edge sits at ωt=0)
    const I_LP_X0 = 36; // i-mode cold piston
    const I_BP_X0 = 560; // i-mode buffer piston
    // Visual amplification factor (Swift's units 1.0 ≈ 1 unit; we want pixels)
    const DISP_K = 6;

    // Inertance phasor: gas displacement in the feedback pipe / buffer tube.
    // Computed from Swift's Tashe.py formula.
    const { rexc, imxc, rexh, imxh, rexb, imxb, reph, imph, repc, impc } =
      TASHE_PHYS;
    const denom = reph * impc - imph * repc;
    const num = rexc * impc - imxc * repc;
    const rexinert = (num * (reph - repc)) / denom;
    const imxinert = (num * (imph - impc)) / denom;

    // Pre-compute zone phasor functions: each smoke tracer's displacement is
    // a phasor blend depending on which "zone" it lives in. The mode active
    // at the time defines which `reg` span to use (i mode regen is at
    // x=140..260; t mode regen is at x=220..400).
    function zoneDisp(zone: string, cwt: number, swt: number, x0: number) {
      // Cold zone: matches cold-piston / cold-HX motion
      if (zone === "cold") return rexc * cwt - imxc * swt;
      // Hot zone: matches hot-end displacement
      if (zone === "hot") return rexh * cwt - imxh * swt;
      // Regenerator: blend cold→hot. Detect mode by x0 range:
      //   i mode regen: x=140..260; t mode regen: x=170..370
      if (zone === "reg") {
        const inT = x0 >= 170 && x0 <= 370;
        const lo = inT ? 170 : 140;
        const hi = inT ? 370 : 260;
        const f = (x0 - lo) / (hi - lo);
        const reC = rexc * cwt - imxc * swt;
        const reH = rexh * cwt - imxh * swt;
        return (1 - f) * reC + f * reH;
      }
      // Buffer tube (i mode): blend hot→buffer-piston
      if (zone === "buf") {
        const f = (x0 - 340) / 220;
        const reH = rexh * cwt - imxh * swt;
        const reB = rexb * cwt - imxb * swt;
        return (1 - f) * reH + f * reB;
      }
      // Feedback pipe (t mode): driven by inertance phasor
      if (zone === "fb") return rexinert * cwt - imxinert * swt;
      return 0;
    }

    function applyMode(newMode: Mode) {
      mode = newMode;
      root.setAttribute("data-mode", newMode);
      tabs.forEach((b) => {
        const sel = b.getAttribute("data-mode") === newMode;
        b.classList.toggle("active", sel);
        b.setAttribute("aria-selected", String(sel));
      });
      loopTitle.textContent = titleByMode[newMode];
    }

    tabs.forEach((b) =>
      b.addEventListener("click", () => {
        const m = b.getAttribute("data-mode") as Mode;
        if (m && m in titleByMode) applyMode(m);
      }),
    );

    // Keyboard shortcuts (s/i/t)
    root.tabIndex = 0;
    root.addEventListener("keydown", (e) => {
      const key = e.key.toLowerCase();
      const map: Record<string, Mode> = {
        s: "stirling",
        i: "isolated",
        t: "thermoacoustic",
      };
      if (map[key]) {
        applyMode(map[key]);
        e.preventDefault();
      }
    });

    applyMode(mode);

    let start: number | null = null;
    function frame(ts: number) {
      if (start === null) start = ts;
      const t = (ts - start) / 1000;
      const wt = (t / PERIOD) * TWO_PI;
      const cwt = Math.cos(wt);
      const swt = Math.sin(wt);

      // i-mode piston positions (only updated when refs exist).
      const dxc = (rexc * cwt - imxc * swt) * DISP_K;
      const dxb = (rexb * cwt - imxb * swt) * DISP_K;
      if (iLeftPiston) iLeftPiston.setAttribute("x", (I_LP_X0 + dxc).toFixed(1));
      if (iBufPiston) iBufPiston.setAttribute("x", (I_BP_X0 + dxb).toFixed(1));

      // Smoke tracers — each shifted along x by zoneDisp.
      smokeLines.forEach((line) => {
        const x0 = parseFloat(line.dataset.x0!);
        const zone = line.dataset.zone!;
        const dx = zoneDisp(zone, cwt, swt, x0) * DISP_K;
        line.setAttribute("transform", `translate(${dx.toFixed(1)} 0)`);
      });

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  document
    .querySelectorAll<HTMLElement>(".tashe-anim")
    .forEach((el) => initTASHE(el));
</script>
