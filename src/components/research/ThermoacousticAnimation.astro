---
// Standing-wave thermoacoustic 4-mode animation
// Physics 1:1 ported from G. W. Swift's `standing.py` (LANL bookAnimations 2015)
// LANL Disclaimer: LA-UR 99-895; permission granted to copy/use with notice + authorship reproduced

interface Props {
  lang?: "zh" | "en";
}
const { lang = "zh" } = Astro.props;
const isEn = lang === "en";

// Bilingual labels. The animation has 30+ Chinese strings inside the SVG and
// in the inline JS; consolidate them here so the rest of the file just reads
// from `L.*`.
const L = isEn
  ? {
      mode_select: "Mode selection",
      tab_flat: "(f)lat uniform",
      tab_refrigerator: "(r)efrigerator",
      tab_critical: "(c)ritical",
      tab_engine: "(e)ngine",
      title: "Standing-wave thermoacoustic mechanism · 4-mode animation",
      desc: "A gas parcel oscillates inside the stack; the figure simultaneously displays the parcel pressure–volume (PV) trajectory, the temperature–position (T–x) trajectory, and the wall temperature gradient. Three modes can be switched: uniform, refrigerator, and engine.",
      initial_perturbation: "Initial perturbation",
      mech_work_in: "Mechanical work input →",
      stack_header: "Resonator + stack",
      stack_arrow: "↓ stack",
      panel_c: "(c) Gas-parcel close-up (red arrows = radial heat transfer direction)",
      panel_b: "(b) Gas-parcel p–ξ / p–V trajectory",
      legend_I: "(acoustic intensity)",
      legend_W: "(work per cycle)",
      axis_pressure: "Pressure",
      axis_xi_or_V: "Displacement / Volume (normalized)",
      panel_d: "(d) Gas-parcel T–x (temperature–position) trajectory",
      panel_d_note1: "Similar to the 3D S–ξ projection: temperature in place of entropy",
      panel_d_note2:
        "(under adiabatic conditions d≡dS; loop area ∝ Q but dimensions differ)",
      axis_temperature: "Temperature",
      axis_displacement: "Displacement",
      wall_gradient: "Wall T gradient",
      panel_e: "(e) Gas-parcel (p, S, ξ) 3D orbit",
      panel_e_note: "Projected loop area × ω/(2π) = I (acoustic intensity), Q (heat flux), w (work source)",
      axis_entropy: "Entropy",
      proj_pxi: "projection",
      proj_sxi: "projection",
      proj_sp: "projection",
      caption_title: "Standing-wave thermoacoustic mechanism (4 modes)",
      caption_body:
        "A cyan gas parcel oscillates inside the stack. The top-left p–ξ / p–V panel overlays two trajectories: orange p–ξ (acoustic intensity I) and dashed cyan p–V (work per cycle W). The bottom-left T–x panel shows the parcel's temperature–position ellipse; the orange dashed line is the wall temperature gradient. The bottom-right 3D orbit panel synchronizes (p, S, ξ) and its three 2D projections.",
      attribution_pre: "Animation concepts based partially on G. W. Swift, ",
      attribution_book_title: "Thermoacoustics: A Unifying Perspective for Some Engines and Refrigerators",
      attribution_post:
        "; physics parameters follow LANL bookAnimations' standing.py (Los Alamos National Laboratory). The 3D-orbit concept is taken from T. Biwa, Introduction to Thermoacoustic Devices (Springer, 2023). This implementation is a native browser remake under the respective licenses.",
      stack_title_flat: "(a) Resonator + stack · uniform mode (no wall T gradient)",
      stack_title_refrigerator: "(a) Resonator + stack + left-end crank piston · refrigerator mode",
      stack_title_critical: "(a) Resonator + stack · critical mode (gradient equals parcel adiabatic)",
      stack_title_engine: "(a) Resonator + stack · engine mode (∇T > 0, hot right / cold left)",
    }
  : {
      mode_select: "模式選擇",
      tab_flat: "(f)lat 均溫",
      tab_refrigerator: "(r)efrigerator 製冷",
      tab_critical: "(c)ritical 臨界",
      tab_engine: "(e)ngine 引擎",
      title: "駐波型熱聲機制 4 模式動畫",
      desc: "氣塊在 stack 中往復振盪；同步顯示氣塊壓力—體積（PV）軌跡、氣塊溫度—位置（T—x）軌跡，及壁溫梯度。可切換 3 種模式：均溫、製冷、引擎。",
      initial_perturbation: "初始擾動",
      mech_work_in: "機械功輸入 →",
      stack_header: "共鳴管 + 片堆",
      stack_arrow: "↓ 片堆 (stack)",
      panel_c: "(c) 氣塊放大特寫（紅箭頭 = 徑向熱傳方向）",
      panel_b: "(b) 氣塊 壓力–位移 / 壓力–體積 軌跡",
      legend_I: "（聲音強度）",
      legend_W: "（一週期之功）",
      axis_pressure: "壓力",
      axis_xi_or_V: "位移 / 體積（歸一化）",
      panel_d: "(d) 氣塊 溫度–位置（T–x）軌跡",
      panel_d_note1: "形似 3D 熵（S）–位移（ξ）投影：以溫度替代熵",
      panel_d_note2: "（絕熱時 dT ∝ dS，環面積 ∝ Q 但量綱不同）",
      axis_temperature: "溫度",
      axis_displacement: "位移",
      wall_gradient: "壁溫梯度",
      panel_e: "(e) 氣塊 (p, S, ξ) 3D 軌道",
      panel_e_note: "投影面積 × ω/(2π) = I（聲音強度）, Q（熱流）, w（功源）",
      axis_entropy: "熵",
      proj_pxi: "投影",
      proj_sxi: "投影",
      proj_sp: "投影",
      caption_title: "駐波型熱聲機制（4 模式）",
      caption_body:
        "氣塊（青色）在 stack 中往復振盪。左上「壓力—位移 / 壓力—體積」面板同時顯示兩條軌跡：橙色 p–ξ（聲音強度 I 之概念）與青色虛線 p–V（一週期之功 W）。左下「T—x 軌跡」顯示氣塊溫度隨位置的橢圓變化；橘色虛線是壁溫梯度。右下 3D 軌道圖則把（p, S, ξ）三量之同步軌跡及其三個 2D 投影同時呈現。",
      attribution_pre: "Swift 動畫部分概念基於 G. W. Swift, ",
      attribution_book_title: "Thermoacoustics: A Unifying Perspective for Some Engines and Refrigerators",
      attribution_post:
        "，物理參數沿用 LANL bookAnimations 之 standing.py（Los Alamos National Laboratory）。3D 軌道圖之概念取自 T. Biwa, Introduction to Thermoacoustic Devices (Springer, 2023)。本實作為網頁原生重製，依各方授權聲明使用。",
      stack_title_flat: "(a) 共鳴管 + 片堆 · 均溫模式（無壁溫梯度）",
      stack_title_refrigerator: "(a) 共鳴管 + 片堆 + 左端曲柄活塞 · 製冷模式",
      stack_title_critical: "(a) 共鳴管 + 片堆 · 臨界模式（梯度恰等於氣塊絕熱）",
      stack_title_engine: "(a) 共鳴管 + 片堆 · 引擎模式（∇T > 0，右熱左冷）",
    };
---

<figure
  class="ta-anim not-prose"
  data-mode="engine"
  data-lang={lang}
  data-stack-flat={L.stack_title_flat}
  data-stack-refrigerator={L.stack_title_refrigerator}
  data-stack-critical={L.stack_title_critical}
  data-stack-engine={L.stack_title_engine}
>
  <div class="ta-tabs" role="tablist" aria-label={L.mode_select}>
    <button type="button" data-mode="flat" role="tab">{L.tab_flat}</button>
    <button type="button" data-mode="refrigerator" role="tab">
      {L.tab_refrigerator}
    </button>
    {/* Critical mode 已封存：對初學者門檻較高（需理解 ∇T_crit）。代碼保留，
        UI tab 隱藏；keyboard `c` shortcut 也保留以便除錯。 */}
    {/* <button type="button" data-mode="critical" role="tab">
      {L.tab_critical}
    </button> */}
    <button
      type="button"
      data-mode="engine"
      role="tab"
      aria-selected="true"
      class="active"
    >
      {L.tab_engine}
    </button>
  </div>

  <svg
    class="ta-svg"
    viewBox="-30 0 830 750"
    role="img"
    aria-labelledby="ta-title ta-desc"
  >
    <title id="ta-title">{L.title}</title>
    <desc id="ta-desc">{L.desc}</desc>

    <defs>
      <marker
        id="ta-heat"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="5"
        markerHeight="5"
        orient="auto"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#dc2626"></path>
      </marker>
      <marker
        id="ta-axis-arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#1e3a5f"></path>
      </marker>
      <!-- Wall-temperature gradients for the close-up panel.
           Convention: x positive to the right; engine has ∇T > 0 → right hot,
           left cold. Direction is the SAME across refrigerator/critical/engine
           (∇T > 0), only intensity differs.
           flat has no fill (CSS sets it to white). -->
      <linearGradient id="ta-grad-engine" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#60a5fa"></stop>
        <stop offset="100%" stop-color="#f87171"></stop>
      </linearGradient>
      <linearGradient id="ta-grad-critical" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#bfdbfe"></stop>
        <stop offset="100%" stop-color="#fecaca"></stop>
      </linearGradient>
      <linearGradient id="ta-grad-refrig" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#dbeafe"></stop>
        <stop offset="100%" stop-color="#fee2e2"></stop>
      </linearGradient>
    </defs>

    <!-- ═══════════ Panel 1: stack with parcel ═══════════ -->
    <g id="ta-stack" transform="translate(40, 60)">
      <!-- Resonator: open-LEFT + closed-RIGHT (right hot convention).
           Piston/crank assembly drives the open left end (refrigerator only). -->
      <!-- Top wall -->
      <line x1="0" y1="0" x2="680" y2="0" stroke="#1e3a5f" stroke-width="3"></line>
      <!-- Bottom wall -->
      <line x1="0" y1="110" x2="680" y2="110" stroke="#1e3a5f" stroke-width="3"></line>
      <!-- Right closed end (hot side in engine convention) -->
      <line x1="680" y1="0" x2="680" y2="110" stroke="#1e3a5f" stroke-width="3"></line>
      <!-- (Left end: open — no vertical wall) -->

      <!-- Wave fronts (xi-sheets): 23 vertical tracer lines that oscillate
           with the standing-wave gas displacement. JS animates `transform`. -->
      <g id="ta-wavefronts" stroke="#94a3b8" stroke-width="1" opacity="0.65">
        <line data-x0="50" x1="50" y1="6" x2="50" y2="104"></line>
        <line data-x0="75" x1="75" y1="6" x2="75" y2="104"></line>
        <line data-x0="100" x1="100" y1="6" x2="100" y2="104"></line>
        <line data-x0="125" x1="125" y1="6" x2="125" y2="104"></line>
        <line data-x0="150" x1="150" y1="6" x2="150" y2="104"></line>
        <line data-x0="175" x1="175" y1="6" x2="175" y2="104"></line>
        <line data-x0="200" x1="200" y1="6" x2="200" y2="104"></line>
        <line data-x0="225" x1="225" y1="6" x2="225" y2="104"></line>
        <line data-x0="250" x1="250" y1="6" x2="250" y2="104"></line>
        <line data-x0="275" x1="275" y1="6" x2="275" y2="104"></line>
        <line data-x0="300" x1="300" y1="6" x2="300" y2="104"></line>
        <line data-x0="325" x1="325" y1="6" x2="325" y2="104"></line>
        <line data-x0="350" x1="350" y1="6" x2="350" y2="104"></line>
        <line data-x0="375" x1="375" y1="6" x2="375" y2="104"></line>
        <line data-x0="400" x1="400" y1="6" x2="400" y2="104"></line>
        <line data-x0="425" x1="425" y1="6" x2="425" y2="104"></line>
        <line data-x0="450" x1="450" y1="6" x2="450" y2="104"></line>
        <line data-x0="475" x1="475" y1="6" x2="475" y2="104"></line>
        <line data-x0="500" x1="500" y1="6" x2="500" y2="104"></line>
        <line data-x0="525" x1="525" y1="6" x2="525" y2="104"></line>
        <line data-x0="550" x1="550" y1="6" x2="550" y2="104"></line>
        <line data-x0="575" x1="575" y1="6" x2="575" y2="104"></line>
        <line data-x0="600" x1="600" y1="6" x2="600" y2="104"></line>
      </g>

      <!-- Flat-mode initial perturbation indicator (open LEFT end).
           A red impulse arrow pointing INTO the resonator. CSS shows this
           only in flat mode; JS fades it out over the spiral span so it
           visually represents the one-time disturbance that excites the
           damped oscillation. -->
      <g id="ta-flat-impulse">
        <!-- Three short horizontal "wind" streaks just outside the open
             left end, curving slightly toward the opening — suggests a
             gust / breath that excites the column once. -->
        <path
          d="M -32 42 L -8 42 Q -2 42 2 47"
          stroke="#64748b"
          stroke-width="1.6"
          fill="none"
          stroke-linecap="round"></path>
        <path
          d="M -36 55 L -6 55 Q 0 55 4 55"
          stroke="#64748b"
          stroke-width="2"
          fill="none"
          stroke-linecap="round"></path>
        <path
          d="M -32 68 L -8 68 Q -2 68 2 63"
          stroke="#64748b"
          stroke-width="1.6"
          fill="none"
          stroke-linecap="round"></path>
        <text
          x="-12"
          y="30"
          font-size="10"
          fill="#475569"
          text-anchor="middle"
          font-weight="500">{L.initial_perturbation}</text>
      </g>

      <!-- Slider-crank piston assembly (refrigerator mode only).
           Mirror-flipped from Swift convention: piston now at LEFT (open) end,
           crank center at (-34, 40). R=10, rod L=44, piston width 22.
           Wrist range: 0..20 (stroke = 2R = 20 px).
           Z-order: piston / wheel / arm at back; conrod and joint pins on top. -->
      <g id="ta-crank-assembly">
        <!-- ── BACK layer ─────────────────────────────────── -->
        <!-- Piston block (slides horizontally). JS sets x. -->
        <rect
          id="ta-piston"
          x="0"
          y="3"
          width="22"
          height="104"
          fill="#16a34a"
          fill-opacity="0.85"
          stroke="#15803d"
          stroke-width="1"></rect>

        <!-- Crank wheel (rim, static circle). -->
        <circle
          cx="-34"
          cy="55"
          r="10"
          fill="white"
          stroke="#1e3a5f"
          stroke-width="1.5"></circle>
        <!-- Crank arm: from center to crank pin. JS updates x2/y2. -->
        <line
          id="ta-crank-arm"
          x1="-34"
          y1="55"
          x2="-24"
          y2="55"
          stroke="#1e3a5f"
          stroke-width="2"
          stroke-linecap="round"></line>
        <!-- Crank centre pivot (small fixed dot). -->
        <circle cx="-34" cy="55" r="2" fill="#1e3a5f"></circle>

        <!-- ── FRONT layer (drawn on top) ────────────────── -->
        <!-- Connecting rod: tilts as the crank rotates. JS updates both endpoints. -->
        <line
          id="ta-conrod"
          x1="0"
          y1="55"
          x2="-24"
          y2="55"
          stroke="#475569"
          stroke-width="3"
          stroke-linecap="round"></line>
        <!-- Wrist pin: joint between conrod and piston rod (slides with piston). -->
        <circle
          id="ta-wrist-pin"
          cx="0"
          cy="55"
          r="3.5"
          fill="#94a3b8"
          stroke="#1e293b"
          stroke-width="1.2"></circle>
        <!-- Crank pin: joint between conrod and crank arm (orbits on rim). -->
        <circle
          id="ta-crank-pin"
          cx="-24"
          cy="55"
          r="3.5"
          fill="#dc2626"
          stroke="#7f1d1d"
          stroke-width="1.2"></circle>

        <!-- Label below the crank-piston, identifying the external work input -->
        <text
          x="-22"
          y="124"
          font-size="10"
          font-weight="600"
          fill="#16a34a"
          text-anchor="middle">{L.mech_work_in}</text>
      </g>

      <!-- Stack region (between velocity & pressure node), x ≈ 460..620
           — moved to RIGHT side, near the closed (hot) end. -->
      <g id="ta-stack-plates">
        <!-- 8 horizontal plates, evenly spaced 14 px apart, positioned so
             that the channel between plates 48 and 62 is centered on the
             tracked parcel (y≈55). 7 channels in total. -->
        <line x1="460" y1="6" x2="620" y2="6" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="20" x2="620" y2="20" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="34" x2="620" y2="34" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="48" x2="620" y2="48" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="62" x2="620" y2="62" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="76" x2="620" y2="76" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="90" x2="620" y2="90" stroke="#1e3a5f" stroke-width="2"></line>
        <line x1="460" y1="104" x2="620" y2="104" stroke="#1e3a5f" stroke-width="2"></line>
      </g>

      <!-- Yellow oval highlight: zoom region around the tracked parcel.
           Centered on the wavefront at x0=530; size bounds parcel motion (~±15 px). -->
      <ellipse
        cx="530"
        cy="55"
        rx="22"
        ry="14"
        fill="none"
        stroke="#eab308"
        stroke-width="1.5"
        stroke-dasharray="3 2"></ellipse>

      <!-- The moving parcel: locked to wavefront at x0=530, co-moves with it.
           JS updates x and width every frame. -->
      <rect
        id="ta-parcel-stack"
        x="528"
        y="50"
        width="4"
        height="10"
        fill="#0891b2"
        rx="0.5"></rect>

      <!-- Panel header — JS rewrites text content per mode -->
      <text
        id="ta-stack-title"
        x="340"
        y="-26"
        font-size="12"
        fill="#1e3a5f"
        text-anchor="middle"
        font-weight="600">{L.stack_header}</text>
      <text x="530" y="-12" font-size="10" fill="#475569" text-anchor="middle">
        {L.stack_arrow}
      </text>
    </g>

    <!-- ═══════════ Panel 2: parcel close-up + heat arrows ═══════════ -->
    <!-- Larger panel: 340 wide × 200 tall content. -->
    <g id="ta-closeup" transform="translate(420, 230)">
      <!-- Wall-temperature gradient between plates; CSS controls fill by mode -->
      <rect
        id="ta-closeup-bg"
        x="0"
        y="12"
        width="280"
        height="146"
        opacity="0.7"></rect>
      <!-- two plate fragments, top and bottom -->
      <rect x="0" y="0" width="280" height="12" fill="#94a3b8"></rect>
      <rect x="0" y="158" width="280" height="12" fill="#94a3b8"></rect>

      <!-- Heat arrow lines (one above + one below parcel)
           JS sets x1/x2/y1/y2/stroke-width every frame to flip direction -->
      <line
        id="ta-heat-top-line"
        x1="140"
        y1="50"
        x2="140"
        y2="18"
        stroke="#dc2626"
        stroke-width="0"
        marker-end="url(#ta-heat)"></line>
      <line
        id="ta-heat-bot-line"
        x1="140"
        y1="120"
        x2="140"
        y2="152"
        stroke="#dc2626"
        stroke-width="0"
        marker-end="url(#ta-heat)"></line>

      <!-- The big parcel — JS updates its x and width -->
      <rect
        id="ta-parcel-big"
        x="115"
        y="58"
        width="50"
        height="54"
        fill="#0891b2"
        fill-opacity="0.85"
        stroke="#0e7490"
        stroke-width="1"
        rx="4"></rect>

      <text x="140" y="-26" font-size="12" fill="#1e3a5f" text-anchor="middle" font-weight="600">
        {L.panel_c}
      </text>
    </g>

    <!-- ═══════════ Panel 3: pressure-displacement (p-xi) + pressure-volume (p-V) ═══════════ -->
    <!-- Two overlaid traces:
         . p-xi (orange, primary) - matches Biwa Fig 6.2's I projection.
         . p-V (cyan dashed)      - classical thermo PV-loop, loop area = work. -->
    <g id="ta-pv" transform="translate(20, 230)">
      <text x="120" y="-26" font-size="12" fill="#1e3a5f" text-anchor="middle" font-weight="600">
        {L.panel_b}
      </text>
      <text x="120" y="-12" font-size="9" text-anchor="middle">
        <tspan fill="#d97706">∮ <tspan font-style="italic">p</tspan> d<tspan font-style="italic">ξ</tspan> × <tspan font-style="italic">ω</tspan>/(2π) = <tspan font-style="italic">I</tspan>{L.legend_I}</tspan>
        <tspan fill="#475569"> · </tspan>
        <tspan fill="#0e7490">∮ <tspan font-style="italic">p</tspan> d<tspan font-style="italic">V</tspan> = <tspan font-style="italic">W</tspan>{L.legend_W}</tspan>
      </text>
      <!-- Axes (with arrowheads) -->
      <line x1="0" y1="170" x2="0" y2="0" stroke="#1e3a5f" stroke-width="2"
            marker-end="url(#ta-axis-arrow)"></line>
      <line x1="0" y1="170" x2="240" y2="170" stroke="#1e3a5f" stroke-width="2"
            marker-end="url(#ta-axis-arrow)"></line>
      <text
        x="-18"
        y="85"
        font-size="11"
        fill="#1e3a5f"
        text-anchor="middle"
        font-weight="500"
        transform="rotate(-90 -18 85)">{L.axis_pressure} <tspan font-style="italic">p</tspan></text>
      <text x="120" y="190" font-size="11" fill="#1e3a5f" text-anchor="middle"
        >{isEn ? "Displacement" : "位移"} <tspan font-style="italic">ξ</tspan> / {isEn ? "Volume" : "體積"} <tspan font-style="italic">V</tspan> {isEn ? "(normalized)" : "（歸一化）"}</text>

      <!-- p–ξ filled cycle (orange) — primary trace = I projection -->
      <path
        id="ta-pv-fill"
        d=""
        fill="#fcd34d"
        fill-opacity="0.18"
        stroke="none"></path>
      <path
        id="ta-pv-loop"
        d=""
        fill="none"
        stroke="#d97706"
        stroke-width="1.8"></path>

      <!-- p–V cycle (cyan dashed) — classical thermodynamic PV loop -->
      <path
        id="ta-pv-loop-V"
        d=""
        fill="none"
        stroke="#0e7490"
        stroke-width="1.4"
        stroke-dasharray="4 3"
        opacity="0.9"></path>

      <!-- Moving dot on the p–ξ trace -->
      <circle id="ta-pv-dot" cx="120" cy="100" r="5" fill="#d97706"></circle>
      <!-- Moving dot on the p–V trace -->
      <circle
        id="ta-pv-dot-V"
        cx="120"
