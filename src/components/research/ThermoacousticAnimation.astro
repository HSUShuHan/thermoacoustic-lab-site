            marker-end="url(#ta-axis-arrow)"></line>
      <line x1="0" y1="200" x2="240" y2="200" stroke="#1e3a5f" stroke-width="2"
            marker-end="url(#ta-axis-arrow)"></line>
      <text
        x="-18"
        y="100"
        font-size="11"
        fill="#1e3a5f"
        text-anchor="middle"
        font-weight="500"
        transform="rotate(-90 -18 100)">{L.axis_temperature} <tspan font-style="italic">T</tspan></text>
      <text x="120" y="220" font-size="11" fill="#1e3a5f" text-anchor="middle"
        >{L.axis_displacement} <tspan font-style="italic">ξ</tspan></text>

      <!-- Wall (plate) temperature gradient — orange. -->
      <line
        id="ta-wall-line"
        x1="15"
        y1="100"
        x2="225"
        y2="100"
        stroke="#ea580c"
        stroke-width="2"
        stroke-dasharray="4 3"></line>
      <text
        id="ta-wall-label"
        x="232"
        y="104"
        font-size="10"
        font-weight="500"
        fill="#ea580c"
        text-anchor="start">{L.wall_gradient}</text>

      <!-- Gas temperature ellipse / loop trace.
           Color: a darker variant of the Q-projection green (#16a34a) — close
           to but distinct from it, signaling "related but not equivalent". -->
      <path
        id="ta-tx-loop"
        d=""
        fill="none"
        stroke="#15803d"
        stroke-width="1.8"></path>

      <!-- Moving dot -->
      <circle id="ta-tx-dot" cx="120" cy="100" r="5" fill="#15803d"></circle>
    </g>

    <!-- ═══════════ Panel 5: Biwa Fig 6.2 — 3D (p, S, ξ) orbit ═══════════ -->
    <g id="ta-biwa" transform="translate(420, 490)">
      <!-- Header (attribution to Biwa moved to figcaption below the SVG) -->
      <text
        x="180"
        y="-26"
        font-size="12"
        fill="#1e3a5f"
        text-anchor="middle"
        font-weight="600"
        >{L.panel_e}</text>
      <text
        x="180"
        y="-12"
        font-size="9"
        fill="#475569"
        text-anchor="middle"
        >{L.panel_e_note}</text>

      <!-- 3D box wireframe + axis arrows + ellipse + dot. JS draws into these. -->
      <g id="ta-biwa-box" stroke="#1e3a5f" fill="none"></g>
      <g id="ta-biwa-axes" fill="none"></g>
      <path
        id="ta-biwa-ellipse"
        d=""
        fill="none"
        stroke="#0891b2"
        stroke-width="1.8"
        opacity="0.9"></path>
      <!-- Three 2D projection ellipses on the back faces -->
      <path
        id="ta-biwa-proj-pxi"
        d=""
        fill="#fcd34d"
        fill-opacity="0.18"
        stroke="#d97706"
        stroke-width="1"
        stroke-dasharray="3 2"></path>
      <path
        id="ta-biwa-proj-sxi"
        d=""
        fill="#86efac"
        fill-opacity="0.18"
        stroke="#16a34a"
        stroke-width="1"
        stroke-dasharray="3 2"></path>
      <path
        id="ta-biwa-proj-sp"
        d=""
        fill="#c4b5fd"
        fill-opacity="0.18"
        stroke="#7c3aed"
        stroke-width="1"
        stroke-dasharray="3 2"></path>
      <!-- Moving dot at current (p, S, ξ) -->
      <circle
        id="ta-biwa-dot"
        cx="0"
        cy="0"
        r="5"
        fill="#0891b2"
        stroke="white"
        stroke-width="1"></circle>
      <!-- Axis labels (Chinese + italic Latin symbol) -->
      <text
        id="ta-biwa-label-p"
        x="0"
        y="0"
        font-size="11"
        font-weight="600"
        fill="#1e3a5f"
        text-anchor="middle">{L.axis_pressure} <tspan font-style="italic">p</tspan></text>
      <text
        id="ta-biwa-label-s"
        x="0"
        y="0"
        font-size="11"
        font-weight="600"
        fill="#1e3a5f"
        text-anchor="middle">{L.axis_entropy} <tspan font-style="italic">S</tspan></text>
      <text
        id="ta-biwa-label-xi"
        x="0"
        y="0"
        font-size="11"
        font-weight="600"
        fill="#1e3a5f"
        text-anchor="middle">{L.axis_displacement} <tspan font-style="italic">ξ</tspan></text>

      <!-- Vertical legend on the right side of the cube. -->
      <g transform="translate(255, 60)">
        <line x1="0" y1="0" x2="18" y2="0" stroke="#d97706" stroke-width="2" stroke-dasharray="3 2"></line>
        <text x="24" y="4" font-size="10" fill="#1e3a5f"><tspan font-style="italic">p</tspan>–<tspan font-style="italic">ξ</tspan> {L.proj_pxi} = <tspan font-weight="600" font-style="italic" fill="#d97706">I</tspan></text>
        <line x1="0" y1="22" x2="18" y2="22" stroke="#16a34a" stroke-width="2" stroke-dasharray="3 2"></line>
        <text x="24" y="26" font-size="10" fill="#1e3a5f"><tspan font-style="italic">S</tspan>–<tspan font-style="italic">ξ</tspan> {L.proj_sxi} ≈ <tspan font-weight="600" font-style="italic" fill="#16a34a">Q</tspan></text>
        <line x1="0" y1="44" x2="18" y2="44" stroke="#7c3aed" stroke-width="2" stroke-dasharray="3 2"></line>
        <text x="24" y="48" font-size="10" fill="#1e3a5f"><tspan font-style="italic">S</tspan>–<tspan font-style="italic">p</tspan> {L.proj_sp} = <tspan font-weight="600" font-style="italic" fill="#7c3aed">w</tspan></text>
      </g>
    </g>
  </svg>

  <figcaption class="ta-caption">
    <p>
      <strong>{isEn ? "Figure: " : "圖："}{L.caption_title}</strong>
      {L.caption_body}
    </p>
    <p class="ta-attrib">
