    <!-- ═══════════ Panel 4: T-x diagram ═══════════ -->
    <g id="ta-tx" transform="translate(20, 490)">
      <text x="120" y="-26" font-size="12" fill="#1e3a5f" text-anchor="middle" font-weight="600">
        {L.panel_d}
