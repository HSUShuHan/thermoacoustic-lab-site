</style>

<script>
  // ── Mode → phase parameter (Swift's standing.py) ─────────────────────
  type Mode = "flat" | "refrigerator" | "critical" | "engine";

  const phases: Record<Mode, number> = {
    flat: 0.14,
    refrigerator: 0.07,
    critical: 0.0,
    engine: -0.14,
  };

  const PERIOD = 5.0; // seconds for one ωt = 2π
  const TWO_PI = Math.PI * 2;

  // Flat mode: undriven damped oscillation. Trace this many cycles, decaying
  // from amplitude 1 to FLAT_DECAY_END (0 = full stop), pause FLAT_REST seconds
  // showing the parcel at rest, then loop back to full amplitude.
  const FLAT_CYCLES = 3;
  const FLAT_DECAY_END = 0;
  const FLAT_REST = 1.0; // seconds of stillness after the spiral collapses

  // SVG element coordinate constants (must match the static SVG above)
  // Resonator is 680 px wide (closed left at x=0, open right at x=680);
  // remaining ~80 px holds the crank-piston assembly in refrigerator mode.
  const RESO_LEN = 680;
  const WAVE_AMP = 25;
  const WAVE_SMALL = 4;

  // Parcel rest position — co-moves with wavefront at x0=530 (right side
  // of resonator, near the closed/hot end in right-hot convention).
  const STACK_X0 = 530;
  const PARCEL_W0 = 4;
  const PARCEL_W_AMP = 1.2;

  // Slider-crank kinematics (refrigerator mode).
  // Piston is to the RIGHT of the crank center (piston in resonator,
  // crank outside on the left of the open end).
  // x_wrist(θ) = Cx + R·cos(θ) + √(L² − R²·sin²(θ))
  // Stroke = 2R = 20 px; rod tilts so wrist x is NOT pure sinusoidal.
  const CRANK_CX = -34;
  const CRANK_CY = 55;
  const CRANK_R = 10;
  const ROD_LEN = 44;
  const PISTON_W = 22; // piston block width

  // Standing-wave displacement at any x0 in the stack panel:
  //   ξ(x0, ωt) = amp(x0)·cos(ωt) + small(x0)·sin(ωt)
  //
  // The resonator is OPEN at x=0 (piston-driven) and CLOSED at x=RESO_LEN.
  // Fundamental quarter-wave mode: displacement antinode at the open
  // end, node at the closed end. Sign chosen so that ξ(0, ωt=0) > 0,
  // matching the piston's rightmost position at ωt=0 — i.e. piston and
  // adjacent wavefronts are now IN PHASE.
  function xiAmp(x0: number) {
    return WAVE_AMP * Math.cos((Math.PI * x0) / (2 * RESO_LEN));
  }
  // Small traveling-wave term: largest at the OPEN/PISTON-driven end (LEFT, x=0)
  // and zero at the closed end (RIGHT, x=680). Sign flipped vs Swift due to
  // the spatial mirror.
  function xiSmall(x0: number) {
    return WAVE_SMALL * ((RESO_LEN - x0) / RESO_LEN);
  }

  const CLOSEUP_X0 = 140; // center of close-up panel (now 280 wide for symmetry with PV/T-x)
  const CLOSEUP_AMP_X = 100; // amplitude in close-up
  const PARCEL_BIG_W0 = 60;
  const PARCEL_BIG_W_AMP = 12;

  // PV diagram (axes 0..240 wide, 0..170 tall, origin at bottom-left)
  const PV_CX = 120; // center of trace
  const PV_CY_BOTTOM = 170;
  const PV_AMP_X = 70;
  const PV_AMP_Y = 50;
  const PV_CY = 95; // visual center y

  // T-x diagram (axes 0..240 wide, 0..200 tall — matches Biwa panel height)
  const TX_CX = 120;
  const TX_CY = 100;
  const TX_AMP_X = 95; // parcel position amplitude on x-axis
  const TX_AMP_T = 70; // parcel temperature deviation amplitude

  // Biwa 3D (p, S, ξ) panel — matches Biwa textbook Fig 6.2 axis convention:
  //   S' (entropy) is the VERTICAL axis (up).
  //   ξ' (displacement) goes right-and-down.
  //   p' (pressure) goes left-and-down (depth into the page).
  // World 3D axis mapping for project3D(x, y, z):
  //   x = ξ (right-down on screen)
  //   y = S (vertical up on screen)
  //   z = p (depth, left-down on screen)
  const BIWA_YAW = Math.PI / 5; // 36°  (more rotation = better separation)
  const BIWA_PITCH = -Math.PI / 7; // ≈ -26° (steeper top-down view)
  const BIWA_SCALE = 58;
  const BIWA_CX = 135; // centered so the p-axis label (extending left-down) stays in panel
  const BIWA_CY = 130; // shifted down so the upward S-axis fits below header
  function project3D(xi: number, p: number, s: number) {
    // Yaw around y-axis
    const x1 = xi * Math.cos(BIWA_YAW) - s * Math.sin(BIWA_YAW);
    const y1 = p;
    const z1 = xi * Math.sin(BIWA_YAW) + s * Math.cos(BIWA_YAW);
    // Pitch around x-axis
    const x2 = x1;
    const y2 = y1 * Math.cos(BIWA_PITCH) + z1 * Math.sin(BIWA_PITCH);
    return {
      x: BIWA_CX + x2 * BIWA_SCALE,
      y: BIWA_CY - y2 * BIWA_SCALE,
    };
  }

  // ── DOM refs ─────────────────────────────────────────────────────────
  function initAnimation(root: HTMLElement) {
    const tabs = root.querySelectorAll<HTMLButtonElement>("[data-mode]");
    const $ = (id: string) => root.querySelector<SVGGraphicsElement>("#" + id)!;

    const parcelStack = $("ta-parcel-stack") as unknown as SVGRectElement;
    const parcelBig = $("ta-parcel-big") as unknown as SVGRectElement;
    const pvDot = $("ta-pv-dot") as unknown as SVGCircleElement;
    const pvDotV = $("ta-pv-dot-V") as unknown as SVGCircleElement;
    const pvLoop = $("ta-pv-loop") as unknown as SVGPathElement;
    const pvLoopV = $("ta-pv-loop-V") as unknown as SVGPathElement;
    const pvFill = $("ta-pv-fill") as unknown as SVGPathElement;
    const txDot = $("ta-tx-dot") as unknown as SVGCircleElement;
    const txLoop = $("ta-tx-loop") as unknown as SVGPathElement;
    const wallLine = $("ta-wall-line") as unknown as SVGLineElement;
    const wavefronts = root.querySelectorAll<SVGLineElement>(
      "#ta-wavefronts line",
    );
    const piston = $("ta-piston") as unknown as SVGRectElement;
    const conrod = $("ta-conrod") as unknown as SVGLineElement;
    const crankArm = $("ta-crank-arm") as unknown as SVGLineElement;
    const wristPin = $("ta-wrist-pin") as unknown as SVGCircleElement;
    const crankPin = $("ta-crank-pin") as unknown as SVGCircleElement;
    const heatTop = $("ta-heat-top-line") as unknown as SVGLineElement;
    const heatBot = $("ta-heat-bot-line") as unknown as SVGLineElement;
    const biwaBox = $("ta-biwa-box") as unknown as SVGGElement;
    const biwaAxes = $("ta-biwa-axes") as unknown as SVGGElement;
    const biwaEllipse = $("ta-biwa-ellipse") as unknown as SVGPathElement;
    const biwaProjPxi = $("ta-biwa-proj-pxi") as unknown as SVGPathElement;
    const biwaProjSxi = $("ta-biwa-proj-sxi") as unknown as SVGPathElement;
    const biwaProjSp = $("ta-biwa-proj-sp") as unknown as SVGPathElement;
    const biwaDot = $("ta-biwa-dot") as unknown as SVGCircleElement;
    const biwaLabelP = $("ta-biwa-label-p") as unknown as SVGTextElement;
    const biwaLabelS = $("ta-biwa-label-s") as unknown as SVGTextElement;
    const biwaLabelXi = $("ta-biwa-label-xi") as unknown as SVGTextElement;
    const flatImpulse = $("ta-flat-impulse") as unknown as SVGGElement;

    // Build the 3D box wireframe + axis arrows + label positions
    // (one-time setup since the projection geometry is fixed).
    {
      const corners: { x: number; y: number }[] = [];
      for (let i = 0; i < 8; i++) {
        const xi = i & 1 ? 1 : -1;
        const p = i & 2 ? 1 : -1;
        const s = i & 4 ? 1 : -1;
        corners.push(project3D(xi, p, s));
      }
      // 12 edges of the cube. Light gray for non-axis edges; axis edges drawn
      // separately as colored arrows in a second pass.
      const edges: [number, number][] = [
        [0, 1], [2, 3], [4, 5], [6, 7], // ξ direction (corner 0→1 is the ξ axis)
        [0, 2], [1, 3], [4, 6], [5, 7], // p direction (corner 0→2 is the p axis)
        [0, 4], [1, 5], [2, 6], [3, 7], // S direction (corner 0→4 is the S axis)
      ];
      const axisEdges = new Set(["0-1", "0-2", "0-4"]);
      let edgesHtml = "";
      for (const [a, b] of edges) {
        if (axisEdges.has(`${a}-${b}`)) continue; // axes drawn separately
        edgesHtml += `<line x1="${corners[a].x.toFixed(1)}" y1="${corners[a].y.toFixed(1)}" x2="${corners[b].x.toFixed(1)}" y2="${corners[b].y.toFixed(1)}" stroke="#cbd5e1" stroke-width="1"/>`;
      }
      biwaBox.innerHTML = edgesHtml;

      // Axis arrows align with the three cube edges at corner 0 = (ξ,S,p) =
      // (−1,−1,−1) and extend past the +1 face. They visually become the
      // three edges meeting at that corner, exactly matching Biwa Fig 6.2.
      const axisOrigin = project3D(-1, -1, -1); // = corners[0]
      const axisXi = project3D(1.6, -1, -1); // ξ axis: from corner along bottom-back edge, past +ξ face
      const axisS = project3D(-1, 1.4, -1); // S axis: from corner upward, past +S face
      const axisP = project3D(-1, -1, 1.6); // p axis: from corner into depth, past +p face
      const axisAttrs =
        ' stroke="#1e3a5f" stroke-width="2" marker-end="url(#ta-axis-arrow)"';
      biwaAxes.innerHTML =
        `<line x1="${axisOrigin.x.toFixed(1)}" y1="${axisOrigin.y.toFixed(1)}" x2="${axisXi.x.toFixed(1)}" y2="${axisXi.y.toFixed(1)}"${axisAttrs}/>` +
        `<line x1="${axisOrigin.x.toFixed(1)}" y1="${axisOrigin.y.toFixed(1)}" x2="${axisS.x.toFixed(1)}" y2="${axisS.y.toFixed(1)}"${axisAttrs}/>` +
        `<line x1="${axisOrigin.x.toFixed(1)}" y1="${axisOrigin.y.toFixed(1)}" x2="${axisP.x.toFixed(1)}" y2="${axisP.y.toFixed(1)}"${axisAttrs}/>`;

      // Axis labels just past the arrow tip — small offsets so each label
      // sits clear of the cube body. CX=135 keeps even the leftmost label
      // (壓力 p) safely inside the panel with anchor=middle.
      const labelXi = project3D(1.85, -1, -1); // 位移 ξ
      const labelS = project3D(-1, 1.65, -1); // 熵 S
      const labelP = project3D(-1, -1, 1.85); // 壓力 p
      biwaLabelXi.setAttribute("x", (labelXi.x + 6).toFixed(1));
      biwaLabelXi.setAttribute("y", (labelXi.y + 16).toFixed(1));
      biwaLabelS.setAttribute("x", labelS.x.toFixed(1));
      biwaLabelS.setAttribute("y", (labelS.y - 2).toFixed(1));
      biwaLabelP.setAttribute("x", (labelP.x - 4).toFixed(1));
      biwaLabelP.setAttribute("y", (labelP.y + 4).toFixed(1));
    }

    // Build 3D ellipse path + 3 projection paths for current mode.
    function buildBiwaPaths(phase: number, mode: Mode) {
      const { cycles, N, closed } = flatTraceParams(mode);
      const main: string[] = [];
      const projP: string[] = [];
      const projS: string[] = [];
      const projSP: string[] = [];
      for (let i = 0; i <= N; i++) {
        const wt = ((i / N) * cycles) * TWO_PI;
        const d = decayAt(i, N, mode);
        const s = state(wt, phase, d);
        const xi = s.parcelXNorm;
        const pNorm = -s.pvyRaw - 0.5;
        const sNorm = s.parcelTDev / 0.3;
        const m = project3D(xi, sNorm, pNorm);
        const a = project3D(xi, -1, pNorm);
        const b = project3D(xi, sNorm, -1);
        const c = project3D(-1, sNorm, pNorm);
        const cmd = i === 0 ? "M " : "L ";
        main.push(cmd + m.x.toFixed(1) + " " + m.y.toFixed(1));
        projP.push(cmd + a.x.toFixed(1) + " " + a.y.toFixed(1));
        projS.push(cmd + b.x.toFixed(1) + " " + b.y.toFixed(1));
        projSP.push(cmd + c.x.toFixed(1) + " " + c.y.toFixed(1));
      }
      const close = closed ? " Z" : "";
      return {
        main: main.join(" ") + close,
        pxi: projP.join(" ") + close,
        sxi: projS.join(" ") + close,
        sp: projSP.join(" ") + close,
      };
    }

    let mode: Mode = (root.getAttribute("data-mode") as Mode) ?? "engine";

    // ── Compute one frame's state from ωt and phase ────────────────────
    // `decay` ∈ (0, 1] scales every oscillation amplitude around its mean —
    // used for flat-mode damped spiral. Default 1 = no decay.
    function state(wt: number, phase: number, decay: number = 1) {
      const cwt = Math.cos(wt);
      const swt = Math.sin(wt);

      // Parcel position — full spatial mirror of Swift (negate sign).
      // At ωt=0 parcel is at LEFT extreme (cold side in right-hot convention).
      //
      // Mode-dependent admixture: Swift's standing.py uses a fixed sin(ωt)
      // coefficient (≈0.0406), making parcelX mode-independent. That makes
      // the p–ξ ellipse area NOT track the mode — which contradicts our
      // pedagogical claim ω/(2π)·∮p dξ = I (acoustic intensity). To fix
      // it, scale the admixture linearly with `phase`: at critical (phase=0)
      // it vanishes (degenerate line, I=0), at |phase|=0.14 it matches
      // Swift's original magnitude (0.0406 = 0.29 × 0.14). Sign of the
      // admixture flips between engine and refrigerator so the loop
      // direction in p–ξ also flips, mirroring p–V behavior.
      // Phase admixture coefficient bumped from 0.29 (Swift's own value) to
      // 0.9 — exaggerates the p–ξ ellipse area for pedagogical clarity at the
      // cost of physical fidelity to Swift's standing.py.
      const parcelXNorm =
        (-(0.5556 * cwt + 0.9 * phase * swt) / 0.557) * decay;
      const parcelSize = 1 + 0.3 * cwt * decay;
      const parcelTDev = -0.3 * Math.cos(wt + 2.5 * phase + 0.073) * decay;

      // PV: pvx = cos(wt - phase) — decays around 0;
      // pvy = -0.5 + (oscillation around -0.5 with amp 0.8) — decays around -0.5
      const pvxRaw = Math.cos(wt - phase) * decay;
      const pvyRaw = -0.5 - 0.8 * cwt * decay;

      return { parcelXNorm, parcelSize, parcelTDev, pvxRaw, pvyRaw };
    }

    // ── Pre-compute traces for current mode ────────────────────────────
    // For flat mode, trace FLAT_CYCLES periods with a linear amplitude decay
    // so the path becomes an inward-shrinking spiral (damped oscillation).
    // For other modes, trace one closed cycle.
    function flatTraceParams(mode: Mode) {
      if (mode === "flat") {
        return { cycles: FLAT_CYCLES, N: 240, closed: false };
      }
      return { cycles: 1, N: 80, closed: true };
    }

    function decayAt(i: number, N: number, mode: Mode) {
      if (mode !== "flat") return 1;
      return 1 - (1 - FLAT_DECAY_END) * (i / N);
    }

    function buildPVPath(phase: number, mode: Mode) {
      const { cycles, N, closed } = flatTraceParams(mode);
      const pts: string[] = [];
      for (let i = 0; i <= N; i++) {
        const wt = ((i / N) * cycles) * TWO_PI;
        const d = decayAt(i, N, mode);
        const { parcelXNorm, pvyRaw } = state(wt, phase, d);
        const x = PV_CX + parcelXNorm * PV_AMP_X;
        const y = PV_CY - (pvyRaw + 0.5) * PV_AMP_Y * 1.5;
        pts.push((i === 0 ? "M " : "L ") + x.toFixed(1) + " " + y.toFixed(1));
      }
      return pts.join(" ") + (closed ? " Z" : "");
    }

    function buildPVPathOnV(phase: number, mode: Mode) {
      const { cycles, N, closed } = flatTraceParams(mode);
      const pts: string[] = [];
      for (let i = 0; i <= N; i++) {
        const wt = ((i / N) * cycles) * TWO_PI;
        const d = decayAt(i, N, mode);
        const { pvxRaw, pvyRaw } = state(wt, phase, d);
        const x = PV_CX + pvxRaw * PV_AMP_X;
        const y = PV_CY - (pvyRaw + 0.5) * PV_AMP_Y * 1.5;
        pts.push((i === 0 ? "M " : "L ") + x.toFixed(1) + " " + y.toFixed(1));
      }
      return pts.join(" ") + (closed ? " Z" : "");
    }

    function buildTXPath(phase: number, mode: Mode) {
      const { cycles, N, closed } = flatTraceParams(mode);
      const pts: string[] = [];
      for (let i = 0; i <= N; i++) {
        const wt = ((i / N) * cycles) * TWO_PI;
        const d = decayAt(i, N, mode);
        const { parcelXNorm, parcelTDev } = state(wt, phase, d);
        const x = TX_CX + parcelXNorm * TX_AMP_X;
        const y = TX_CY - (parcelTDev / 0.3) * TX_AMP_T;
        pts.push((i === 0 ? "M " : "L ") + x.toFixed(1) + " " + y.toFixed(1));
      }
      return pts.join(" ") + (closed ? " Z" : "");
    }

    const stackTitle = root.querySelector<SVGTextElement>("#ta-stack-title")!;
    // Mode titles are rendered server-side into data-stack-* attributes by the
    // bilingual frontmatter so we can stay locale-aware without re-loading JS.
    const titleByMode: Record<Mode, string> = {
      flat: root.dataset.stackFlat ?? "",
      refrigerator: root.dataset.stackRefrigerator ?? "",
      critical: root.dataset.stackCritical ?? "",
      engine: root.dataset.stackEngine ?? "",
    };

    function applyMode(newMode: Mode) {
      mode = newMode;
      root.setAttribute("data-mode", newMode);
      tabs.forEach((b) => {
        const sel = b.getAttribute("data-mode") === newMode;
        b.classList.toggle("active", sel);
        b.setAttribute("aria-selected", String(sel));
      });
      stackTitle.textContent = titleByMode[newMode];

      const phase = phases[newMode];

      // PV traces — both p–ξ (primary, orange) and p–V (secondary, cyan dashed)
      const pvD = buildPVPath(phase, newMode);
      const pvDV = buildPVPathOnV(phase, newMode);
      pvLoop.setAttribute("d", pvD);
      pvLoopV.setAttribute("d", pvDV);
      // Fill the primary p–ξ cycle (translucent amber) to highlight the area
      // = I; suppress fill for the degenerate critical mode and the open
      // spiral in flat mode.
      pvFill.setAttribute(
        "d",
        phase === 0 || newMode === "flat" ? "" : pvD,
      );

      // T-x trace
      txLoop.setAttribute("d", buildTXPath(phase, newMode));

      // Wall T line — convention: ∇T > 0 (right hot, left cold) for engine.
      // slopeMag here means dy/dx on the T-x plot; negative number means SVG y
      // decreases (= temperature INCREASES on screen) as x grows.
      const slopeMag = 4.286 * (phase - 0.14); // engine phase=-0.14 → -1.2
      const yL = TX_CY - slopeMag * TX_AMP_T; // left side y
      const yR = TX_CY + slopeMag * TX_AMP_T; // right side y
      wallLine.setAttribute("y1", yL.toFixed(1));
      wallLine.setAttribute("y2", yR.toFixed(1));

      // Biwa 3D ellipse + 3 projection ellipses
      const b = buildBiwaPaths(phase, newMode);
      biwaEllipse.setAttribute("d", b.main);
      biwaProjPxi.setAttribute("d", b.pxi);
      biwaProjSxi.setAttribute("d", b.sxi);
      biwaProjSp.setAttribute("d", b.sp);
    }

    // ── Animation loop ─────────────────────────────────────────────────
    let start: number | null = null;
    function frame(ts: number) {
      if (start === null) start = ts;
      const t = (ts - start) / 1000; // seconds
      // Flat mode: amplitude decays over FLAT_CYCLES periods (no driving force →
      // damped oscillation), then loops. Other modes are steady-state cycles.
      let wt: number;
      let decay: number;
      if (mode === "flat") {
        const span = PERIOD * FLAT_CYCLES;
        const totalSpan = span + FLAT_REST;
        const localT = t % totalSpan; // 0..(span+rest)
        if (localT < span) {
          // Active phase: parcel oscillates with linearly decaying amplitude.
          wt = (localT / PERIOD) * TWO_PI;
          decay = 1 - (1 - FLAT_DECAY_END) * (localT / span);
        } else {
          // Rest phase: parcel sits at equilibrium for FLAT_REST seconds.
          wt = 0;
          decay = 0;
        }
        // Initial-perturbation indicator: bright at the start of each spiral
        // span, fades to transparent within the first ~25% of the span.
        const flash = Math.max(0, 1 - (localT / span) / 0.25);
        flatImpulse.setAttribute("opacity", flash.toFixed(2));
      } else {
        wt = (t / PERIOD) * TWO_PI;
        decay = 1;
      }
      const phase = phases[mode];
      const s = state(wt, phase, decay);

      const cwt = Math.cos(wt);
      const swt = Math.sin(wt);

      // Stack panel parcel — co-moves with wavefront at STACK_X0 (=530, near
      // right closed end where stack plates are). Same formula as wavefronts.
      const parcelDx = xiAmp(STACK_X0) * cwt + xiSmall(STACK_X0) * swt;
      const sx = STACK_X0 + parcelDx;
      const sw = PARCEL_W0 + s.parcelSize * PARCEL_W_AMP - PARCEL_W_AMP;
      parcelStack.setAttribute("x", (sx - sw / 2).toFixed(1));
      parcelStack.setAttribute("width", Math.max(0.5, sw).toFixed(1));

      // Wave fronts (xi-sheets) — standing-wave gas displacement
      // using the same xiAmp/xiSmall functions as the parcel above.
      wavefronts.forEach((line) => {
        const x0 = parseFloat((line as SVGLineElement).dataset.x0!);
        const dx = xiAmp(x0) * cwt + xiSmall(x0) * swt;
        line.setAttribute("transform", `translate(${dx.toFixed(1)} 0)`);
      });

      // Slider-crank piston assembly (visible only in refrigerator mode via CSS).
      // Crank rotates at ωt; wrist x derived from constant rod-length constraint.
      const cpx = CRANK_CX + CRANK_R * cwt; // crank pin x (orbits)
      const cpy = CRANK_CY + CRANK_R * swt; // crank pin y
      // Piston is to the RIGHT of crank center → use + sqrt(...)
      const wristX =
        CRANK_CX +
        CRANK_R * cwt +
        Math.sqrt(ROD_LEN * ROD_LEN - CRANK_R * CRANK_R * swt * swt);
      const wxs = wristX.toFixed(1);
      const cpxs = cpx.toFixed(1);
      const cpys = cpy.toFixed(1);

      // Piston block — LEFT face at wrist pin (piston extends RIGHTWARD into resonator)
      piston.setAttribute("x", wristX.toFixed(1));
      // Crank arm — from center to crank pin
      crankArm.setAttribute("x2", cpxs);
      crankArm.setAttribute("y2", cpys);
      // Connecting rod — wrist pin → crank pin (tilts with θ)
      conrod.setAttribute("x1", wxs);
      conrod.setAttribute("x2", cpxs);
      conrod.setAttribute("y2", cpys);
      // Joint pins (drawn on top of conrod)
      wristPin.setAttribute("cx", wxs);
      crankPin.setAttribute("cx", cpxs);
      crankPin.setAttribute("cy", cpys);

      // Close-up parcel
      const cx = CLOSEUP_X0 + s.parcelXNorm * CLOSEUP_AMP_X;
      const cw = PARCEL_BIG_W0 + (s.parcelSize - 1) * PARCEL_BIG_W_AMP * 3;
      const cwClamped = Math.max(8, cw);
      parcelBig.setAttribute("x", (cx - cwClamped / 2).toFixed(1));
      parcelBig.setAttribute("width", cwClamped.toFixed(1));

      // PV dots — primary p–ξ trace + secondary p–V trace (both moving)
      const pvX = PV_CX + s.parcelXNorm * PV_AMP_X;
      const pvY = PV_CY - (s.pvyRaw + 0.5) * PV_AMP_Y * 1.5;
      pvDot.setAttribute("cx", pvX.toFixed(1));
      pvDot.setAttribute("cy", pvY.toFixed(1));
      const pvXV = PV_CX + s.pvxRaw * PV_AMP_X;
      pvDotV.setAttribute("cx", pvXV.toFixed(1));
      pvDotV.setAttribute("cy", pvY.toFixed(1));

      // Biwa 3D dot — same parcel projected to (ξ, S, p) world coords
      const biwaPos = project3D(
        s.parcelXNorm, // x = ξ
        s.parcelTDev / 0.3, // y = S (vertical, entropy stand-in (T as a proxy for S))
        -s.pvyRaw - 0.5, // z = p (depth, pressure deviation)
      );
      biwaDot.setAttribute("cx", biwaPos.x.toFixed(1));
      biwaDot.setAttribute("cy", biwaPos.y.toFixed(1));

      // T-x dot
      const txX = TX_CX + s.parcelXNorm * TX_AMP_X;
      const txY = TX_CY - (s.parcelTDev / 0.3) * TX_AMP_T;
      txDot.setAttribute("cx", txX.toFixed(1));
      txDot.setAttribute("cy", txY.toFixed(1));

      // ── Heat arrows ────────────────────────────────────────────────
      // FULL MIRROR (∇T > 0, right hot): both wall direction AND parcel position
      // are mirrored relative to Swift, so the two negations cancel — shaftW
      // formula reverts to Swift's exact form. shaftW > 0 → heat OUT, < 0 → heat IN.
      // Engine cycle: gas at right (hot) absorbs (shaftW < 0) at ωt=π,
      //               gas at left (cold) deposits (shaftW > 0) at ωt=0.
      const shaftW = s.parcelTDev - 1.5 * cwt * 1.49 * (phase - 0.14);
      const w = Math.min(8, Math.abs(shaftW) * 14);

      const xs = cx.toFixed(1);
      heatTop.setAttribute("x1", xs);
      heatTop.setAttribute("x2", xs);
      heatBot.setAttribute("x1", xs);
      heatBot.setAttribute("x2", xs);
      heatTop.setAttribute("stroke-width", w.toFixed(1));
      heatBot.setAttribute("stroke-width", w.toFixed(1));

      // Geometry constants for the (resized) close-up panel:
      //   top plate inner = y=12, parcel = y=58..112, bottom plate inner = y=158
      //   gap above parcel: y=12..58 (46 tall)
      //   gap below parcel: y=112..158 (46 tall)
      if (shaftW < 0) {
        // Heat IN to parcel from BOTH plates
        heatTop.setAttribute("y1", "18");
        heatTop.setAttribute("y2", "52");
        heatBot.setAttribute("y1", "152");
        heatBot.setAttribute("y2", "118");
      } else {
        // Heat OUT of parcel to BOTH plates
        heatTop.setAttribute("y1", "52");
        heatTop.setAttribute("y2", "18");
        heatBot.setAttribute("y1", "118");
        heatBot.setAttribute("y2", "152");
      }

      requestAnimationFrame(frame);
    }

    // ── Wire up tab clicks ─────────────────────────────────────────────
    tabs.forEach((b) =>
      b.addEventListener("click", () => {
        const m = b.getAttribute("data-mode") as Mode;
        if (m && m in phases) applyMode(m);
      }),
    );

    // ── Keyboard shortcuts (f/r/c/e), respect Swift's UI ──────────────
    root.tabIndex = 0;
    root.addEventListener("keydown", (e) => {
      const key = e.key.toLowerCase();
      const map: Record<string, Mode> = {
        f: "flat",
        r: "refrigerator",
        c: "critical",
        e: "engine",
      };
      if (map[key]) {
        applyMode(map[key]);
        e.preventDefault();
      }
    });

    applyMode(mode);
    requestAnimationFrame(frame);
  }

  // Initialize all instances on the page
  document
    .querySelectorAll<HTMLElement>(".ta-anim")
    .forEach((el) => initAnimation(el));
</script>
