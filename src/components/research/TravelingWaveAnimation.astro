---
// Traveling-wave (loop / TASHE) animation — v4.
// Aligned with the lab's research-overview Fig. 4 and Biwa Fig. 4.8.
//
// Pedagogical spine (Ceperley): a traveling wave IS a pistonless Stirling
// engine. Both devices share ONE straight core (cold HX – regenerator – hot
// HX) drawn at the same place with the same tube bore. The toggle swaps only
// what closes the two ends:
//   mechanical — two solid pistons in cylinders, 90° apart;
//   acoustic   — a constant-bore feedback loop; "oscillating gas columns"
//                (ghost pistons) play the pistons' role.
//
// Physics model (normalized, isothermal regenerator):
//   p'(t) = A·cos ωt,  u'(t) = A·cos(ωt+φ),  ξ'(t) = A·sin(ωt+φ)
//   V'(t) = A·[k_T·(r−1)·sin(ωt+φ) − k_C·cos ωt],   r = T_H/T_C
//   loop area ∝ (r−1)·cos φ → fat at φ=0 (traveling), a line at φ=90°
//   (standing): an isothermal regenerator does no work at standing-wave
//   phasing — why standing-wave engines need imperfect contact (χ″a).
//   Ideal regenerator: Ī gain G = 1+(r−1)cosφ and Q̄(x) = −Ī(x) (H̄ = 0).
interface Props {
  lang?: "zh" | "en";
}
const { lang = "zh" } = Astro.props;
const isEn = lang === "en";

const L = isEn
  ? {
      drive: "Drive",
      m_mech: "Mechanical α-Stirling",
      m_ac: "Traveling wave (TASHE)",
      s_phi: "Phase",
      s_phi_hint: "traveling ↔ standing",
      s_branch: "Branch length",
      s_branch_hint: "acoustic load → phase",
      s_ratio: "Temp ratio",
      s_ratio_hint: "regenerator T_H/T_C",
      s_amp: "Amplitude",
      s_amp_hint: "drive strength",
      title: "Traveling-wave Stirling engine — one cycle, two drives",
      desc: "Toggle the drive: solid pistons or an acoustic traveling wave. The shared core (cold HX – regenerator – hot HX) and every lower panel stay put — they describe the same cycle.",
      dev_mech: "(a) Mechanical α-Stirling — solid pistons",
      dev_ac: "(a) Looped thermoacoustic engine — the wave replaces the pistons",
      regen: "regenerator",
      comp: "compression piston",
      expn: "expansion piston",
      ghost: "oscillating gas column = piston",
      q_in: "heat in",
      q_out: "heat out",
      crest: "compressions travel around the loop — parcels only oscillate in place",
      flux: "(b) Energy flow diagram",
      flux_note: "ducts adiabatic (ωτ≫1): Q̄=0 · ideal regenerator: Q̄(x) = −Ī(x), H̄=0 · s̄=Q̄/T: flat = reversible (Carnot), sloped = entropy production",
      flux_in_ac: "Ī in (feedback loop)",
      flux_out_ac: "Ī out (amplified)",
      flux_in_mech: "W in (compression piston)",
      flux_out_mech: "W out (expansion piston)",
      pv: "(c) Stirling p–V",
      pv_note: "area = work / cycle",
      pore: "(d) Parcel in a regenerator pore",
      pore_note: "pore ≪ δα → parcel T ≡ wall T (isothermal)",
      phasor: "(e) p–u phase",
      cap_lead: "One cycle, two drives (cf. research overview Fig. 4).",
      cap: "The two solid pistons (90° apart) and the traveling wave (p–u in phase) drive the same isothermal Stirling cycle — in the acoustic device the oscillating gas columns at the regenerator ends play the role of the pistons. Heat flow Q̄ entering at the hot exchanger is converted along the regenerator into a growing work flow Ī (gain T_H/T_C). The closed branch tube is the acoustic load that tunes the field: at L = λ/4 it presents the traveling-wave condition (φ = 0, the loop runs traveling while the branch holds a standing wave); lengthen or shorten it and the phasing detunes toward standing (a one-parameter teaching simplification — the real mapping follows from the loop–branch transfer matrices). At φ = 90° the pistons fall into step, the p–V loop collapses and amplification stops — an isothermal regenerator does no work in a standing wave, which is why standing-wave engines must rely on imperfect thermal contact (χ″a) instead.",
      cap_link: "cf. Fig. 4 in the thermoacoustics overview",
    }
  : {
      drive: "驅動方式",
      m_mech: "機械式 α-Stirling",
      m_ac: "行波熱聲（TASHE）",
      s_phi: "相位差",
      s_phi_hint: "行波 ↔ 駐波",
      s_branch: "支管長度",
      s_branch_hint: "聲負載 → 相位",
      s_ratio: "溫度比",
      s_ratio_hint: "蓄熱器 T_H/T_C",
      s_amp: "振幅",
      s_amp_hint: "驅動強度",
      title: "行波型 Stirling 引擎 — 同一個循環，兩種驅動",
      desc: "切換驅動方式：固體活塞或行波。共用核心（冷端熱交換器–蓄熱器–熱端熱交換器）與下方所有面板不變 —— 它們描述同一個循環。",
      dev_mech: "(a) 機械式 α-Stirling — 固體活塞",
      dev_ac: "(a) 環形熱聲引擎 — 行波取代活塞",
      regen: "蓄熱器",
      comp: "壓縮活塞",
      expn: "膨脹活塞",
      ghost: "振盪氣柱＝活塞",
      q_in: "熱入",
      q_out: "熱出",
      crest: "疏密（壓縮帶）沿迴路傳播 — 氣塊僅原地往復",
      flux: "(b) 能量流線圖",
      flux_note: "管段絕熱（ωτ≫1）：Q̄=0 · 理想蓄熱器：Q̄(x) = −Ī(x)、H̄=0 · s̄=Q̄/T：水平＝可逆（Carnot）、傾斜＝熵生成",
      flux_in_ac: "Ī 入（迴路回授）",
      flux_out_ac: "Ī 出（已放大）",
      flux_in_mech: "W 入（壓縮活塞）",
      flux_out_mech: "W 出（膨脹活塞）",
      pv: "(c) Stirling p–V",
      pv_note: "面積 = 一週期之功",
      pore: "(d) 蓄熱器孔內的氣塊",
      pore_note: "孔徑 ≪ δα → 氣塊溫度 ≡ 壁溫（等溫）",
      phasor: "(e) p–u 相位",
      cap_lead: "同一個循環，兩種驅動（對照研究總論圖 4）。",
      cap: "雙固體活塞（相差 90°）與行波（p–u 同相）驅動同一個等溫 Stirling 循環 —— 行波裝置裡，蓄熱器兩端的「振盪氣柱」就扮演活塞的角色。熱流 Q̄ 自熱端交換器進入，沿蓄熱器被轉換成逐漸增厚的功流 Ī（放大率 T_H/T_C）。閉端支管是調諧聲場的聲負載：L = λ/4 時呈現行波條件（φ = 0，迴路跑行波、支管內站駐波）；拉長或縮短支管，相位便偏向駐波（此為單參數教學簡化，嚴謹映射需解迴路＋支管的傳遞行列）。φ = 90° 時活塞變成同步、p–V 迴圈塌成線、放大停止 —— 等溫蓄熱器在駐波中不做功，這正是駐波型引擎必須改靠不完全熱接觸（χ″a）的原因。",
      cap_link: "對照：熱聲效應總論 圖 4",
    };
---

<figure class="tw-anim not-prose" data-mode="acoustic" data-lang={lang}>
  <!-- ── Sticky controls: drive toggle + sliders (same pattern as 駐波頁) ── -->
  <div
    class="tw-controls sticky top-[68px] z-20 -mx-4 -mt-5 mb-2 flex flex-wrap items-center gap-x-5 gap-y-2 border-b border-brand-100 bg-white/95 px-4 py-3 backdrop-blur"
  >
    <div class="tw-tabs" role="tablist" aria-label={L.drive}>
      <span class="tw-tabs-label">{L.drive}</span>
      <button type="button" class="tw-tab" data-mode="mechanical" role="tab">{L.m_mech}</button>
      <button type="button" class="tw-tab active" data-mode="acoustic" role="tab" aria-selected="true"
        >{L.m_ac}</button
      >
    </div>
    <label class="tw-slider">
      <span class="tw-slider-name"
        >{L.s_phi} <span class="tw-sym">φ</span>
        <small>{L.s_phi_hint}</small></span
      >
      <input type="range" data-knob="phi" min="0" max="90" step="1" value="0" />
    </label>
    <label class="tw-slider" id="tw-branch-slider">
      <span class="tw-slider-name"
        >{L.s_branch} <span class="tw-sym">L<sub>b</sub></span>
        <small>{L.s_branch_hint}</small></span
      >
      <input type="range" data-knob="branch" min="0.05" max="0.45" step="0.01" value="0.25" />
    </label>
    <label class="tw-slider">
      <span class="tw-slider-name"
        >{L.s_ratio} <span class="tw-sym">T<sub>H</sub>/T<sub>C</sub></span>
        <small>{L.s_ratio_hint}</small></span
      >
      <input type="range" data-knob="ratio" min="1" max="3" step="0.05" value="2.2" />
    </label>
    <label class="tw-slider">
      <span class="tw-slider-name"
        >{L.s_amp}
        <small>{L.s_amp_hint}</small></span
      >
      <input type="range" data-knob="amp" min="0.3" max="1.2" step="0.05" value="1" />
    </label>
  </div>

  <svg class="tw-svg" viewBox="0 0 760 930" role="img" aria-labelledby="tw-title tw-desc">
    <title id="tw-title">{L.title}</title>
    <desc id="tw-desc">{L.desc}</desc>

    <defs>
      <pattern id="tw-mesh" width="6" height="6" patternUnits="userSpaceOnUse">
        <path d="M0 0 L6 6 M6 0 L0 6" stroke="#94a3b8" stroke-width="0.8"></path>
      </pattern>
      <marker id="tw-arr-i" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="4.5" markerHeight="4.5" orient="auto">
        <path d="M0 0 L10 5 L0 10 z" fill="#0e7490"></path>
      </marker>
      <marker id="tw-arr-hot" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
        <path d="M0 0 L10 5 L0 10 z" fill="#d72121"></path>
      </marker>
      <marker id="tw-arr-cool" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
        <path d="M0 0 L10 5 L0 10 z" fill="#58b3e5"></path>
      </marker>
      <marker id="tw-arr-axis" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M0 0 L10 5 L0 10 z" fill="#1e3a5f"></path>
      </marker>
      <linearGradient id="tw-pore-grad" x1="0" y1="0" x2="1" y2="0">
        <stop id="tw-pore-grad-l" offset="0%" stop-color="#ffffff"></stop>
        <stop id="tw-pore-grad-r" offset="100%" stop-color="#ffffff"></stop>
      </linearGradient>
    </defs>

    <!-- ═══════════ (a) Device — one straight core, two ways to close it ═══
         Core run centre-line y = 150, bore 31 (y ≈ 134…166). Acoustic mode
         closes it with a constant-bore racetrack loop (corner r = 52, top run
         y = 46); mechanical mode closes it with two piston cylinders. -->
    <g transform="translate(20, 100)">
      <text id="tw-dev-title" x="0" y="-16" font-size="12.5" fill="#1e3a5f" font-weight="600"
        >{L.dev_ac}</text
      >

      <!-- ── Acoustic: constant-bore feedback loop (racetrack ring) ── -->
      <g class="tw-only-ac">
        <path
          d="M 162 150 L 558 150 A 52 52 0 0 0 610 98 A 52 52 0 0 0 558 46 L 162 46 A 52 52 0 0 0 110 98 A 52 52 0 0 0 162 150 Z"
          fill="none"
          stroke="#0f172a"
          stroke-width="40"></path>
        <path
          d="M 162 150 L 558 150 A 52 52 0 0 0 610 98 A 52 52 0 0 0 558 46 L 162 46 A 52 52 0 0 0 110 98 A 52 52 0 0 0 162 150 Z"
          fill="none"
          stroke="#f8fafc"
          stroke-width="31"></path>
        <!-- compression–rarefaction tracer lines (built + animated by JS),
             like the air-column animation's wavefronts -->
        <g id="tw-tracers-ac" stroke="#64748b" stroke-width="1.1" opacity="0.75"></g>
        <!-- branch tube (acoustic load / phase tuner): a closed quarter-wave
             stub teed off the feedback run; JS sets its length from the L_b
             slider and the standing wave inside it -->
        <line id="tw-branch-dark" x1="360" y1="30" x2="360" y2="-50" stroke="#0f172a" stroke-width="40"></line>
        <line id="tw-branch-light" x1="360" y1="40" x2="360" y2="-45" stroke="#f8fafc" stroke-width="31"></line>
        <g id="tw-tracers-br" stroke="#64748b" stroke-width="1.1" opacity="0.75"></g>
        <text id="tw-branch-lab" x="384" y="-36" font-size="9.5" fill="#475569"></text>
        <!-- return direction inside the top run -->
        <line x1="300" y1="46" x2="264" y2="46" stroke="#0e7490" stroke-width="1.8" marker-end="url(#tw-arr-i)" opacity="0.8"></line>
        <text x="216" y="24" font-size="9.5" fill="#0e7490" text-anchor="middle">{L.crest}</text>
        <!-- ghost gas-pistons: the wave playing the pistons -->
        <rect id="tw-ghost-c" x="192" y="137" width="26" height="26" rx="3" fill="#0891b2" fill-opacity="0.35" stroke="#0e7490" stroke-width="1.3" stroke-dasharray="4 3"></rect>
        <rect id="tw-ghost-h" x="502" y="137" width="26" height="26" rx="3" fill="#0891b2" fill-opacity="0.35" stroke="#0e7490" stroke-width="1.3" stroke-dasharray="4 3"></rect>
        <text x="205" y="192" font-size="9.5" fill="#0e7490" text-anchor="middle" font-weight="600">{L.ghost}</text>
        <text x="515" y="192" font-size="9.5" fill="#0e7490" text-anchor="middle" font-weight="600">{L.ghost}</text>
        <!-- phase annotation, centred in the ring's empty interior -->
        <text id="tw-ac-phase" x="360" y="100" font-size="10.5" fill="#475569" text-anchor="middle" font-weight="600"></text>
      </g>

      <!-- ── Mechanical α-Stirling, drawn after Biwa Fig. 4.1(a): the core
           duct on top, elbows turning DOWN into two hanging cylinders, angled
           con-rods to grounded cranks on one crankshaft, flywheel at right. ── -->
      <g class="tw-only-mech">
        <!-- gas circuit: cylinder – elbow – core run – elbow – cylinder -->
        <path
          d="M 140 222 L 140 180 A 30 30 0 0 1 170 150 L 550 150 A 30 30 0 0 1 580 180 L 580 222"
          fill="none"
          stroke="#0f172a"
          stroke-width="40"></path>
        <path
          d="M 140 222 L 140 180 A 30 30 0 0 1 170 150 L 550 150 A 30 30 0 0 1 580 180 L 580 222"
          fill="none"
          stroke="#f8fafc"
          stroke-width="31"></path>
        <!-- compression–rarefaction tracers in the core run (JS) -->
        <g id="tw-tracers-mech" stroke="#64748b" stroke-width="1.1" opacity="0.75"></g>
        <!-- hanging cylinders — OPEN toward the crank (trunk-piston style),
             so the con-rod exits without crossing a wall -->
        <path d="M 118 258 L 118 196 L 162 196 L 162 258" fill="#eff6ff" stroke="#1e3a5f" stroke-width="2.5" stroke-linejoin="round"></path>
        <path d="M 558 258 L 558 196 L 602 196 L 602 258" fill="#fef2f2" stroke="#1e3a5f" stroke-width="2.5" stroke-linejoin="round"></path>
        <!-- connecting rods (big end on the crank pin, small end at the wrist
             pin inside the piston skirt) + pistons (JS animates) -->
        <line id="tw-rod-c" x1="140" y1="262" x2="140" y2="220" stroke="#475569" stroke-width="5" stroke-linecap="round"></line>
        <line id="tw-rod-h" x1="580" y1="262" x2="580" y2="220" stroke="#475569" stroke-width="5" stroke-linecap="round"></line>
        <rect id="tw-piston-c" x="123" y="214" width="34" height="12" fill="#16a34a" fill-opacity="0.9" stroke="#15803d"></rect>
        <rect id="tw-piston-h" x="563" y="214" width="34" height="12" fill="#16a34a" fill-opacity="0.9" stroke="#15803d"></rect>
        <circle id="tw-wrist-c" cx="140" cy="220" r="2.8" fill="#e2e8f0" stroke="#334155" stroke-width="1.5"></circle>
        <circle id="tw-wrist-h" cx="580" cy="220" r="2.8" fill="#e2e8f0" stroke="#334155" stroke-width="1.5"></circle>
        <!-- crankshaft below (one shaft keeps the 90° lock); crank discs and
             the flywheel drawn as oblique 3-D wheels on the horizontal axle,
             as in Biwa Fig. 1.9(a): narrow ellipse face + offset back rim -->
        <line x1="140" y1="262" x2="580" y2="262" stroke="#475569" stroke-width="3"></line>
        <!-- left crank disc -->
        <line x1="134" y1="248" x2="140" y2="248" stroke="#0f172a" stroke-width="1.5"></line>
        <line x1="134" y1="276" x2="140" y2="276" stroke="#0f172a" stroke-width="1.5"></line>
        <ellipse cx="134" cy="262" rx="4.5" ry="14" fill="#94a3b8" stroke="#0f172a" stroke-width="1.5"></ellipse>
        <ellipse cx="140" cy="262" rx="4.5" ry="14" fill="#e2e8f0" stroke="#0f172a" stroke-width="1.5"></ellipse>
        <!-- right flywheel: a larger 3-D disc; rim dot shows the spin -->
        <line x1="572" y1="244" x2="580" y2="244" stroke="#0f172a" stroke-width="1.5"></line>
        <line x1="572" y1="280" x2="580" y2="280" stroke="#0f172a" stroke-width="1.5"></line>
        <ellipse cx="572" cy="262" rx="6" ry="18" fill="#94a3b8" stroke="#0f172a" stroke-width="1.5"></ellipse>
        <ellipse cx="580" cy="262" rx="6" ry="18" fill="#e2e8f0" stroke="#0f172a" stroke-width="1.5"></ellipse>
        <circle id="tw-fly-dot" cx="580" cy="247" r="2" fill="#475569"></circle>
        <line id="tw-crank-c" x1="140" y1="262" x2="140" y2="251" stroke="#334155" stroke-width="4" stroke-linecap="round"></line>
        <line id="tw-crank-h" x1="580" y1="262" x2="580" y2="251" stroke="#334155" stroke-width="4" stroke-linecap="round"></line>
        <circle cx="140" cy="262" r="2.5" fill="#0f172a"></circle>
        <circle cx="580" cy="262" r="2.5" fill="#0f172a"></circle>
        <circle id="tw-pin-c" cx="140" cy="251" r="3.2" fill="#1e293b"></circle>
        <circle id="tw-pin-h" cx="580" cy="251" r="3.2" fill="#1e293b"></circle>
        <!-- grounded bearings (hatched mounts, as in the textbook figure) -->
        <g stroke="#475569" stroke-width="1.2">
          <line x1="124" y1="280" x2="156" y2="280"></line>
          <line x1="128" y1="280" x2="122" y2="287"></line>
          <line x1="138" y1="280" x2="132" y2="287"></line>
          <line x1="148" y1="280" x2="142" y2="287"></line>
          <line x1="564" y1="284" x2="596" y2="284"></line>
          <line x1="568" y1="284" x2="562" y2="291"></line>
          <line x1="578" y1="284" x2="572" y2="291"></line>
          <line x1="588" y1="284" x2="582" y2="291"></line>
        </g>
        <text x="108" y="225" font-size="9.5" fill="#475569" text-anchor="end">{L.comp}</text>
        <text x="612" y="225" font-size="9.5" fill="#475569" text-anchor="start">{L.expn}</text>
        <text x="606" y="288" font-size="9" fill="#475569" text-anchor="start">{isEn ? "flywheel" : "飛輪"}</text>
        <!-- phase annotation, in the open space above the core -->
        <text id="tw-mech-phase" x="360" y="246" font-size="10.5" fill="#475569" text-anchor="middle" font-weight="600"></text>
      </g>

      <!-- ── Shared core: cold HX – regenerator – hot HX (+ heat arrows) ── -->
      <g>
        <rect x="288" y="134" width="16" height="32" fill="#2563eb" fill-opacity="0.9"></rect>
        <rect x="304" y="134" width="120" height="32" fill="url(#tw-mesh)" stroke="#475569" stroke-width="1.4"></rect>
        <rect x="424" y="134" width="16" height="32" fill="#dc2626" fill-opacity="0.9"></rect>
        <text x="296" y="124" font-size="9.5" fill="#2563eb" text-anchor="middle" font-weight="600" font-style="italic">T<tspan font-style="normal" dy="2" font-size="7.5">C</tspan></text>
        <text x="364" y="124" font-size="10" fill="#475569" text-anchor="middle">{L.regen}</text>
        <text x="432" y="124" font-size="9.5" fill="#dc2626" text-anchor="middle" font-weight="600" font-style="italic">T<tspan font-style="normal" dy="2" font-size="7.5">H</tspan></text>
        <!-- tracked parcel inside the regenerator (cf. the research overview's
             stirling-engine-wave figure): shuttles cold ⇄ hot, swells/shrinks,
             and takes the process-step colour — synced with every panel below -->
        <rect id="tw-regen-parcel" x="356" y="141" width="16" height="18" rx="2" fill="#0891b2" fill-opacity="0.9" stroke="#0e7490" stroke-width="1.2"></rect>
        <!-- heat in at the hot HX / heat out at the cold HX -->
        <line x1="432" y1="206" x2="432" y2="172" stroke="#d72121" stroke-width="4.5" marker-end="url(#tw-arr-hot)"></line>
        <text x="442" y="200" font-size="9.5" fill="#d72121" font-weight="600">{L.q_in} <tspan font-style="italic">Q̄</tspan><tspan dy="2" font-size="7.5">H</tspan></text>
        <line x1="296" y1="172" x2="296" y2="206" stroke="#58b3e5" stroke-width="4.5" marker-end="url(#tw-arr-cool)"></line>
        <text x="286" y="200" font-size="9.5" fill="#58b3e5" font-weight="600" text-anchor="end">{L.q_out} <tspan font-style="italic">Q̄</tspan><tspan dy="2" font-size="7.5">C</tspan></text>
      </g>
    </g>

    <!-- ═══════════ (b) Energy flow diagram — Biwa Fig. 4.8 ═══════════ -->
    <g transform="translate(20, 440)">
      <text x="0" y="-8" font-size="12.5" fill="#1e3a5f" font-weight="600">{L.flux}</text>

      <!-- alignment guides at the HX faces, dropped STRAIGHT from the engine
           model above (no duplicate schematic) -->
      <line x1="288" y1="-44" x2="288" y2="192" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3 3"></line>
      <line x1="304" y1="-44" x2="304" y2="192" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3 3"></line>
      <line x1="424" y1="-44" x2="424" y2="192" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3 3"></line>
