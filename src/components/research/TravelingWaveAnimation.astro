<script>
  type Mode = "mechanical" | "acoustic";
  const TWO_PI = Math.PI * 2;
  const PERIOD = 5.0; // seconds per cycle

  function initAnimation(root: HTMLElement) {
    const $ = <T extends Element>(id: string) => root.querySelector<T>("#" + id);
    const tabs = root.querySelectorAll<HTMLButtonElement>(".tw-tab");
    const isEn = root.getAttribute("data-lang") === "en";

    // ── State ───────────────────────────────────────────────────────────
    let mode: Mode = (root.getAttribute("data-mode") as Mode) ?? "acoustic";
    let phi = 0; // p–u phase, rad: 0 traveling … π/2 standing
    let branchLen = 0.25; // branch-tube length in λ; λ/4 → traveling condition
    let ratio = 2.2; // T_H / T_C
    let amp = 1;

    const K_T = 0.5;
    const K_C = 0.45;
    const pOf = (wt: number) => amp * Math.cos(wt);
    const xiOf = (wt: number) => amp * Math.sin(wt + phi);
    const vOf = (wt: number) =>
      amp * (K_T * (ratio - 1) * Math.sin(wt + phi) - K_C * Math.cos(wt));
    const dvOf = (wt: number) =>
      amp * (K_T * (ratio - 1) * Math.cos(wt + phi) + K_C * Math.sin(wt));

    // ── DOM refs ────────────────────────────────────────────────────────
    const devTitle = $<SVGTextElement>("tw-dev-title")!;
    const pistonC = $<SVGRectElement>("tw-piston-c");
    const rodC = $<SVGLineElement>("tw-rod-c");
    const pistonH = $<SVGRectElement>("tw-piston-h");
    const rodH = $<SVGLineElement>("tw-rod-h");
    const ghostC = $<SVGRectElement>("tw-ghost-c");
    const ghostH = $<SVGRectElement>("tw-ghost-h");
    const mechPhase = $<SVGTextElement>("tw-mech-phase");
    const acPhase = $<SVGTextElement>("tw-ac-phase");
    const tracersAc = $<SVGGElement>("tw-tracers-ac");
    const tracersMech = $<SVGGElement>("tw-tracers-mech");
    const crankC = $<SVGLineElement>("tw-crank-c");
    const crankH = $<SVGLineElement>("tw-crank-h");
    const pinC = $<SVGCircleElement>("tw-pin-c");
    const pinH = $<SVGCircleElement>("tw-pin-h");
    const wristC = $<SVGCircleElement>("tw-wrist-c");
    const wristH = $<SVGCircleElement>("tw-wrist-h");
    const flyDot = $<SVGCircleElement>("tw-fly-dot");
    const regenParcel = $<SVGRectElement>("tw-regen-parcel");
    const branchDark = $<SVGLineElement>("tw-branch-dark");
    const branchLight = $<SVGLineElement>("tw-branch-light");
    const branchLab = $<SVGTextElement>("tw-branch-lab");
    const tracersBr = $<SVGGElement>("tw-tracers-br");
    const branchWrap = root.querySelector<HTMLElement>("#tw-branch-slider");
    const fluxI = $<SVGPathElement>("tw-flux-i");
    const fluxQ = $<SVGPathElement>("tw-flux-q");
    const fluxS = $<SVGPathElement>("tw-flux-s");
    const sLab = $<SVGTextElement>("tw-s-lab");
    const qcLab = $<SVGTextElement>("tw-qc-lab");
    const qhLab = $<SVGTextElement>("tw-qh-lab");
    const wExt = $<SVGLineElement>("tw-w-ext");
    const wLine = $<SVGLineElement>("tw-w-line");
    const wText = $<SVGTextElement>("tw-w-text");
    const gainText = $<SVGTextElement>("tw-gain");
    const fluxLeft = $<SVGTextElement>("tw-flux-left")!;
    const fluxRight = $<SVGTextElement>("tw-flux-right")!;
    const pvLoop = $<SVGPathElement>("tw-pv-loop");
    const pvFill = $<SVGPathElement>("tw-pv-fill");
    const pvDot = $<SVGCircleElement>("tw-pv-dot");
    const pvQ = [
      $<SVGCircleElement>("tw-pv-q0"),
      $<SVGCircleElement>("tw-pv-q1"),
      $<SVGCircleElement>("tw-pv-q2"),
      $<SVGCircleElement>("tw-pv-q3"),
    ];
    const parcel = $<SVGRectElement>("tw-parcel");
    const heatTop = $<SVGLineElement>("tw-heat-top");
    const heatBot = $<SVGLineElement>("tw-heat-bot");
    const stepText = $<SVGTextElement>("tw-step");
    const poreGradL = $<SVGStopElement>("tw-pore-grad-l");
    const poreGradR = $<SVGStopElement>("tw-pore-grad-r");
    const phP = $<SVGLineElement>("tw-ph-p");
    const phU = $<SVGLineElement>("tw-ph-u");
    const phArc = $<SVGPathElement>("tw-ph-arc");
    const phPLabel = $<SVGTextElement>("tw-ph-p-label");
    const phULabel = $<SVGTextElement>("tw-ph-u-label");
    const phDeg = $<SVGTextElement>("tw-ph-deg");

    const titleMech = isEn
      ? "(a) Mechanical α-Stirling — solid pistons"
      : "(a) 機械式 α-Stirling — 固體活塞";
    const titleAc = isEn
      ? "(a) Looped thermoacoustic engine — the wave replaces the pistons"
      : "(a) 環形熱聲引擎 — 行波取代活塞";
    const inAc = isEn ? "Ī in (feedback loop)" : "Ī 入（迴路回授）";
    const outAc = isEn ? "Ī out (amplified)" : "Ī 出（已放大）";
    const inMech = isEn ? "W in (compression piston)" : "W 入（壓縮活塞）";
    const outMech = isEn ? "W out (expansion piston)" : "W 出（膨脹活塞）";

    // Fig.-4b process steps (加熱 → 膨脹 → 冷卻 → 壓縮), colour-matched.
    const STEPS = isEn
      ? [
          { t: "heating (toward hot)", c: "#d72121" },
          { t: "expansion (hot end)", c: "#e27c2f" },
          { t: "cooling (toward cold)", c: "#58b3e5" },
          { t: "compression (cold end)", c: "#2563eb" },
        ]
      : [
          { t: "加熱（往熱端）", c: "#d72121" },
          { t: "膨脹（熱端）", c: "#e27c2f" },
          { t: "冷卻（往冷端）", c: "#58b3e5" },
          { t: "壓縮（冷端）", c: "#2563eb" },
        ];
    // Smooth parcel colour: blend continuously around the cycle between the
    // four step colours (anchored at ωt = 0, π/2, π, 3π/2 — the step centres).
    const STEP_RGB = [
      [215, 33, 33],
      [226, 124, 47],
      [88, 179, 229],
      [37, 99, 235],
    ];
    function stepColor(wt: number) {
      const pos = ((((wt % TWO_PI) + TWO_PI) % TWO_PI) / (Math.PI / 2)) % 4;
      const i = Math.floor(pos);
      const f = pos - i;
      const a = STEP_RGB[i];
      const b = STEP_RGB[(i + 1) % 4];
      return `rgb(${a.map((v, k) => Math.round(v + (b[k] - v) * f)).join(",")})`;
    }

    // ── PV loop geometry (panel-local: 195 × 160) ───────────────────────
    const PV_CX = 97,
      PV_CY = 78,
      PV_SX = 58,
      PV_SY = 52;
    const pvX = (wt: number) => PV_CX + PV_SX * vOf(wt);
    const pvY = (wt: number) => PV_CY - PV_SY * pOf(wt);

    // ── Ring sampler for the wave crests (racetrack centreline) ─────────
    // Bottom run y150 (162→558), corner r 52, top run y46 (558→162).
    const R = 52;
    type Seg = { len: number; at: (u: number) => { x: number; y: number } };
    const arc = (cx: number, cy: number, a0: number, a1: number): Seg => ({
      len: (Math.PI / 2) * R,
      at: (u) => {
        const a = a0 + (a1 - a0) * u;
        return { x: cx + R * Math.cos(a), y: cy + R * Math.sin(a) };
      },
    });
    const lineSeg = (x0: number, y0: number, x1: number, y1: number): Seg => ({
      len: Math.hypot(x1 - x0, y1 - y0),
      at: (u) => ({ x: x0 + (x1 - x0) * u, y: y0 + (y1 - y0) * u }),
    });
    const SEGS: Seg[] = [
      lineSeg(162, 150, 558, 150), // core run, cold → hot
      arc(558, 98, Math.PI / 2, 0), // bottom-right corner, up
      arc(558, 98, 0, -Math.PI / 2), // to the top run
      lineSeg(558, 46, 162, 46), // top run, returning
      arc(162, 98, -Math.PI / 2, -Math.PI), // top-left corner, down
      arc(162, 98, Math.PI, Math.PI / 2), // back to the core run
    ];
    const TOTAL = SEGS.reduce((s, g) => s + g.len, 0);
    function ringPoint(s: number) {
      let d = ((s % 1) + 1) % 1 * TOTAL;
      for (const g of SEGS) {
        if (d <= g.len) return g.at(d / g.len);
        d -= g.len;
      }
      return SEGS[SEGS.length - 1].at(1);
    }

    // ── Compression–rarefaction tracers (à la the air-column animation) ──
    // Tracer marks ride the gas displacement field: where they bunch up is a
    // compression travelling around the ring; each mark only oscillates
    // around its rest position — exactly what the gas does.
    const NS = "http://www.w3.org/2000/svg";
    const AC_N = 56;
    const acTracers: { el: SVGLineElement; s0: number }[] = [];
    if (tracersAc) {
      for (let k = 0; k < AC_N; k++) {
        const el = document.createElementNS(NS, "line");
        tracersAc.appendChild(el);
        acTracers.push({ el, s0: k / AC_N });
      }
    }
    // perpendicular tick of half-length 11 at ring position s
    function placeRingTick(el: SVGLineElement, s: number) {
      const p0 = ringPoint(s - 0.001);
      const p1 = ringPoint(s + 0.001);
      const dx = p1.x - p0.x,
        dy = p1.y - p0.y;
      const n = Math.hypot(dx, dy) || 1;
      const nx = (-dy / n) * 11,
        ny = (dx / n) * 11;
      const c = ringPoint(s);
      el.setAttribute("x1", (c.x - nx).toFixed(1));
      el.setAttribute("y1", (c.y - ny).toFixed(1));
      el.setAttribute("x2", (c.x + nx).toFixed(1));
      el.setAttribute("y2", (c.y + ny).toFixed(1));
    }
    // hide tracers where the regenerator + HXs occupy the core run
    function onCore(s: number) {
      const d = (((s % 1) + 1) % 1) * TOTAL;
      return d >= 121 && d <= 283; // bottom run x = 162 + d → 283…445
    }
    const MECH_N = 26;
    const mechTracers: { el: SVGLineElement; x0: number }[] = [];
    if (tracersMech) {
      for (let k = 0; k < MECH_N; k++) {
        const el = document.createElementNS(NS, "line");
        el.setAttribute("y1", "139.5");
        el.setAttribute("y2", "160.5");
        tracersMech.appendChild(el);
        mechTracers.push({ el, x0: 180 + (k / (MECH_N - 1)) * 360 });
      }
    }
    // branch-tube tracers: a standing wave in the closed stub (node at the
    // closed end, max motion at the junction) — loop runs traveling, branch
    // stands. f = fractional distance from the closed end; y0 set per length.
    const BR_N = 6;
    const brTracers: { el: SVGLineElement; f: number; y0: number }[] = [];
    if (tracersBr) {
      for (let k = 0; k < BR_N; k++) {
        const el = document.createElementNS(NS, "line");
        el.setAttribute("x1", "349.5");
        el.setAttribute("x2", "370.5");
        tracersBr.appendChild(el);
        brTracers.push({ el, f: (k + 0.5) / BR_N, y0: 20 });
      }
    }
    const S_JUNCTION = 757 / TOTAL; // ring position of the branch tee (x=360, top run)
    const S_RC = 202 / TOTAL; // ring position of the regenerator centre (x=364, core run)

    // ── Static (control-dependent) rendering ────────────────────────────
    function renderStatic() {
      // PV loop + the 4 step-colour markers (ωt = 0, π/2, π, 3π/2)
      const pts: string[] = [];
      for (let i = 0; i <= 90; i++) {
        const wt = (i / 90) * TWO_PI;
        pts.push((i === 0 ? "M " : "L ") + pvX(wt).toFixed(1) + " " + pvY(wt).toFixed(1));
      }
      const d = pts.join(" ") + " Z";
      pvLoop?.setAttribute("d", d);
      pvFill?.setAttribute("d", d);
      pvQ.forEach((dot, k) => {
        const wt = (k * Math.PI) / 2;
        dot?.setAttribute("cx", pvX(wt).toFixed(1));
        dot?.setAttribute("cy", pvY(wt).toFixed(1));
      });

      // Energy flow diagram (Biwa Fig. 4.8): Ī(x) flat–ramp–flat in the
      // positive half; Q̄(x) = −Ī(x) inside the ideal regenerator, ramping to
      // zero across each HX, zero in the adiabatic ducts.
      // x landmarks: a=180, b=210, c=510, d=540.
      // x landmarks aligned with the device core: a=288, b=304, c=424, d=440.
      const G = 1 + (ratio - 1) * Math.cos(phi);
      const y0 = 95;
      const hIn = 18 * amp + 5; // tall plot scale (vertical stretch ×2)
      const hOut = hIn * G;
      fluxI?.setAttribute(
        "d",
        `M 60 ${(y0 - hIn).toFixed(1)} L 304 ${(y0 - hIn).toFixed(1)} L 424 ${(y0 - hOut).toFixed(1)} L 660 ${(y0 - hOut).toFixed(1)}`,
      );
      fluxQ?.setAttribute(
        "d",
        `M 60 ${y0} L 288 ${y0} L 304 ${(y0 + hIn).toFixed(1)} L 424 ${(y0 + hOut).toFixed(1)} L 440 ${y0} L 660 ${y0}`,
      );
      // entropy flux s̄ = Q̄/T (plot-scaled ×0.62): flat inside the
      // regenerator when reversible (φ=0, Carnot), sloped otherwise.
      {
        const SS = 0.62;
        const pts: string[] = [`M 60 ${y0}`, `L 288 ${y0}`, `L 304 ${(y0 + SS * hIn).toFixed(1)}`];
        for (let i = 1; i <= 24; i++) {
          const f = i / 24;
          const q = hIn + (hOut - hIn) * f;
          const Tn = 1 + (ratio - 1) * f;
          pts.push(`L ${(304 + 120 * f).toFixed(1)} ${(y0 + (SS * q) / Tn).toFixed(1)}`);
        }
        pts.push(`L 440 ${y0}`, `L 660 ${y0}`);
        fluxS?.setAttribute("d", pts.join(" "));
        const qMid = hIn + (hOut - hIn) * 0.5;
        const tMid = 1 + (ratio - 1) * 0.5;
        sLab?.setAttribute("y", (y0 + (SS * qMid) / tMid + 13).toFixed(1));
      }
      qcLab?.setAttribute("y", (y0 + hIn + 12).toFixed(1));
      qhLab?.setAttribute("y", (y0 + hOut + 12).toFixed(1));
      wExt?.setAttribute("y1", (y0 - hIn).toFixed(1));
      wExt?.setAttribute("y2", (y0 - hIn).toFixed(1));
      wLine?.setAttribute("y1", (y0 - hIn).toFixed(1));
      wLine?.setAttribute("y2", (y0 - hOut).toFixed(1));
      const showW = G > 1.06;
      wExt?.setAttribute("opacity", showW ? "0.7" : "0");
      wLine?.setAttribute("opacity", showW ? "1" : "0");
      wText?.setAttribute("opacity", showW ? "1" : "0");
      wText?.setAttribute("y", (y0 - (hIn + hOut) / 2 + 4).toFixed(1));
      if (gainText)
        gainText.innerHTML = (isEn ? "gain " : "放大 ") + '<tspan font-style="italic">Ī</tspan>×' + G.toFixed(2);

      // pore backdrop (soft pastel)
      const frac = Math.min(1, (ratio - 1) / 2);
      const lerp = (t: [number, number, number]) =>
        `rgb(${t.map((v) => Math.round(255 + (v - 255) * frac)).join(",")})`;
      poreGradL?.setAttribute("stop-color", lerp([191, 219, 254]));
      poreGradR?.setAttribute("stop-color", lerp([254, 202, 202]));

      // branch tube: visible length from L_b (0.05–0.45 λ → 26–100 px);
      // top of the stub is the closed end (dark cap = dark stroke overhang)
      const Lpx = 26 + ((branchLen - 0.05) / 0.4) * 74;
      const topY = 26 - Lpx;
      branchDark?.setAttribute("y2", (topY - 4.5).toFixed(1));
      branchLight?.setAttribute("y2", topY.toFixed(1));
      branchLab?.setAttribute("y", (topY + 12).toFixed(1));
      if (branchLab)
        branchLab.innerHTML =
          (isEn ? "branch " : "支管 ") +
          '<tspan font-style="italic">L</tspan> = ' +
          branchLen.toFixed(2) +
          '<tspan font-style="italic">λ</tspan>';
      {
        const jY = 38;
        const span = jY - (topY + 7);
        for (const tr of brTracers) tr.y0 = topY + 7 + tr.f * span;
      }

      // phase annotations (cf. research Fig. 4a wording)
      const deg = Math.round((phi * 180) / Math.PI);
      if (mechPhase)
        mechPhase.textContent = isEn
          ? `two-piston phase diff. = ${90 - deg}°`
          : `雙活塞相位差 = ${90 - deg}°`;
      if (acPhase)
        acPhase.innerHTML = isEn
          ? `traveling-wave phase: <tspan font-style="italic">p–u</tspan> diff. = ${deg}°`
          : `行波相位：<tspan font-style="italic">p–u</tspan> 相位差 = ${deg}°`;
      if (phDeg)
        phDeg.innerHTML =
          '<tspan font-style="italic">φ</tspan> = ' + deg + "°" +
          (phi < 0.05 ? (isEn ? " (traveling)" : "（行波·同相）") : "") +
          (phi > Math.PI / 2 - 0.05 ? (isEn ? " (standing)" : "（駐波·90°）") : "");
      // phasor angle arc between p̂ and û (visible once φ > ~5°)
      if (phArc) {
        if (phi > 0.09) {
          const r = 30;
          const x0 = 75 + r, // p̂ at angle 0 reference; arc drawn in frame()
            y0a = 72;
          phArc.setAttribute("data-r", String(r));
          phArc.setAttribute("opacity", "1");
          void x0;
          void y0a;
        } else {
          phArc.setAttribute("opacity", "0");
        }
      }
    }

    // ── Mode toggle ─────────────────────────────────────────────────────
    function applyMode(m: Mode) {
      mode = m;
      root.setAttribute("data-mode", m);
      tabs.forEach((b) => {
        const on = b.getAttribute("data-mode") === m;
        b.classList.toggle("active", on);
        b.setAttribute("aria-selected", String(on));
      });
      devTitle.textContent = m === "mechanical" ? titleMech : titleAc;
      fluxLeft.textContent = m === "mechanical" ? inMech : inAc;
      fluxRight.textContent = m === "mechanical" ? outMech : outAc;
      // the branch tube only exists on the acoustic device
      const brInput = root.querySelector<HTMLInputElement>('[data-knob="branch"]');
      if (brInput) brInput.disabled = m === "mechanical";
      if (branchWrap) branchWrap.style.opacity = m === "mechanical" ? "0.4" : "1";
    }
    tabs.forEach((b) =>
      b.addEventListener("click", () => applyMode(b.getAttribute("data-mode") as Mode)),
    );

    // ── Sliders ─────────────────────────────────────────────────────────
    const phiSlider = root.querySelector<HTMLInputElement>('[data-knob="phi"]');
    const branchSlider = root.querySelector<HTMLInputElement>('[data-knob="branch"]');
    const ratioSlider = root.querySelector<HTMLInputElement>('[data-knob="ratio"]');
    const ampSlider = root.querySelector<HTMLInputElement>('[data-knob="amp"]');
    // L_b ↔ φ coupling (pedagogical one-parameter map, noted in the caption):
    // L_b = λ/4 presents the traveling-wave load (φ=0); detuning either way
    // pushes the field toward standing-wave phasing (φ→90°).
    phiSlider?.addEventListener("input", () => {
      phi = (parseFloat(phiSlider.value) * Math.PI) / 180;
      branchLen = 0.25 + 0.2 * (phi / (Math.PI / 2));
      if (branchSlider) branchSlider.value = branchLen.toFixed(2);
      renderStatic();
    });
    branchSlider?.addEventListener("input", () => {
      branchLen = parseFloat(branchSlider.value);
      phi = Math.min(1, Math.abs(branchLen - 0.25) / 0.2) * (Math.PI / 2);
      if (phiSlider) phiSlider.value = String(Math.round((phi * 180) / Math.PI));
      renderStatic();
    });
    ratioSlider?.addEventListener("input", () => {
      ratio = parseFloat(ratioSlider.value);
      renderStatic();
    });
    ampSlider?.addEventListener("input", () => {
      amp = parseFloat(ampSlider.value);
      renderStatic();
    });

    // ── Animation loop ──────────────────────────────────────────────────
    let start: number | null = null;
    function frame(ts: number) {
      if (start === null) start = ts;
      const t = (ts - start) / 1000;
      const wt = ((t / PERIOD) % 1) * TWO_PI;

      // ── Drive kinematics. Phase gap Δ = 90° − φ (φ=0 → Stirling's 90°;
      // φ=90° → cranks in step: the gas merely sloshes, the loop collapses).
      const delta = Math.PI / 2 - phi;

      // Mechanical: crank pins orbit at a FIXED radius (a real crank's stroke
      // is set by its geometry, not by drive strength); pistons hang off the
      // pins; the 90° gap is visible right on the crank circles.
      // crank pins orbit on the oblique 3-D disc faces: full vertical throw
      // (rc), foreshortened horizontal excursion (the discs are seen edge-on)
      const rc = 11;
      const pcx = 140 + 3.5 * Math.sin(wt + phi);
      const pcy = 262 - rc * Math.cos(wt + phi); // crank pin (left), pivot at y=262
      const phx = 580 + 4 * Math.sin(wt + phi - delta);
      const phy = 262 - rc * Math.cos(wt + phi - delta);
      const pyC = pcy - 48; // piston rect-top follows its pin via the rod
      const pyH = phy - 48;
      // flywheel rim dot (opposite the crank pin) shows the spin
      flyDot?.setAttribute("cx", (580 + 5 * Math.sin(wt + phi - delta + Math.PI)).toFixed(1));
      flyDot?.setAttribute("cy", (262 - 15 * Math.cos(wt + phi - delta + Math.PI)).toFixed(1));
      wristC?.setAttribute("cy", (pyC + 6).toFixed(1));
      wristH?.setAttribute("cy", (pyH + 6).toFixed(1));
      crankC?.setAttribute("x2", pcx.toFixed(1));
      crankC?.setAttribute("y2", pcy.toFixed(1));
      pinC?.setAttribute("cx", pcx.toFixed(1));
      pinC?.setAttribute("cy", pcy.toFixed(1));
      pistonC?.setAttribute("y", pyC.toFixed(1));
      if (rodC) {
        rodC.setAttribute("x1", pcx.toFixed(1));
        rodC.setAttribute("y1", pcy.toFixed(1));
        rodC.setAttribute("x2", "140");
        rodC.setAttribute("y2", (pyC + 6).toFixed(1));
      }
      crankH?.setAttribute("x2", phx.toFixed(1));
      crankH?.setAttribute("y2", phy.toFixed(1));
      pinH?.setAttribute("cx", phx.toFixed(1));
      pinH?.setAttribute("cy", phy.toFixed(1));
      pistonH?.setAttribute("y", pyH.toFixed(1));
      if (rodH) {
        rodH.setAttribute("x1", phx.toFixed(1));
        rodH.setAttribute("y1", phy.toFixed(1));
        rodH.setAttribute("x2", "580");
        rodH.setAttribute("y2", (pyH + 6).toFixed(1));
      }

      // ── Gas displacement fields (what the tracers + ghosts ride on) ──
      // Acoustic ring: traveling ↔ standing mix by φ, one wavelength per lap,
      // PHASE-ANCHORED at the regenerator centre so the tube texture, ghost
      // pistons, branch and the thermodynamic panels all show ξ′ = sin(ωt+φ)
      // at the same instant (every panel stays in sync):
      //   ξ(s,t) = cosφ·sin(ωt+φ − 2πΔ) + sinφ·cos(2πΔ)·sin(ωt+φ),  Δ = s−s_rc
      const field = (s: number) => {
        const d = TWO_PI * (s - S_RC);
        return (
          Math.cos(phi) * Math.sin(wt + phi - d) +
          Math.sin(phi) * Math.cos(d) * Math.sin(wt + phi)
        );
      };
      const dsAmp = 0.016 * amp;
      for (const tr of acTracers) {
        const s = tr.s0 + dsAmp * field(tr.s0);
        if (onCore(s)) {
          tr.el.setAttribute("opacity", "0");
        } else {
          tr.el.removeAttribute("opacity");
          placeRingTick(tr.el, s);
        }
      }
      // ghost gas-pistons ride the same field at their own ring positions
      const sGC = 43 / TOTAL;
      const sGH = 353 / TOTAL;
      ghostC?.setAttribute("x", (192 + 16 * amp * field(sGC)).toFixed(1));
      ghostH?.setAttribute("x", (502 + 16 * amp * field(sGH)).toFixed(1));

      // tracked parcel inside the regenerator — same ξ′/V′ cycle as every
      // panel below: position, size and process-step colour all in sync
      if (regenParcel) {
        const w = Math.max(8, 16 * (1 + 0.45 * vOf(wt)));
        regenParcel.setAttribute("x", (364 + 34 * xiOf(wt) - w / 2).toFixed(1));
        regenParcel.setAttribute("width", w.toFixed(1));
        const act = (ratio - 1) * Math.cos(phi) * amp;
        if (act > 0.18) {
          const q = Math.floor((((wt + Math.PI / 4) % TWO_PI) / (Math.PI / 2)) % 4);
          regenParcel.setAttribute("fill", stepColor(wt));
        } else {
          regenParcel.setAttribute("fill", "#0891b2");
        }
      }

      // branch tube: standing wave in the closed stub — node at the closed
      // end, max motion at the junction, driven by the ring field there
      const jDrive = field(S_JUNCTION);
      for (const tr of brTracers) {
        const y = tr.y0 + 8 * amp * Math.sin((tr.f * Math.PI) / 2) * jDrive;
        tr.el.setAttribute("y1", y.toFixed(1));
        tr.el.setAttribute("y2", y.toFixed(1));
      }

      // Mechanical duct: displacement interpolates between the two pistons'
      // strokes — the same oscillating gas column, seen between the cranks.
      const sC = 13 * Math.cos(wt + phi); // fixed stroke (set by the crank)
      const sH = 13 * Math.cos(wt + phi - delta);
      for (const tr of mechTracers) {
        const f = (tr.x0 - 170) / 380;
        const x = tr.x0 + (sC * (1 - f) + sH * f);
        if (x >= 283 && x <= 445) {
          tr.el.setAttribute("opacity", "0");
        } else {
          tr.el.removeAttribute("opacity");
          tr.el.setAttribute("x1", x.toFixed(1));
          tr.el.setAttribute("x2", x.toFixed(1));
        }
      }

      // PV dot
      pvDot?.setAttribute("cx", pvX(wt).toFixed(1));
      pvDot?.setAttribute("cy", pvY(wt).toFixed(1));

      // Pore parcel + heat arrows + step label
      if (parcel) {
        const cx = 120 + 62 * xiOf(wt);
        const w = 34 * (1 + 0.45 * vOf(wt));
        const wc = Math.max(12, w);
        parcel.setAttribute("x", (cx - wc / 2).toFixed(1));
        parcel.setAttribute("width", wc.toFixed(1));
        const dv = dvOf(wt);
        const mag = Math.min(5.5, Math.abs(dv) * 3.4);
        const into = dv > 0; // expanding → heat flows wall → parcel
        for (const [el, yWall, yParcel] of [
          [heatTop, 38, 58],
          [heatBot, 120, 100],
        ] as const) {
          if (!el) continue;
          el.setAttribute("x1", cx.toFixed(1));
          el.setAttribute("x2", cx.toFixed(1));
          el.setAttribute("y1", into ? String(yWall) : String(yParcel));
          el.setAttribute("y2", into ? String(yParcel) : String(yWall));
          el.setAttribute("stroke-width", mag.toFixed(1));
          el.setAttribute("opacity", mag < 0.4 ? "0" : "1");
        }
        if (stepText) {
          const activity = (ratio - 1) * Math.cos(phi) * amp;
          if (activity > 0.18) {
            const q = Math.floor((((wt + Math.PI / 4) % TWO_PI) / (Math.PI / 2)) % 4);
            stepText.textContent = STEPS[q].t;
            stepText.setAttribute("fill", STEPS[q].c);
            parcel.setAttribute("fill", stepColor(wt)); // same blend as the regen parcel
          } else {
            stepText.textContent = isEn ? "(cycle degenerate)" : "（循環退化）";
            stepText.setAttribute("fill", "#94a3b8");
            parcel.setAttribute("fill", "#0891b2");
          }
        }
      }

      // Phasor: p̂ rotates at ωt, û leads by φ; dashed arc shows the gap.
      const C = { x: 75, y: 72 };
      const aP = -wt;
      const aU = -wt - phi;
      const set = (
        el: SVGLineElement | null,
        lab: SVGTextElement | null,
        a: number,
        r: number,
      ) => {
        const x = C.x + r * Math.cos(a);
        const y = C.y + r * Math.sin(a);
        el?.setAttribute("x2", x.toFixed(1));
        el?.setAttribute("y2", y.toFixed(1));
        lab?.setAttribute("x", (C.x + (r + 13) * Math.cos(a)).toFixed(1));
        lab?.setAttribute("y", (C.y + (r + 13) * Math.sin(a) + 4).toFixed(1));
      };
      set(phP, phPLabel, aP, 56 * amp);
      set(phU, phULabel, aU, 44 * amp);
      if (phArc && phi > 0.09) {
        const r = 30;
        const x1 = C.x + r * Math.cos(aP),
          y1 = C.y + r * Math.sin(aP);
        const x2 = C.x + r * Math.cos(aU),
          y2 = C.y + r * Math.sin(aU);
        phArc.setAttribute(
          "d",
          `M ${x1.toFixed(1)} ${y1.toFixed(1)} A ${r} ${r} 0 0 0 ${x2.toFixed(1)} ${y2.toFixed(1)}`,
        );
      }

      requestAnimationFrame(frame);
    }

    applyMode(mode);
    renderStatic();
    requestAnimationFrame(frame);
  }

  document.querySelectorAll<HTMLElement>(".tw-anim").forEach((el) => initAnimation(el));
</script>
