---
// PROTOTYPE — not linked from main nav. Visit /design-preview/dark-hero to view.
// Phase 4b (revised): narukama lives in the BACKGROUND layer (low opacity,
// fade-gradient overlay for legibility), with copy on the left and a
// smoked-glass news panel on the right — matches Claude Design's home-v3.
import NarukamaHero from "~/components/NarukamaHero.astro";
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Design Preview · Dark Hero · 熱聲實驗室</title>
    <meta name="robots" content="noindex, nofollow" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <style>
      :root {
        --dk-bg: #05080f;
        --dk-bg-soft: #0a1018;
        --dk-bg-card: #0d1422;
        --dk-bg-elev: #131c2c;
        --dk-fg-1: #f3f5f8;
        --dk-fg-2: rgba(243, 245, 248, 0.78);
        --dk-fg-3: rgba(243, 245, 248, 0.52);
        --dk-fg-4: rgba(243, 245, 248, 0.32);
        --dk-border: rgba(255, 255, 255, 0.08);
        --dk-border-strong: rgba(255, 255, 255, 0.16);
        --flame-core: #ffe7a8;
        --flame-yellow: #ffba59;
        --flame-orange: #ff7a30;
        --flame-red: #e83a1a;
        --flame-deep: #7a160a;
        --font-sans:
          "Inter", "Noto Sans TC", -apple-system, "PingFang TC",
          "Microsoft JhengHei", sans-serif;
        --font-mono: "JetBrains Mono", ui-monospace, monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--dk-bg);
        color: var(--dk-fg-2);
        font-family: var(--font-sans);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .container {
        max-width: 1152px;
        margin: 0 auto;
        padding: 0 24px;
      }
      @media (min-width: 768px) { .container { padding: 0 48px; } }

      /* Prototype banner */
      .proto-banner {
        background: rgba(255, 122, 48, 0.08);
        border-bottom: 1px solid rgba(255, 122, 48, 0.18);
        color: var(--dk-fg-2);
        font-size: 13px;
        padding: 8px 0;
        text-align: center;
      }
      .proto-banner a { color: var(--flame-orange); text-decoration: underline; }
      .proto-banner code { font-family: var(--font-mono); }

      /* Header — sticky on scroll, above the fixed narukama bg */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(5, 8, 15, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--dk-border);
        padding: 16px 0;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
      }
      .brand-symbol {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
      }
      .brand-symbol path:first-child { stroke: #fff; stroke-width: 2; fill: none; }
      .brand-symbol path:last-child {
        stroke: var(--flame-orange);
        stroke-width: 2;
        fill: none;
        filter: drop-shadow(0 0 4px rgba(255, 122, 48, 0.6));
      }
      .brand-zh {
        font-size: 18px;
        font-weight: 700;
        color: var(--dk-fg-1);
      }
      .brand-en {
        font-size: 10px;
        font-weight: 500;
        color: var(--dk-fg-3);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 2px;
      }
      .nav { display: flex; gap: 24px; }
      .nav a {
        color: var(--dk-fg-2);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 150ms;
      }
      .nav a:hover { color: var(--flame-orange); }
      .nav a.is-current {
        color: var(--flame-orange);
        border-bottom: 2px solid var(--flame-orange);
        padding-bottom: 2px;
      }

      /* Hero — narukama in background, 2-column copy/news on top */
      .hero {
        position: relative;
        padding: 96px 0;
        isolation: isolate;
        overflow: hidden;
      }
      /* Narukama + fade kept FIXED to viewport so it persists while scrolling.
         pointer-events: none so they don't block clicks on content above. */
      .hero-bg-figure {
        position: fixed;
        top: 50%;
        left: 50%;
        width: 440px;
        max-width: 42%;
        transform: translate(-50%, -50%);
        opacity: 0.42;
        filter: saturate(0.95);
        pointer-events: none;
        z-index: 0;
      }
      .hero-bg-figure svg {
        width: 100%;
        height: auto;
        display: block;
      }
      .hero-bg-fade {
        position: fixed;
        inset: 0;
        background:
          linear-gradient(90deg,
            var(--dk-bg)         0%,
            rgba(5, 8, 15, 0.55) 20%,
            rgba(5, 8, 15, 0.18) 50%,
            rgba(5, 8, 15, 0.55) 80%,
            var(--dk-bg)         100%),
          radial-gradient(ellipse 560px 460px at 50% 55%,
            rgba(255, 186, 89, 0.16) 0%,
            rgba(255, 122, 48, 0.10) 28%,
            rgba(232, 58, 26, 0.05) 50%,
            transparent 75%);
        pointer-events: none;
        z-index: 1;
      }
      .hero-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
        align-items: start;
      }
      @media (min-width: 900px) {
        .hero-grid {
          grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
          gap: 56px;
        }
      }

      /* News panel on right side of hero */
      .hero-news {
        background: rgba(13, 20, 34, 0.55);
        border: 1px solid var(--dk-border-strong);
        border-radius: 4px;
        padding: 18px 20px 14px;
        backdrop-filter: blur(14px) saturate(1.2);
        -webkit-backdrop-filter: blur(14px) saturate(1.2);
        position: relative;
        z-index: 3;
      }
      .hero-news__head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
      }
      .hero-news__rule {
        width: 24px;
        height: 2px;
        background: var(--flame-orange);
        box-shadow: 0 0 8px rgba(255, 122, 48, 0.55);
      }
      .hero-news__label {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--flame-orange);
      }
      .hero-news__more {
        margin-left: auto;
        background: none;
        border: 0;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--dk-fg-3);
        cursor: pointer;
      }
      .hero-news__more:hover { color: var(--flame-orange); }
      .hero-news__list { list-style: none; margin: 0; padding: 0; }
      .hero-news__list li {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 10px 0;
        border-top: 1px solid var(--dk-border);
      }
      .hero-news__list li:first-child { border-top: 0; padding-top: 0; }
      .hero-news__list li:last-child { padding-bottom: 0; }
      .hero-news__meta {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--dk-fg-3);
        letter-spacing: 0.04em;
      }
      .hero-news__meta .kind {
        padding: 1px 6px;
        border-radius: 2px;
        background: rgba(255, 122, 48, 0.12);
        color: var(--flame-orange);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 10px;
      }
      .hero-news__title {
        color: var(--dk-fg-1);
        font-size: 13.5px;
        line-height: 1.5;
        text-decoration: none;
        transition: color 150ms ease-out;
      }
      .hero-news__title:hover { color: var(--flame-orange); }

      .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: var(--dk-fg-3);
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 24px;
      }
      .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--flame-orange);
        box-shadow: 0 0 10px rgba(255, 122, 48, 0.7);
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
      }

      h1.hero-title {
        font-size: 64px;
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--dk-fg-1);
        margin: 0;
      }
      .hero-subtitle {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.16em;
        color: var(--flame-orange);
        text-transform: uppercase;
        margin-top: 12px;
      }
      .hero-body {
        font-size: 16px;
        color: var(--dk-fg-2);
        line-height: 1.7;
        margin-top: 28px;
        max-width: 30em;
      }
      .hero-actions { margin-top: 32px; display: flex; gap: 12px; flex-wrap: wrap; }
      .btn {
        display: inline-flex;
        align-items: center;
        font-size: 14px;
        font-weight: 600;
        padding: 12px 22px;
        border-radius: 4px;
        text-decoration: none;
        transition: 150ms ease-out;
        cursor: pointer;
        border: 1px solid transparent;
      }
      .btn-primary {
        background: linear-gradient(180deg, #ff8838, #e84e15);
        color: #1a0a05;
        box-shadow:
          0 0 0 1px rgba(255, 138, 56, 0.4),
          0 8px 24px rgba(232, 78, 21, 0.25);
      }
      .btn-primary:hover {
        background: linear-gradient(180deg, #ffa356, #ff6a28);
        box-shadow:
          0 0 0 1px rgba(255, 138, 56, 0.6),
          0 8px 32px rgba(232, 78, 21, 0.4);
      }
      .btn-secondary {
        background: transparent;
        color: var(--dk-fg-1);
        border-color: var(--dk-border-strong);
      }
      .btn-secondary:hover {
        border-color: var(--flame-orange);
        color: var(--flame-orange);
      }

      /* (Inline narukama / embers / flame-note styles removed —
         narukama now lives in the absolute background layer.) */

      /* Section header — relative + z-index so it sits ABOVE the fixed
         narukama background (which has z-index 0 / 1). */
      .section {
        padding: 64px 0;
        position: relative;
        z-index: 2;
      }
      .section-rule {
        width: 48px;
        height: 2px;
        background: var(--flame-orange);
        box-shadow: 0 0 12px rgba(255, 122, 48, 0.5);
        margin-bottom: 16px;
      }
      .eyebrow {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--flame-orange);
        margin-bottom: 8px;
      }
      h2 {
        font-size: 36px;
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--dk-fg-1);
        margin: 0 0 24px;
      }

      /* Card */
      .cards { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 32px; }
      @media (min-width: 768px) { .cards { grid-template-columns: 1fr 1fr; } }
      .card {
        background: var(--dk-bg-card);
        border: 1px solid var(--dk-border);
        border-radius: 4px;
        padding: 28px;
        color: var(--dk-fg-2);
        transition: 200ms ease-out;
      }
      .card:hover {
        border-color: rgba(255, 122, 48, 0.4);
        box-shadow:
          0 0 0 1px rgba(255, 122, 48, 0.2),
          0 8px 32px rgba(255, 122, 48, 0.08);
        transform: translateY(-1px);
      }
      .card-num {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--flame-orange);
        letter-spacing: 0.08em;
        margin-bottom: 12px;
      }
      .card-title {
        font-size: 20px;
        font-weight: 600;
        color: var(--dk-fg-1);
        line-height: 1.3;
        margin: 0 0 4px;
      }
      .card-title-en {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--dk-fg-3);
        margin-top: 4px;
      }
      .card-body {
        font-size: 14px;
        line-height: 1.65;
        margin-top: 12px;
      }
      .card-link {
        display: inline-block;
        margin-top: 16px;
        font-size: 13px;
        font-weight: 600;
        color: var(--dk-fg-1);
        text-decoration: none;
        transition: color 150ms;
      }
      .card:hover .card-link { color: var(--flame-orange); }

      /* PI block (faculty) */
      .pi-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        align-items: start;
      }
      @media (min-width: 768px) {
        .pi-grid { grid-template-columns: 240px 1fr; gap: 48px; }
      }
      .pi-card {
        background: var(--dk-bg-card);
        border: 1px solid var(--dk-border);
        border-radius: 4px;
        padding: 24px;
      }
      .pi-photo {
        width: 100%;
        aspect-ratio: 1;
        background: linear-gradient(135deg, #1d242f 0%, #0a0e15 100%);
        border: 1px solid var(--dk-border);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--dk-fg-4);
        font-size: 11px;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .pi-name {
        font-size: 24px;
        font-weight: 700;
        color: var(--dk-fg-1);
        margin: 16px 0 4px;
      }
      .pi-role {
        font-size: 13px;
        color: var(--dk-fg-3);
        font-family: var(--font-mono);
        letter-spacing: 0.04em;
      }
      .pi-affil { color: var(--dk-fg-2); font-size: 14px; line-height: 1.6; }
      .pi-interests { margin-top: 20px; }
      .pi-interests-label {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--flame-orange);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .pi-interests ul { list-style: none; padding: 0; margin: 0; }
      .pi-interests li {
        padding: 6px 0;
        border-top: 1px solid var(--dk-border);
        color: var(--dk-fg-2);
        font-size: 14px;
      }
      .pi-interests li:first-child { border-top: 0; }
      .pi-interests li::before {
        content: '·';
        color: var(--flame-orange);
        margin-right: 8px;
      }

      /* Publications row (dark variant of step 3 design) */
      .pub-row {
        display: grid;
        grid-template-columns: 56px 1fr 80px;
        gap: 16px;
        align-items: start;
        padding: 18px 0;
        border-bottom: 1px solid var(--dk-border);
      }
      @media (min-width: 768px) {
        .pub-row { grid-template-columns: 80px 1fr 100px; gap: 24px; }
      }
      .pub-list-dark {
        list-style: none;
        margin: 24px 0 0;
        padding: 0;
        border-top: 1px solid var(--dk-border);
      }
      .pub-year {
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--flame-orange);
        font-weight: 500;
      }
      .pub-title-dark {
        display: block;
        color: var(--dk-fg-1);
        font-weight: 600;
        line-height: 1.45;
        text-decoration: none;
        transition: color 150ms;
      }
      .pub-title-dark:hover { color: var(--flame-orange); }
      .pub-authors-dark { font-size: 13px; color: var(--dk-fg-2); margin-top: 4px; }
      .pub-venue-dark {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--dk-fg-3);
        font-style: italic;
        margin-top: 2px;
      }
      .pub-chip {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 500;
        margin-right: 6px;
        margin-top: 8px;
      }
      .pub-chip.if {
        background: rgba(255, 122, 48, 0.12);
        color: var(--flame-orange);
      }
      .pub-chip.q1 {
        background: rgba(16, 185, 129, 0.14);
        color: #6ee7b7;
      }
      .pub-kind-dark {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--dk-fg-3);
        text-align: right;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* Projects row */
      .project-card-dark {
        background: var(--dk-bg-card);
        border: 1px solid var(--dk-border);
        border-radius: 4px;
        padding: 20px 24px;
        margin-bottom: 14px;
      }
      .project-meta-dark {
        display: flex;
        gap: 14px;
        align-items: baseline;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--dk-fg-3);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .project-meta-dark .funder {
        color: var(--flame-orange);
        background: rgba(255, 122, 48, 0.12);
        padding: 1px 8px;
        border-radius: 2px;
      }
      .project-meta-dark .budget {
        margin-left: auto;
        color: var(--flame-orange);
        font-weight: 600;
      }
      .project-title-dark {
        margin-top: 8px;
        font-size: 17px;
        color: var(--dk-fg-1);
        font-weight: 600;
        line-height: 1.4;
      }

      /* Media (video) grid */
      .media-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
        margin-top: 24px;
      }
      @media (min-width: 768px) { .media-grid { grid-template-columns: 1fr 1fr; } }
      .media-card {
        background: var(--dk-bg-card);
        border: 1px solid var(--dk-border);
        border-radius: 4px;
        overflow: hidden;
        transition: 200ms ease-out;
      }
      .media-card:hover {
        border-color: rgba(255, 122, 48, 0.4);
        transform: translateY(-1px);
      }
      .media-thumb {
        aspect-ratio: 16/9;
        background:
          linear-gradient(180deg, rgba(255, 122, 48, 0.18), rgba(232, 58, 26, 0.06)),
          var(--dk-bg-elev);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--dk-fg-4);
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        position: relative;
      }
      .media-thumb::after {
        content: '';
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255, 122, 48, 0.9);
        position: absolute;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 24px rgba(255, 122, 48, 0.5);
      }
      .media-thumb::before {
        content: '▶';
        position: absolute;
        font-size: 16px;
        color: #1a0a05;
        z-index: 1;
        margin-left: 4px;
      }
      .media-meta-row { padding: 14px 18px; }
      .media-year-dark {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--dk-fg-3);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .media-title-dark {
        margin-top: 4px;
        color: var(--dk-fg-1);
        font-weight: 600;
        line-height: 1.4;
      }

      /* Footer — also above fixed narukama; opaque bg covers it */
      .footer {
        position: relative;
        z-index: 2;
        background: #02050a;
        border-top: 1px solid var(--dk-border);
        padding: 48px 0 32px;
        margin-top: 64px;
        color: var(--dk-fg-3);
        font-size: 13px;
      }
      .footer h4 {
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--flame-orange);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 0 0 8px;
      }
      .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 768px) {
        .footer-grid { grid-template-columns: 1.4fr 1fr 1fr; }
      }
      .footer p { margin: 4px 0; line-height: 1.6; }
      .footer a { color: var(--dk-fg-2); text-decoration: none; }
      .footer a:hover { color: var(--flame-orange); }
      .footer-copy {
        margin-top: 32px;
        padding-top: 16px;
        border-top: 1px solid var(--dk-border);
        font-size: 11px;
        font-family: var(--font-mono);
        display: flex;
        justify-content: space-between;
        color: var(--dk-fg-4);
      }

      /* Compare strip — also above fixed narukama */
      .compare {
        position: relative;
        z-index: 2;
        border-top: 1px solid var(--dk-border);
        padding: 40px 0 80px;
        font-size: 13px;
        color: var(--dk-fg-3);
        text-align: center;
      }
      .compare a { color: var(--flame-orange); }
    </style>
  </head>
  <body>
    <div class="proto-banner">
      🧪 Design preview <code>/design-preview/dark-hero</code> · not linked from
      the live site · <a href="/">回主站</a>
    </div>

    <header class="site-header">
      <div class="container header-inner">
        <a href="#" class="brand">
          <svg
            class="brand-symbol"
            viewBox="0 0 32 32"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path d="M 2 16 Q 8 8, 16 16 T 30 16" />
            <path d="M 2 22 Q 8 14, 16 22 T 30 22" />
          </svg>
          <div>
