---
import BaseLayout from "~/layouts/BaseLayout.astro";
import MediaGallery from "~/components/MediaGallery.astro";
---

<BaseLayout
  lang="en"
  title="Media"
  description="Experiment footage, visualizations and images from the Thermoacoustic Lab. YouTube videos linked to their source publications where applicable."
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Media</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">
      Media
    </h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  <div class="mt-6">
    <MediaGallery lang="en" />
  </div>
</BaseLayout>
