---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const allRaw = await getCollection("news");
const baseEntries = allRaw.filter((n) => !n.slug.endsWith("-en"));
// Use -en variant when one exists; fall back to base entry otherwise.
const variants = baseEntries.map((b) => ({
  baseSlug: b.slug,
  entry: allRaw.find((n) => n.slug === `${b.slug}-en`) ?? b,
}));

const sorted = variants.sort(
  (a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf(),
);

const rendered = await Promise.all(
  sorted.map(async ({ baseSlug, entry }) => ({
    baseSlug,
    entry,
    ...(await render(entry)),
  })),
);
---

<BaseLayout
  lang="en"
  title="News"
  description="Latest news from the Thermoacoustic Lab — events, conferences, and admissions."
  narukamaBg
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">News</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">News</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  {
    rendered.length === 0 ? (
      <p class="mt-8 text-gray-500">No news yet.</p>
    ) : (
      <ol class="mt-8 space-y-8">
        {rendered.map(({ baseSlug, entry: n, Content }) => (
          <li id={baseSlug} class="scroll-mt-24 rounded-lg border border-brand-100 p-5 transition hover:border-brand-300">
            <p class="text-sm text-brand-500">
              {n.data.date.toISOString().slice(0, 10)}
            </p>
            <h2 class="mt-1 text-xl font-semibold text-brand-900">
              <a href={`#${baseSlug}`} class="hover:text-accent-700">{n.data.title_en ?? n.data.title}</a>
            </h2>
            <div class="prose prose-brand mt-4 max-w-none text-gray-700">
              <Content />
            </div>
          </li>
        ))}
      </ol>
    )
  }
</BaseLayout>
