---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Prose from "~/components/Prose.astro";

const allRaw = await getCollection("members");
const baseMembers = allRaw.filter((m) => !m.slug.endsWith("-en"));
// For sections that render MDX body (PI block), prefer the -en variant.
const all = baseMembers.map(
  (b) => allRaw.find((m) => m.slug === `${b.slug}-en`) ?? b,
);
const pubs = await getCollection("publications");
const pubMap = new Map(pubs.map((p) => [p.slug, p.data]));
const byRole = (role: string) =>
  all
    .filter((m) => m.data.role === role)
    .sort((a, b) => a.data.order - b.data.order);

const pi = byRole("pi");
const postdoc = byRole("postdoc");
const phd = byRole("phd");
const ms = byRole("ms");
const undergrad = byRole("undergrad");
const exchange = byRole("exchange");
const ra = byRole("research-assistant");
const alumni = byRole("alumni");
const degreeEn: Record<string, string> = {
  學士: "B.S.",
  碩士: "M.S.",
  博士: "Ph.D.",
};
// Alumni grouped by graduation year (Gregorian), newest first
const alumniYears = [
  ...new Set(alumni.map((m) => (m.data.graduated ?? "").slice(0, 4))),
].sort((a, b) => b.localeCompare(a));
const degreeOrder = ["學士", "碩士", "博士"];
const alumniDegrees = degreeOrder.filter((d) =>
  alumni.some((m) => m.data.degree === d),
);
const awards = (await getCollection("awards")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);

// Alumni statistics
const degreeCounts = degreeOrder
  .map((d) => ({
    label: degreeEn[d] ?? d,
    n: alumni.filter((m) => m.data.degree === d).length,
  }))
  .filter((x) => x.n > 0);
const yearCounts = alumniYears.map((y) => ({
  label: y || "Other",
  n: alumni.filter((m) => (m.data.graduated ?? "").slice(0, 4) === y).length,
}));
const destMeta = [
  { key: "further-study", label: "Further study" },
  { key: "industry", label: "Industry" },
  { key: "other", label: "Other" },
];
const destCounts = destMeta
  .map((d) => ({
    label: d.label,
    n: alumni.filter((m) => m.data.destination_type === d.key).length,
  }))
  .filter((x) => x.n > 0);
const maxDegree = Math.max(...degreeCounts.map((x) => x.n), 1);
const maxYear = Math.max(...yearCounts.map((x) => x.n), 1);
const maxDest = Math.max(...destCounts.map((x) => x.n), 1);
const pct = (n: number, max: number) => Math.round((n / max) * 100);

const roleSections = [
  { label: "Postdoc", members: postdoc },
  { label: "Ph.D. Students", members: phd },
  { label: "Master's Students", members: ms },
  { label: "Undergraduate Students", members: undergrad },
  { label: "Exchange Students", members: exchange },
  { label: "Research Assistants", members: ra },
];
---

<BaseLayout
  lang="en"
  title="People"
  description="Members of the Thermoacoustic Lab — PI, graduate students, undergraduate students, and alumni."
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">People</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">People</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  {
    pi.map(async (m) => {
      const { Content } = await m.render();
      const initial = m.data.name_en.charAt(0);
      return (
        <section class="mt-8 rounded-lg border border-brand-100 bg-brand-50 p-8">
          <p class="text-xs uppercase tracking-[0.3em] text-brand-500">
            Principal Investigator
          </p>
          <div class="mt-6 grid gap-8 md:grid-cols-[200px_1fr]">
            <div>
              {m.data.photo ? (
                <img
                  src={m.data.photo}
                  alt={`${m.data.name_en} (welding heat exchangers and assembling thermoacoustic engine setups)`}
                  class="h-48 w-48 rounded-lg object-cover ring-1 ring-brand-200"
                />
              ) : (
                <div
                  class="flex h-48 w-48 items-center justify-center rounded-lg bg-brand-800 text-7xl font-bold text-white ring-1 ring-brand-200"
                  aria-label={`${m.data.name_en} photo placeholder`}
                >
                  {initial}
                </div>
              )}
            </div>
            <div>
              <h2 class="text-3xl font-bold text-brand-900">
                {m.data.name_en}
                <span class="ml-3 text-base font-normal text-brand-600">
                  Associate Professor
                </span>
              </h2>
              <p class="mt-1 text-lg text-brand-600">
                {m.data.name_zh}
              </p>
              {m.data.affiliation && (
                <p class="mt-3 text-gray-700">
                  Department of Mechanical Engineering, National Taipei
                  University of Technology
                </p>
              )}
              <div class="mt-4 space-y-1 text-sm text-gray-600">
                {m.data.email && (
                  <p>
                    Email:{" "}
                    <a
                      href={`mailto:${m.data.email}`}
                      class="text-accent-600 underline hover:text-accent-700"
                    >
                      {m.data.email}
                    </a>
                  </p>
                )}
                {m.data.orcid && (
                  <p>
                    ORCID:{" "}
                    <a
                      href={`https://orcid.org/${m.data.orcid}`}
                      target="_blank"
                      rel="noopener"
                      class="text-accent-600 underline hover:text-accent-700"
                    >
                      {m.data.orcid}
                    </a>
                  </p>
                )}
              </div>
            </div>
          </div>
          <div class="mt-8 border-t border-brand-200 pt-6">
            <Prose>
              <Content />
            </Prose>
          </div>
        </section>
      );
    })
  }

  <section class="mt-16">
    <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
      Members
    </p>
    <h2 class="mt-2 text-2xl font-semibold text-brand-900">Lab Members</h2>
    {
      roleSections.every((s) => s.members.length === 0) ? (
        <p class="mt-4 text-gray-500">
          The roster is being updated — full member list coming soon.
        </p>
      ) : (
        roleSections.map((s) =>
          s.members.length > 0 ? (
            <div class="mt-6">
              <h3 class="text-lg font-medium text-brand-800">{s.label}</h3>
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                {s.members.map((m) => (
                  <div class="rounded-lg border border-brand-100 p-4 transition hover:border-brand-300">
                    <p class="font-medium text-brand-900">
                      {m.data.name_en}{" "}
                      <span class="text-sm text-brand-500">
                        {m.data.name_zh}
                      </span>
                    </p>
                    {m.data.interests.length > 0 && (
                      <p class="mt-1 text-sm text-gray-600">
                        {m.data.interests.join(", ")}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ) : null,
        )
      )
    }
  </section>

  {
    alumni.length > 0 && (
      <section class="mt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Alumni
        </p>
        <h2 class="mt-2 text-2xl font-semibold text-brand-900">Alumni</h2>

        <div class="mt-4 rounded-lg border border-brand-100 bg-brand-50 p-5">
          <p class="text-sm text-gray-700">
            <strong class="text-brand-900">{alumni.length}</strong> graduates in total（{degreeCounts.map((d) => `${d.label} ${d.n}`).join(", ")}）
          </p>
          <div class="mt-4 grid gap-x-8 gap-y-5 sm:grid-cols-2">
            <div>
              <h3 class="text-xs font-medium uppercase tracking-widest text-brand-500">
                Degrees
              </h3>
              <div class="mt-2 space-y-1.5">
                {degreeCounts.map((d) => (
                  <div class="grid grid-cols-[3rem_1fr_1.5rem] items-center gap-2">
                    <span class="text-right text-xs text-gray-600">{d.label}</span>
                    <span class="h-3.5 rounded bg-brand-700" style={`width:${pct(d.n, maxDegree)}%`} />
                    <span class="text-xs text-gray-500">{d.n}</span>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <h3 class="text-xs font-medium uppercase tracking-widest text-brand-500">
                By graduation year
              </h3>
              <div class="mt-2 space-y-1.5">
                {yearCounts.map((y) => (
                  <div class="grid grid-cols-[3rem_1fr_1.5rem] items-center gap-2">
                    <span class="text-right font-mono text-xs text-gray-600">{y.label}</span>
                    <span class="h-3.5 rounded bg-accent-500" style={`width:${pct(y.n, maxYear)}%`} />
                    <span class="text-xs text-gray-500">{y.n}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          {destCounts.length > 0 ? (
            <div class="mt-5">
              <h3 class="text-xs font-medium uppercase tracking-widest text-brand-500">
                Destinations
              </h3>
              <div class="mt-2 space-y-1.5 sm:max-w-md">
                {destCounts.map((d) => (
                  <div class="grid grid-cols-[6rem_1fr_1.5rem] items-center gap-2">
                    <span class="text-right text-xs text-gray-600">{d.label}</span>
                    <span class="h-3.5 rounded bg-brand-500" style={`width:${pct(d.n, maxDest)}%`} />
                    <span class="text-xs text-gray-500">{d.n}</span>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <p class="mt-4 text-xs text-gray-400">
              Destination statistics coming soon (alumni placements are being updated).
            </p>
          )}
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
          <div class="flex items-center gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-gray-500">Year</span>
            <div class="flex flex-wrap gap-1" data-alumni-filter="year">
              <button class="filter-btn" data-filter-value="all" data-active="true">
                All
              </button>
              {alumniYears.map((y) => (
                <button class="filter-btn" data-filter-value={y}>
                  {y}
                </button>
              ))}
            </div>
          </div>
          {alumniDegrees.length > 1 && (
            <div class="flex items-center gap-2">
              <span class="font-mono text-xs uppercase tracking-widest text-gray-500">Degree</span>
              <div class="flex flex-wrap gap-1" data-alumni-filter="degree">
                <button class="filter-btn" data-filter-value="all" data-active="true">
                  All
                </button>
                {alumniDegrees.map((d) => (
                  <button class="filter-btn" data-filter-value={d}>
                    {degreeEn[d] ?? d}
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>

        <div id="alumni-list">
        {alumniYears.map((year) => (
          <div class="mt-6" data-year-group={year}>
            <h3>
              <span class="inline-block rounded bg-brand-50 px-2.5 py-1 font-mono text-sm font-medium text-brand-700">
                {year}
              </span>
            </h3>
            <div class="mt-3 grid gap-3 md:grid-cols-2">
              {alumni
                .filter((m) => (m.data.graduated ?? "").slice(0, 4) === year)
                .map((m) => (
                  <div
                    class="rounded-lg border border-brand-100 p-4"
                    data-year={year}
                    data-degree={m.data.degree ?? ""}
                  >
                    <p class="font-medium text-brand-900">
                      {m.data.name_en}{" "}
                      <span class="text-sm text-brand-500">{m.data.name_zh}</span>
                    </p>
                    {m.data.graduated && (
                      <p class="mt-1 text-sm text-brand-500">
                        {`Graduated ${m.data.graduated}${m.data.degree ? ` · ${degreeEn[m.data.degree] ?? m.data.degree}` : ""}`}
                      </p>
              )}
              {(m.data.thesis_en ?? m.data.thesis) && (
                <p class="mt-1 text-sm text-gray-700">
                  Thesis:{" "}
                  {m.data.thesis_url ? (
                    <a
                      href={m.data.thesis_url}
                      target="_blank"
                      rel="noopener"
                      class="text-accent-600 underline hover:text-accent-700"
                    >
                      {m.data.thesis_en ?? m.data.thesis}
                    </a>
                  ) : (
                    m.data.thesis_en ?? m.data.thesis
                  )}
                </p>
              )}
              {m.data.related_pubs.length > 0 && (
                <p class="mt-1 text-sm text-gray-600">
                  Related work:{" "}
                  {m.data.related_pubs
                    .map((slug) => pubMap.get(slug))
                    .filter((p) => p !== undefined)
                    .map((p, i) => (
                      <Fragment>
                        {i > 0 && ", "}
                        <a
                          href={p.doi ? `https://doi.org/${p.doi}` : "/en/publications/"}
                          target="_blank"
                          rel="noopener"
                          class="text-accent-600 underline hover:text-accent-700"
                        >
                          {p.venue_short ?? p.venue} {p.year}
                        </a>
                      </Fragment>
                    ))}
                      </p>
                    )}
                    {(m.data.award_en ?? m.data.award_zh) && (
                      <p class="mt-1 text-sm text-gray-600">
                        Award:{" "}
                        {m.data.award_url ? (
                          <a
                            href={m.data.award_url}
                            target="_blank"
                            rel="noopener"
                            class="text-accent-600 underline hover:text-accent-700"
                          >
                            {m.data.award_en ?? m.data.award_zh}
                          </a>
                        ) : (
                          m.data.award_en ?? m.data.award_zh
                        )}
                      </p>
                    )}
                  </div>
                ))}
            </div>
          </div>
        ))}
        </div>
        <p id="alumni-empty" hidden class="mt-6 text-sm text-gray-500">
          No alumni match the selected filters.
        </p>
      </section>
    )
  }

  {
    awards.length > 0 && (
      <section class="mt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Honors
        </p>
        <h2 class="mt-2 text-2xl font-semibold text-brand-900">Honors</h2>
        <div class="mt-6 space-y-4">
          {awards.map((a) => (
            <article class="rounded-lg border border-brand-100 p-5">
              <p class="text-sm">
                <span class="rounded bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent-700">
                  {a.data.award_en ?? a.data.award_zh}
                </span>
                <span class="ml-2 font-mono text-brand-500">{a.data.date}</span>
              </p>
              <h3 class="mt-2 text-lg font-semibold text-brand-900">
                {a.data.title_en ?? a.data.title_zh}
              </h3>
              <p class="mt-1 text-sm text-brand-600">
                {a.data.event_en ?? a.data.event_zh}
              </p>
              {a.data.recipients.length > 0 && (
                <p class="mt-1 text-sm text-gray-700">
                  {a.data.recipients.join(", ")}
                  {a.data.advisor && ` (advisor: ${a.data.advisor})`}
                </p>
              )}
              <div class="mt-2 flex flex-wrap gap-4 text-xs">
                {a.data.url && (
                  <a
                    href={a.data.url}
                    target="_blank"
                    rel="noopener"
                    class="text-accent-600 underline hover:text-accent-700"
                  >
                    Award report ↗
                  </a>
                )}
                {a.data.related_pub && pubMap.get(a.data.related_pub) && (
                  <a
                    href="/en/publications/"
                    class="text-accent-600 underline hover:text-accent-700"
                  >
                    Related paper
                  </a>
                )}
              </div>
              {a.data.images.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-3">
                  {a.data.images.map((img) => (
                    <img
                      src={img.src}
                      alt={img.alt ?? a.data.title_en ?? a.data.title_zh}
                      class="max-h-64 w-auto rounded-lg border border-brand-100 object-contain"
                      loading="lazy"
                    />
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  const groups = document.querySelectorAll<HTMLElement>("[data-alumni-filter]");
  const cards = document.querySelectorAll<HTMLElement>(
    "#alumni-list [data-year][data-degree]",
  );
  const yearGroups =
    document.querySelectorAll<HTMLElement>("#alumni-list [data-year-group]");
  const empty = document.getElementById("alumni-empty") as HTMLElement | null;
  const state: Record<string, string> = { year: "all", degree: "all" };

  groups.forEach((g) => {
    g.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(
        "[data-filter-value]",
      );
      if (!btn) return;
      const group = g.dataset.alumniFilter!;
      state[group] = btn.dataset.filterValue!;
      g.querySelectorAll<HTMLElement>("[data-filter-value]").forEach((b) =>
        b.setAttribute("data-active", String(b === btn)),
      );
      apply();
    });
  });

  function apply() {
    let visible = 0;
    cards.forEach((c) => {
      const match =
        (state.year === "all" || state.year === c.dataset.year) &&
        (state.degree === "all" || state.degree === c.dataset.degree);
      c.hidden = !match;
      if (match) visible++;
    });
    yearGroups.forEach((yg) => {
      yg.hidden =
        yg.querySelectorAll<HTMLElement>("[data-year]:not([hidden])").length === 0;
    });
    if (empty) empty.hidden = visible > 0;
  }
</script>
