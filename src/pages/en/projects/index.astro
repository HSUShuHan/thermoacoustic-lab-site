---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const all = await getCollection("projects");
const pubs = await getCollection("publications");
const pubBySlug = new Map(pubs.map((p) => [p.slug, p.data]));

const CATEGORIES = [
  { key: "research", label: "Research" },
  { key: "teaching", label: "Teaching" },
  { key: "industry", label: "Industry Collaboration" },
];

const groups = CATEGORIES.map((c) => ({
  ...c,
  items: all
    .filter((p) => (p.data.category ?? "research") === c.key)
    .sort((a, b) =>
      (b.data.period_start || "").localeCompare(a.data.period_start || ""),
    ),
})).filter((g) => g.items.length > 0);

// Project statistics (from the PI's project records; MOST merged into NSTC)
const nfmt = (twd: number) => `NT$ ${twd.toLocaleString()}K`;
const pct = (n: number, max: number) => Math.max(4, Math.round((n / max) * 100));
const budgetOf = (p: (typeof all)[number]) => p.data.budget_twd ?? 0;

const count = all.length;
const activeCount = all.filter((p) => p.data.active).length;
const totalBudget = all.reduce((s, p) => s + budgetOf(p), 0);
const outputCount = new Set(all.flatMap((p) => p.data.related_pubs)).size;

const startYears = all
  .map((p) => (p.data.period_start || "").slice(0, 4))
  .filter(Boolean)
  .sort();
const endYears = all
  .map((p) => (p.data.period_end || "").slice(0, 4))
  .filter(Boolean)
  .sort();
const spanStart = startYears[0];
const spanEnd = endYears[endYears.length - 1];

// By funding agency (MOST is the former name of NSTC — merge)
const funderEn: Record<string, string> = {
  國科會: "NSTC (incl. MOST)",
  科技部: "NSTC (incl. MOST)",
  教育部: "MOE",
};
const funderNorm = (f: string) => funderEn[f] ?? f;
const funderMap = new Map<string, { count: number; budget: number }>();
for (const p of all) {
  const k = funderNorm(p.data.funder);
  const e = funderMap.get(k) ?? { count: 0, budget: 0 };
  e.count += 1;
  e.budget += budgetOf(p);
  funderMap.set(k, e);
}
const funderStats = [...funderMap.entries()]
  .map(([label, v]) => ({ label, ...v }))
  .sort((a, b) => b.budget - a.budget);
const maxFunderBudget = Math.max(...funderStats.map((f) => f.budget), 1);

// Funding awarded by project start year
const yearMap = new Map<string, number>();
for (const p of all) {
  const y = (p.data.period_start || "").slice(0, 4);
  if (!y) continue;
  yearMap.set(y, (yearMap.get(y) ?? 0) + budgetOf(p));
}
const yearStats = [...yearMap.entries()]
  .sort((a, b) => b[0].localeCompare(a[0]))
  .map(([year, budget]) => ({ year, budget }));
const maxYearBudget = Math.max(...yearStats.map((y) => y.budget), 1);

// By category
const catMap = new Map<string, { count: number; budget: number }>();
for (const p of all) {
  const k = p.data.category ?? "research";
  const e = catMap.get(k) ?? { count: 0, budget: 0 };
  e.count += 1;
  e.budget += budgetOf(p);
  catMap.set(k, e);
}
const catStats = CATEGORIES.filter((c) => catMap.has(c.key)).map((c) => ({
  label: c.label,
  ...catMap.get(c.key)!,
}));
---

<BaseLayout
  lang="en"
  title="Funded Projects"
  description="Projects led by or involving the Thermoacoustic Lab: research (NSTC and others), teaching, and industry collaboration."
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Projects</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">Funded Projects</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
    <p class="mt-4 text-sm text-gray-500">
      For the most up-to-date research list, see the PI's
      <a
        href="https://wrs.nstc.gov.tw/modules/talentSearch/talentSearch.do?action=initRsm17new&rsNo=54dd1397f8ea4f919455e0fa4b43f2c6&LANG=eng"
        class="text-accent-600 underline hover:text-accent-700"
        target="_blank"
        rel="noopener"
        >NSTC talent search profile</a
      >.
    </p>
  </section>

  <section class="mt-4 rounded-xl border border-brand-100 bg-brand-50/40 p-5 sm:p-6">
    <h2 class="text-lg font-semibold text-brand-900">Project statistics</h2>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-lg border border-brand-100 bg-white p-4">
        <p class="text-2xl font-bold text-brand-900">{count}</p>
        <p class="mt-1 text-xs text-brand-500">Projects ({activeCount} active)</p>
      </div>
      <div class="rounded-lg border border-brand-100 bg-white p-4">
        <p class="text-2xl font-bold text-brand-900">{nfmt(totalBudget)}</p>
        <p class="mt-1 text-xs text-brand-500">Total funding awarded</p>
      </div>
      <div class="rounded-lg border border-brand-100 bg-white p-4">
        <p class="text-2xl font-bold text-brand-900">{outputCount}</p>
        <p class="mt-1 text-xs text-brand-500">Publications</p>
      </div>
      <div class="rounded-lg border border-brand-100 bg-white p-4">
        <p class="text-2xl font-bold text-brand-900">{spanStart}–{spanEnd}</p>
        <p class="mt-1 text-xs text-brand-500">Project span</p>
      </div>
    </div>

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <div>
        <h3 class="text-sm font-semibold text-brand-700">
          Funding awarded (by start year)
        </h3>
        <div class="mt-3 space-y-2">
          {yearStats.map((y) => (
            <div class="flex items-center gap-3 text-sm">
              <span class="w-12 shrink-0 font-mono text-brand-500">{y.year}</span>
              <span
                class="h-3.5 rounded bg-accent-500"
                style={`width:${pct(y.budget, maxYearBudget)}%`}
              />
              <span class="whitespace-nowrap text-brand-600">{nfmt(y.budget)}</span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-brand-700">By funding agency</h3>
        <div class="mt-3 space-y-2">
          {funderStats.map((f) => (
            <div class="flex items-center gap-3 text-sm">
              <span class="w-32 shrink-0 text-brand-700">{f.label}</span>
              <span
                class="h-3.5 rounded bg-brand-700"
                style={`width:${pct(f.budget, maxFunderBudget)}%`}
              />
              <span class="whitespace-nowrap text-brand-600">
                {f.count} · {nfmt(f.budget)}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-6">
      <h3 class="text-sm font-semibold text-brand-700">By category</h3>
      <div class="mt-2 flex flex-wrap gap-2">
        {catStats.map((c) => (
          <span class="rounded-md border border-brand-100 bg-white px-2.5 py-1 text-sm text-brand-800">
            {c.label} · {c.count} · {nfmt(c.budget)}
          </span>
        ))}
      </div>
    </div>

    <p class="mt-5 text-xs text-brand-400">
      Source: the PI's own project records (cross-referenced with NSTC / GRB);
      MOST projects are counted under NSTC. Funding is attributed to each
      project's start year.
    </p>
  </section>

  {
    groups.map((g) => (
      <section class="mt-10">
        <h2 class="text-2xl font-semibold text-brand-900">{g.label}</h2>
        <div class="mt-4 space-y-4">
          {g.items.map((p) => (
            <article class="rounded-lg border border-brand-100 p-5 transition hover:border-brand-300">
              <p class="text-sm">
                <span
                  class={`rounded px-2 py-0.5 text-xs font-medium ${p.data.active ? "bg-accent-50 text-accent-700" : "bg-brand-100 text-brand-800"}`}
                >
                  {p.data.funder}
                </span>
                <span class="ml-2 text-brand-500">
                  {p.data.period_start} ~ {p.data.period_end}
                </span>
                {p.data.budget_twd !== undefined && (
                  <span class="ml-2 text-sm font-medium text-brand-700">
                    NT$ {p.data.budget_twd.toLocaleString()}K
                  </span>
                )}
                {!p.data.active && (
                  <span class="ml-2 rounded bg-brand-50 px-2 py-0.5 text-xs text-brand-500">
                    Completed
                  </span>
                )}
              </p>
              <h3 class="mt-2 text-lg font-semibold text-brand-900">
                {p.data.title_en ?? p.data.title_zh}
              </h3>
              {p.data.title_en && p.data.title_zh && (
                <p class="mt-1 text-sm italic text-brand-500">
                  {p.data.title_zh}
                </p>
              )}
              <p class="mt-3 text-gray-700">{p.data.summary_en ?? p.data.summary}</p>
              {p.data.related_pubs.length > 0 && (
                <div class="mt-3 border-t border-brand-100 pt-3">
                  <p class="text-xs font-semibold uppercase tracking-wide text-brand-500">
                    Research output ({p.data.related_pubs.length})
                  </p>
                  <ul class="mt-1.5 space-y-1">
                    {p.data.related_pubs
                      .map((slug) => pubBySlug.get(slug))
                      .filter((pub) => pub !== undefined)
                      .map((pub) => (
                        <li class="text-sm leading-snug">
                          <a
                            href={pub.doi ? `https://doi.org/${pub.doi}` : "/en/publications/"}
                            target="_blank"
                            rel="noopener"
                            class="whitespace-nowrap font-medium text-accent-600 underline hover:text-accent-700"
                          >
                            {pub.venue_short ?? pub.venue} {pub.year}
                          </a>
                          <span class="text-gray-600">
                            {" — "}
                            {pub.title_en ?? pub.title}
                          </span>
                        </li>
                      ))}
                  </ul>
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
