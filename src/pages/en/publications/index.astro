---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const all = await getCollection("publications");
const sorted = all.sort((a, b) => b.data.year - a.data.year);

const allVideos = await getCollection("videos");
const videoBySlug = new Map(
  allVideos
    .filter((v) => v.data.related_pub)
    .map((v) => [v.data.related_pub!, v]),
);

const byYear = sorted.reduce<Record<number, typeof sorted>>((acc, p) => {
  (acc[p.data.year] ??= []).push(p);
  return acc;
}, {});

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

const typeLabel: Record<string, string> = {
  journal: "Journal",
  conference: "Conference",
  thesis: "Thesis",
  preprint: "Preprint",
};

const typeColor: Record<string, string> = {
  journal: "bg-brand-100 text-brand-800",
  conference: "bg-accent-50 text-accent-700",
  thesis: "bg-gray-100 text-gray-700",
  preprint: "bg-amber-100 text-amber-800",
};

function quartileColor(ranking: string | undefined): string {
  if (!ranking) return "bg-gray-100 text-gray-700";
  if (ranking.startsWith("Q1")) return "bg-emerald-50 text-emerald-700";
  if (ranking.startsWith("Q2")) return "bg-sky-50 text-sky-700";
  if (ranking.startsWith("Q3")) return "bg-amber-50 text-amber-700";
  return "bg-gray-100 text-gray-700";
}

const LAB_AUTHORS = new Set([
  "許書涵",
  "Shu-Han Hsu",
  "Shu-Han HSU",
  "Shu Han Hsu",
  "Shu Hsu",
]);
---

<BaseLayout
  lang="en"
  title="Publications"
  description="Publications from the Thermoacoustic Lab — journal articles, conference papers, and theses."
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">
      Publications
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">Publications</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
    <p class="mt-4 text-sm text-gray-500">
      For the most complete and up-to-date list, see the PI's
      <a
        href="https://orcid.org/0000-0002-3014-2013"
        class="text-accent-600 underline hover:text-accent-700"
        target="_blank"
        rel="noopener"
        >ORCID</a
      >.
    </p>
  </section>

  {
    years.map((year) => (
      <section class="mt-10">
        <h2 class="text-2xl font-semibold text-brand-900">{year}</h2>
        <ol class="mt-4 space-y-3">
          {byYear[year].map((p) => (
            <li class="rounded-lg border border-brand-100 p-4 transition hover:border-brand-300">
              <div class="flex items-start gap-3">
                <span
                  class:list={[
                    "shrink-0 rounded px-2 py-0.5 text-xs font-medium",
                    typeColor[p.data.type] ?? "bg-gray-100 text-gray-700",
                  ]}
                >
                  {typeLabel[p.data.type] ?? p.data.type}
                </span>
                <div class="min-w-0 flex-1">
                  <p class="font-medium leading-snug text-brand-900">
                    {p.data.title}
                  </p>
                  <p class="mt-1 text-sm text-gray-700">
                    {p.data.authors.map((a, i) => (
                      <>
                        {i > 0 && ", "}
                        {LAB_AUTHORS.has(a) ? <strong>{a}</strong> : a}
                      </>
                    ))}
                  </p>
                  <p class="mt-1 text-sm italic text-gray-600">
                    {p.data.venue}
                  </p>
                  {p.data.type === "journal" && (
                    <div class="mt-1.5 flex flex-wrap items-center gap-2 text-xs">
                      {p.data.impact_factor !== undefined && (
                        <span class="rounded bg-brand-50 px-2 py-0.5 font-medium text-brand-700">
                          IF {p.data.impact_factor}
                          {p.data.if_year && (
                            <span class="ml-0.5 text-brand-500">({p.data.if_year})</span>
                          )}
                        </span>
                      )}
                      {p.data.ranking && (
                        <span class:list={[
                          "rounded px-2 py-0.5 font-medium",
                          quartileColor(p.data.ranking),
                        ]}>
                          {p.data.ranking}
                        </span>
                      )}
                      {p.data.not_indexed && (
                        <span class="rounded bg-gray-100 px-2 py-0.5 font-medium text-gray-600">
                          not indexed
                        </span>
                      )}
                    </div>
                  )}
                  <div class="mt-2 flex flex-wrap gap-3 text-xs">
                    {p.data.doi && (
                      <a
                        href={`https://doi.org/${p.data.doi}`}
                        target="_blank"
                        rel="noopener"
                        class="text-accent-600 underline hover:text-accent-700"
                      >
                        DOI: {p.data.doi}
                      </a>
                    )}
                    {videoBySlug.get(p.slug) && (
                      <a
                        href={`/en/media#${videoBySlug.get(p.slug)!.slug}`}
                        class="rounded bg-red-50 px-2 py-0.5 font-medium text-red-700 hover:bg-red-100"
                      >
                        ▶ Video
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))
  }
</BaseLayout>
