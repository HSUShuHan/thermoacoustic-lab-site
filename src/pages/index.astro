---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const research = (await getCollection("research"))
  .filter((r) => r.data.active)
  .sort((a, b) => a.data.order - b.data.order);

const pi = (await getCollection("members")).find((m) => m.data.role === "pi");

const featuredPubs = (await getCollection("publications"))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year);

const recentPubs =
  featuredPubs.length > 0
    ? featuredPubs
    : (await getCollection("publications"))
        .sort((a, b) => b.data.year - a.data.year)
        .slice(0, 4);

const projects = (await getCollection("projects"))
  .sort((a, b) => (b.data.period_start || "").localeCompare(a.data.period_start || ""))
  .slice(0, 3);

const videos = (await getCollection("videos"))
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return (b.data.year ?? 0) - (a.data.year ?? 0);
  })
  .slice(0, 4);

const heroNews = (await getCollection("news"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="熱聲實驗室"
  description="熱聲實驗室（Thermoacoustic Lab，國立臺北科技大學）。研究主軸：熱聲引擎、熱聲製冷、非線性熱聲動力學。"
>
  <!-- Hero -->
  <section class="relative py-20">
    <div
      class="absolute -top-2 left-0 h-1 w-24 bg-accent-500"
      aria-hidden="true"
    >
    </div>
    <div class="grid gap-10 md:grid-cols-2 md:gap-12">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-brand-500">
          National Taipei University of Technology
        </p>
        <h1 class="mt-3 text-6xl font-bold tracking-tight text-brand-900">
          熱聲實驗室
        </h1>
        <p class="mt-3 text-3xl font-light tracking-wide text-brand-600">
          Thermoacoustic Lab.
        </p>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-gray-700">
          本實驗室探索熱與聲的能量轉換，專注於研究熱聲引擎與熱聲製冷、熱聲非線性現象應用與探索，與熱聲能源系統機電整合控制。
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/research"
            class="inline-flex items-center rounded bg-brand-800 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-brand-700"
            >了解我們的研究 →</a
          >
          <a
            href="/join-us"
            class="inline-flex items-center rounded border border-brand-300 px-5 py-2.5 text-sm font-medium text-brand-800 transition hover:border-brand-800"
            >加入我們</a
          >
        </div>
      </div>

      <!-- 近況 strip -->
      <aside
        class="rounded-lg border border-brand-100 bg-brand-50/50 p-5 md:mt-2"
      >
        <p class="text-xs uppercase tracking-[0.3em] text-brand-500">News</p>
        <h2 class="mt-1 text-lg font-semibold text-brand-900">近況</h2>
        {
          heroNews.length > 0 ? (
            <ol class="mt-4 space-y-3">
              {heroNews.map((n) => (
                <li class="border-l-2 border-accent-500 pl-3">
                  <a
                    href={`/news#${n.slug}`}
                    class="group block transition"
                  >
                    <p class="text-xs text-brand-500">
                      {n.data.date.toISOString().slice(0, 10)}
                    </p>
                    <p class="mt-0.5 text-sm leading-snug text-brand-900 group-hover:text-accent-700">
                      {n.data.title}
                    </p>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <p class="mt-4 text-sm text-gray-500">尚無動態。</p>
          )
        }
        <p class="mt-4 text-xs">
          <a
            href="/news"
            class="text-brand-700 underline transition hover:text-accent-600"
          >
            查看全部 →
          </a>
        </p>
      </aside>
    </div>
  </section>

  <!-- PI -->
  {
    pi && (
      <section class="mt-16 border-t border-brand-100 pt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Principal Investigator
        </p>
        <h2 class="mt-2 text-3xl font-bold text-brand-900">指導教授</h2>
        <div class="mt-8 grid gap-8 md:grid-cols-[1fr_2fr]">
          <div class="rounded-lg border border-brand-100 bg-brand-50 p-6">
            {pi.data.photo ? (
              <img
                src={pi.data.photo}
                alt={`${pi.data.name_zh}（焊接熱交換器、整備熱聲引擎實驗裝置）`}
                class="h-56 w-56 rounded-lg object-cover ring-1 ring-brand-200"
              />
            ) : (
              <div
                class="flex h-56 w-56 items-center justify-center rounded-lg bg-brand-800 text-7xl font-bold text-white ring-1 ring-brand-200"
                aria-label={`${pi.data.name_zh} 照片佔位`}
              >
                {pi.data.name_zh.charAt(0)}
              </div>
            )}
            <p class="mt-4 text-2xl font-semibold text-brand-900">
              {pi.data.name_zh}{" "}
              <span class="text-base font-normal text-brand-600">副教授</span>
            </p>
            <p class="mt-1 text-sm text-brand-600">
              Assoc. Prof. {pi.data.name_en}
            </p>
            {pi.data.email && (
              <p class="mt-4 text-sm">
                <a
                  href={`mailto:${pi.data.email}`}
                  class="text-accent-600 underline transition hover:text-accent-700"
                >
                  {pi.data.email}
                </a>
              </p>
            )}
            <p class="mt-4 text-sm">
              <a
                href={`/people/${pi.slug}`}
                class="text-brand-700 underline transition hover:text-accent-600"
              >
                查看完整簡歷 →
              </a>
            </p>
          </div>
          <div>
            <p class="text-gray-700">{pi.data.affiliation}</p>
            <p class="mt-1 text-sm text-gray-500">
              日本東北大學工學博士，機械機能創成專攻
            </p>
            <h3 class="mt-6 text-xs font-medium uppercase tracking-widest text-brand-500">
              研究方向
            </h3>
            <ul class="mt-3 space-y-1 text-gray-700">
              {pi.data.interests.map((i) => (
                <li class="flex items-baseline gap-2">
                  <span class="inline-block h-1 w-1 shrink-0 rounded-full bg-accent-500" />
                  {i}
                </li>
              ))}
            </ul>
            <p class="mt-6 text-sm">
              <a
                href="/people"
                class="text-brand-700 underline transition hover:text-accent-600"
              >
                查看所有成員 →
              </a>
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- Research -->
  {
    research.length > 0 && (
      <section class="mt-20 border-t border-brand-100 pt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Research
        </p>
        <h2 class="mt-2 text-3xl font-bold text-brand-900">研究內容</h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {research.slice(0, 4).map((r) => (
            <a
              href={`/research/${r.slug}`}
              class="block rounded-lg border border-brand-100 p-6 transition hover:border-brand-800 hover:shadow-md"
            >
              <h3 class="text-xl font-semibold text-brand-900">
                {r.data.title_zh}
              </h3>
              <p class="mt-1 text-sm text-brand-500">{r.data.title_en}</p>
              <p class="mt-3 text-gray-700">{r.data.summary}</p>
            </a>
          ))}
          <a
            href="/research/animations/standing-wave"
            class="block rounded-lg border border-brand-100 p-6 transition hover:border-brand-800 hover:shadow-md"
          >
            <p>
              <span class="rounded bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent-700">
                互動動畫
              </span>
            </p>
            <h3 class="mt-2 text-xl font-semibold text-brand-900">
              熱聲機制動畫
            </h3>
            <p class="mt-1 text-sm text-brand-500">
              Thermoacoustic Mechanism Animation
            </p>
            <p class="mt-3 text-gray-700">
              氣塊振盪、PV 軌跡、T—x 軌跡、3D 軌道同步顯示；可切換 3 種壁溫梯度模式（均溫、製冷、引擎），看裝置從「無作用」變成製冷機、再到引擎。
            </p>
          </a>
        </div>
      </section>
    )
  }

  <!-- Media / Videos -->
  {
    videos.length > 0 && (
      <section class="mt-20 border-t border-brand-100 pt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Media
        </p>
        <h2 class="mt-2 text-3xl font-bold text-brand-900">影像紀錄</h2>
        <p class="mt-3 max-w-2xl text-gray-700">
          實驗影像、視覺化動畫；對應論文者於影片下方標明出處。
        </p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {videos.map((v) => (
            <a
              href={`/media#${v.slug}`}
              class="group block overflow-hidden rounded-lg border border-brand-100 bg-white shadow-sm transition hover:border-brand-300 hover:shadow-md"
            >
              <div class="relative aspect-video w-full bg-black">
                <img
                  src={`https://i.ytimg.com/vi/${v.data.youtube_id}/hqdefault.jpg`}
                  alt={v.data.title_zh ?? v.data.title}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
                <span class="absolute inset-0 flex items-center justify-center">
                  <span class="flex h-14 w-14 items-center justify-center rounded-full bg-black/60 text-white transition group-hover:bg-accent-600">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                </span>
              </div>
              <div class="p-4">
                <h3 class="font-medium leading-snug text-brand-900 group-hover:text-accent-700">
                  {v.data.title_zh ?? v.data.title}
                </h3>
                {v.data.year && (
                  <p class="mt-1 text-xs text-brand-500">{v.data.year}</p>
                )}
              </div>
            </a>
          ))}
        </div>
        <p class="mt-6">
          <a
            href="/media"
            class="text-sm text-brand-700 underline transition hover:text-accent-600"
          >
            查看所有影像 →
          </a>
        </p>
      </section>
    )
  }

  <!-- Recent Publications -->
  {
    recentPubs.length > 0 && (
      <section class="mt-20 border-t border-brand-100 pt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Selected Publications
        </p>
        <h2 class="mt-2 text-3xl font-bold text-brand-900">精選發表</h2>
        <ol class="mt-8 space-y-4">
          {recentPubs.map((p) => {
            const journalUrl =
              p.data.url ||
              (p.data.doi ? `https://doi.org/${p.data.doi}` : null);
            const inner = (
              <>
                <p class="text-sm text-brand-500">{p.data.year}</p>
                <p class="mt-1 font-medium leading-snug text-brand-900 group-hover:text-accent-700">
                  {p.data.title}
                  {journalUrl && (
                    <span class="ml-1 inline-block text-xs text-brand-500 group-hover:text-accent-600">
                      ↗
                    </span>
                  )}
                </p>
                <p class="mt-1 text-sm italic text-gray-600">{p.data.venue}</p>
              </>
            );
            return (
              <li>
                {journalUrl ? (
                  <a
                    href={journalUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block rounded border-l-4 border-accent-500 bg-brand-50/50 p-4 transition hover:bg-brand-100"
                  >
                    {inner}
                  </a>
                ) : (
                  <div class="rounded border-l-4 border-accent-500 bg-brand-50/50 p-4">
                    {inner}
                  </div>
                )}
              </li>
            );
          })}
        </ol>
        <p class="mt-6">
          <a
            href="/publications"
            class="text-sm text-brand-700 underline transition hover:text-accent-600"
          >
            查看所有論文 →
          </a>
        </p>
      </section>
    )
  }

  <!-- Recent Projects -->
  {
    projects.length > 0 && (
      <section class="mt-20 border-t border-brand-100 pt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Projects
        </p>
        <h2 class="mt-2 text-3xl font-bold text-brand-900">近期計畫</h2>
        <div class="mt-8 space-y-3">
          {projects.map((p) => (
            <article class="rounded border border-brand-100 p-5">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <p class="text-sm text-brand-500">
                  {p.data.funder} · {p.data.period_start} ~ {p.data.period_end}
                </p>
                {p.data.budget_twd !== undefined && (
                  <p class="text-sm font-medium text-accent-700">
                    NT$ {p.data.budget_twd.toLocaleString()} 千元
                  </p>
                )}
              </div>
              <h3 class="mt-1 font-semibold text-brand-900">
                {p.data.title_zh}
              </h3>
            </article>
          ))}
        </div>
        <p class="mt-6">
          <a
            href="/projects"
            class="text-sm text-brand-700 underline transition hover:text-accent-600"
          >
            查看所有計畫 →
          </a>
        </p>
      </section>
    )
  }
</BaseLayout>
