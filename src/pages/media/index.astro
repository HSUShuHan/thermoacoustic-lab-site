---
import BaseLayout from "~/layouts/BaseLayout.astro";
import MediaGallery from "~/components/MediaGallery.astro";
---

<BaseLayout
  title="影像紀錄"
  description="熱聲實驗室實驗影像、動畫與圖像紀錄。對應論文之 YouTube 影片與實驗圖像彙整。"
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Media</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">
      影像紀錄
    </h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  <div class="mt-6">
    <MediaGallery lang="zh" />
  </div>
</BaseLayout>
