---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Prose from "~/components/Prose.astro";

const all = (await getCollection("news")).filter(
  (n) => !n.slug.endsWith("-en"),
);
const sorted = all.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const rendered = await Promise.all(
  sorted.map(async (n) => ({ entry: n, ...(await render(n)) })),
);
---

<BaseLayout title="近況" description="熱聲實驗室最新消息、研討會、招生公告。">
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">News</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">近況</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  {
    rendered.length === 0 ? (
      <p class="mt-8 text-gray-500">尚無動態。</p>
    ) : (
      <ol class="mt-8 space-y-8">
        {rendered.map(({ entry: n, Content }) => (
          <li id={n.slug} class="scroll-mt-24 rounded-lg border border-brand-100 p-5 transition hover:border-brand-300">
            <p class="text-sm text-brand-500">
              {n.data.date.toISOString().slice(0, 10)}
            </p>
            <h2 class="mt-1 text-xl font-semibold text-brand-900">
              <a href={`#${n.slug}`} class="hover:text-accent-700">{n.data.title}</a>
            </h2>
            <Prose>
              <Content />
            </Prose>
          </li>
        ))}
      </ol>
    )
  }
</BaseLayout>
