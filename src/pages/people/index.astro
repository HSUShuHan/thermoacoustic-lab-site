---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Prose from "~/components/Prose.astro";
import AlumniOutcomes from "~/components/AlumniOutcomes.astro";

const all = (await getCollection("members")).filter(
  (m) => !m.slug.endsWith("-en"),
);
const pubs = await getCollection("publications");
const pubMap = new Map(pubs.map((p) => [p.slug, p.data]));
const byRole = (role: string) =>
  all
    .filter((m) => m.data.role === role)
    .sort((a, b) => a.data.order - b.data.order);

const pi = byRole("pi");
const postdoc = byRole("postdoc");
const phd = byRole("phd");
const ms = byRole("ms");
const undergrad = byRole("undergrad");
const exchange = byRole("exchange");
const ra = byRole("research-assistant");
const alumni = byRole("alumni");
// 校友依畢業學年度分組（新到舊）
const alumniYears = [
  ...new Set(alumni.map((m) => m.data.academic_year ?? "")),
].sort((a, b) => b.localeCompare(a));
const degreeOrder = ["學士", "碩士", "博士"];
const alumniDegrees = degreeOrder.filter((d) =>
  alumni.some((m) => m.data.degree === d),
);
const awards = (await getCollection("awards")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);

// 畢業生統計
const degreeCounts = degreeOrder
  .map((d) => ({ label: d, n: alumni.filter((m) => m.data.degree === d).length }))
  .filter((x) => x.n > 0);
const yearCounts = alumniYears.map((y) => ({
  label: y ? `${y} 學年度` : "其他",
  n: alumni.filter((m) => (m.data.academic_year ?? "") === y).length,
}));
const maxDegree = Math.max(...degreeCounts.map((x) => x.n), 1);
const maxYear = Math.max(...yearCounts.map((x) => x.n), 1);
const pct = (n: number, max: number) => Math.round((n / max) * 100);

// 大學部專題團隊：以學士校友的 related_pub[0] 為專題，成員含所有 related_pubs
// 包含該篇的校友（跨年度/跨學位，如廖哲儀亦納入其大學部專題組）。
const projectSlugs = [
  ...new Set(
    alumni
      .filter((m) => m.data.degree === "學士")
      .map((m) => m.data.related_pubs[0])
      .filter((s): s is string => !!s),
  ),
];
const alumniTeams = projectSlugs.map((slug) => {
  const members = alumni
    .filter((m) => m.data.related_pubs.includes(slug))
    .sort((a, b) => a.data.order - b.data.order);
  const year =
    members.find((m) => m.data.degree === "學士")?.data.academic_year ?? "";
  const award = members.find((m) => m.data.award_zh);
  return { slug, pub: pubMap.get(slug), members, year, award };
});
const mastersInYear = (year: string) =>
  alumni
    .filter(
      (m) => (m.data.academic_year ?? "") === year && m.data.degree !== "學士",
    )
    .sort((a, b) => a.data.order - b.data.order);
const teamsInYear = (year: string) =>
  alumniTeams.filter((t) => t.year === year);

const roleSections = [
  { label: "博士後", members: postdoc },
  { label: "博士生", members: phd },
  { label: "碩士生", members: ms },
  { label: "交換學生", members: exchange },
  { label: "研究助理", members: ra },
];
// 大學部專題生依專題（interests[0]）分組
const undergradTeams = (() => {
  const map = new Map<string, typeof undergrad>();
  for (const m of undergrad) {
    const key = m.data.interests[0] ?? "";
    if (!map.has(key)) map.set(key, []);
    map.get(key)!.push(m);
  }
  return [...map.values()];
})();
---

<BaseLayout
  title="成員"
  description="熱聲實驗室成員：PI、研究生、大學部專題生、校友。"
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">People</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">成員</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  {
    pi.map(async (m) => {
      const { Content } = await m.render();
      const initial = m.data.name_zh.charAt(0);
      return (
        <section class="mt-8 rounded-lg border border-brand-100 bg-brand-50 p-8">
          <p class="text-xs uppercase tracking-[0.3em] text-brand-500">
            Principal Investigator 指導教授
          </p>
          <div class="mt-6 grid gap-8 md:grid-cols-[200px_1fr]">
            <div>
              {m.data.photo ? (
                <img
                  src={m.data.photo}
                  alt={`${m.data.name_zh}（焊接熱交換器、整備熱聲引擎實驗裝置）`}
                  class="h-48 w-48 rounded-lg object-cover ring-1 ring-brand-200"
                />
              ) : (
                <div
                  class="flex h-48 w-48 items-center justify-center rounded-lg bg-brand-800 text-7xl font-bold text-white ring-1 ring-brand-200"
                  aria-label={`${m.data.name_zh} 照片佔位`}
                >
                  {initial}
                </div>
              )}
            </div>
            <div>
              <h2 class="text-3xl font-bold text-brand-900">
                {m.data.name_zh}
                <span class="ml-3 text-base font-normal text-brand-600">
                  副教授
                </span>
              </h2>
              <p class="mt-1 text-lg text-brand-600">
                Assoc. Prof. {m.data.name_en}
              </p>
              {m.data.affiliation && (
                <p class="mt-3 text-gray-700">{m.data.affiliation}</p>
              )}
              <div class="mt-4 space-y-1 text-sm text-gray-600">
                {m.data.email && (
                  <p>
                    Email:{" "}
                    <a
                      href={`mailto:${m.data.email}`}
                      class="text-accent-600 underline hover:text-accent-700"
                    >
                      {m.data.email}
                    </a>
                  </p>
                )}
                {m.data.orcid && (
                  <p>
                    ORCID:{" "}
                    <a
                      href={`https://orcid.org/${m.data.orcid}`}
                      target="_blank"
                      rel="noopener"
                      class="text-accent-600 underline hover:text-accent-700"
                    >
                      {m.data.orcid}
                    </a>
                  </p>
                )}
              </div>
            </div>
          </div>
          <div class="mt-8 border-t border-brand-200 pt-6">
            <Prose>
              <Content />
            </Prose>
          </div>
        </section>
      );
    })
  }

  <section class="mt-16">
    <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
      Members
    </p>
    <h2 class="mt-2 text-2xl font-semibold text-brand-900">團隊成員</h2>
    {
      roleSections.every((s) => s.members.length === 0) &&
      undergrad.length === 0 ? (
        <p class="mt-4 text-gray-500">
          團隊成員資料更新中，最新名單將陸續上線。
        </p>
      ) : (
        <>
          {roleSections.map((s) =>
            s.members.length > 0 ? (
              <div class="mt-6">
                <h3 class="text-lg font-medium text-brand-800">{s.label}</h3>
                <div class="mt-3 grid gap-3 md:grid-cols-2">
                  {s.members.map((m) => (
                    <div class="rounded-lg border border-brand-100 p-4 transition hover:border-brand-300">
                      <p class="font-medium text-brand-900">
                        {m.data.name_zh}{" "}
                        <span class="text-sm text-brand-500">
                          {m.data.name_en}
                        </span>
                      </p>
                      {m.data.interests.length > 0 && (
                        <p class="mt-1 text-sm text-gray-600">
                          {m.data.interests.join("、")}
                        </p>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            ) : null,
          )}

          {undergrad.length > 0 && (
            <div class="mt-6">
              <h3 class="text-lg font-medium text-brand-800">大學部專題生</h3>
              <div class="mt-3 space-y-3">
                {undergradTeams.map((team) => (
                  <div class="rounded-lg border border-brand-100 p-4">
                    <p class="text-sm font-medium text-brand-700">
                      {team[0].data.interests[0]}
                    </p>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {team.map((m) => (
                        <span class="rounded-md border border-brand-100 bg-brand-50 px-2.5 py-1 text-sm text-brand-900">
                          {m.data.name_zh}{" "}
                          <span class="text-xs text-brand-500">
                            {m.data.name_en}
                          </span>
                        </span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </>
      )
    }
  </section>

  {
    alumni.length > 0 && (
      <section class="mt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Alumni
        </p>
        <h2 class="mt-2 text-2xl font-semibold text-brand-900">畢業學生</h2>

        <div class="mt-4 rounded-lg border border-brand-100 bg-brand-50 p-5">
          <p class="text-sm text-gray-700">
            共 <strong class="text-brand-900">{alumni.length}</strong> 位畢業生（{degreeCounts.map((d) => `${d.label} ${d.n}`).join("、")}）
          </p>
          <div class="mt-4 grid gap-x-8 gap-y-5 sm:grid-cols-2">
            <div>
              <h3 class="text-xs font-medium uppercase tracking-widest text-brand-500">
                學位分布
              </h3>
              <div class="mt-2 space-y-1.5">
                {degreeCounts.map((d) => (
                  <div class="grid grid-cols-[3rem_1fr_1.5rem] items-center gap-2">
                    <span class="text-right text-xs text-gray-600">{d.label}</span>
                    <span class="h-3.5 rounded bg-brand-700" style={`width:${pct(d.n, maxDegree)}%`} />
                    <span class="text-xs text-gray-500">{d.n}</span>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <h3 class="text-xs font-medium uppercase tracking-widest text-brand-500">
                各學年度畢業人數
              </h3>
              <div class="mt-2 space-y-1.5">
                {yearCounts.map((y) => (
                  <div class="grid grid-cols-[5rem_1fr_1.5rem] items-center gap-2">
                    <span class="text-right font-mono text-xs text-gray-600">{y.label}</span>
                    <span class="h-3.5 rounded bg-accent-500" style={`width:${pct(y.n, maxYear)}%`} />
                    <span class="text-xs text-gray-500">{y.n}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="mt-6 border-t border-brand-100 pt-4">
            <h3 class="text-xs font-medium uppercase tracking-widest text-brand-500">
              畢業去向
            </h3>
            <div class="mt-3">
              <AlumniOutcomes lang="zh" />
            </div>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
          <div class="flex items-center gap-2">
            <span class="font-mono text-xs uppercase tracking-widest text-gray-500">年份</span>
            <div class="flex flex-wrap gap-1" data-alumni-filter="year">
              <button class="filter-btn" data-filter-value="all" data-active="true">
                全部
              </button>
              {alumniYears.map((y) => (
                <button class="filter-btn" data-filter-value={y}>
                  {y ? `${y} 學年度` : "其他"}
                </button>
              ))}
            </div>
          </div>
          {alumniDegrees.length > 1 && (
            <div class="flex items-center gap-2">
              <span class="font-mono text-xs uppercase tracking-widest text-gray-500">學位</span>
              <div class="flex flex-wrap gap-1" data-alumni-filter="degree">
                <button class="filter-btn" data-filter-value="all" data-active="true">
                  全部
                </button>
                {alumniDegrees.map((d) => (
                  <button class="filter-btn" data-filter-value={d}>
                    {d}
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>

        <div id="alumni-list">
        {alumniYears.map((year) => (
          <div class="mt-6" data-year-group={year}>
            <h3>
              <span class="inline-block rounded bg-brand-50 px-2.5 py-1 font-mono text-sm font-medium text-brand-700">
                {year ? `${year} 學年度` : "其他"}
              </span>
            </h3>
            {mastersInYear(year).length > 0 && (
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                {mastersInYear(year).map((m) => (
                  <div
                    class="rounded-lg border border-brand-100 p-4"
                    data-year={year}
                    data-degree={m.data.degree ?? ""}
                  >
                    <p class="font-medium text-brand-900">
                      {m.data.name_zh}{" "}
                      <span class="text-sm text-brand-500">{m.data.name_en}</span>
                    </p>
                    {m.data.graduated && (
                      <p class="mt-1 text-sm text-brand-500">
                        {`畢業 ${m.data.graduated}${m.data.degree ? ` · ${m.data.degree}` : ""}`}
                      </p>
                    )}
              {m.data.thesis && (
                <p class="mt-1 text-sm text-gray-700">
                  論文：
                  {m.data.thesis_url ? (
                    <a
                      href={m.data.thesis_url}
                      target="_blank"
                      rel="noopener"
                      class="text-accent-600 underline hover:text-accent-700"
                    >
                      {m.data.thesis}
                    </a>
                  ) : (
                    m.data.thesis
                  )}
                </p>
              )}
              {m.data.related_pubs.length > 0 && (
                <p class="mt-1 text-sm text-gray-600">
                  相關論文成果：
                  {m.data.related_pubs
                    .map((slug) => pubMap.get(slug))
                    .filter((p) => p !== undefined)
                    .map((p, i) => (
                      <Fragment>
                        {i > 0 && "、"}
                        <a
                          href={p.doi ? `https://doi.org/${p.doi}` : "/publications/"}
                          target="_blank"
                          rel="noopener"
                          class="text-accent-600 underline hover:text-accent-700"
                        >
                          {p.venue_short ?? p.venue} {p.year}
                        </a>
                      </Fragment>
                    ))}
                      </p>
                    )}
                    {m.data.award_zh && (
                      <p class="mt-1 text-sm text-gray-600">
                        獲獎：
                        {m.data.award_url ? (
                          <a
                            href={m.data.award_url}
                            target="_blank"
                            rel="noopener"
                            class="text-accent-600 underline hover:text-accent-700"
                          >
                            {m.data.award_zh}
                          </a>
                        ) : (
                          m.data.award_zh
                        )}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            )}
            {teamsInYear(year).length > 0 && (
              <div class="mt-3 space-y-3">
                {teamsInYear(year).map((team) => (
                  <div
                    class="rounded-lg border border-brand-100 p-4"
                    data-year={year}
                    data-degree="學士"
                  >
                    <p class="text-xs uppercase tracking-wide text-brand-400">
                      大學部專題
                    </p>
                    {team.pub && (
                      <p class="mt-0.5 text-sm font-medium text-brand-800">
                        {team.pub.title}
                      </p>
                    )}
                    <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-sm">
                      {team.pub && (
                        <a
                          href={team.pub.doi
                            ? `https://doi.org/${team.pub.doi}`
                            : "/publications/"}
                          target="_blank"
                          rel="noopener"
                          class="text-accent-600 underline hover:text-accent-700"
                        >
                          相關論文：{team.pub.venue_short ?? team.pub.venue}{" "}
                          {team.pub.year}
                        </a>
                      )}
                      {team.award?.data.award_zh &&
                        (team.award.data.award_url ? (
                          <a
                            href={team.award.data.award_url}
                            target="_blank"
                            rel="noopener"
                            class="text-accent-600 underline hover:text-accent-700"
                          >
                            獲獎：{team.award.data.award_zh}
                          </a>
                        ) : (
                          <span class="text-gray-600">
                            獲獎：{team.award.data.award_zh}
                          </span>
                        ))}
                    </div>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {team.members.map((m) => (
                        <span class="rounded-md border border-brand-100 bg-brand-50 px-2.5 py-1 text-sm text-brand-900">
                          {m.data.name_zh}{" "}
                          <span class="text-xs text-brand-500">
                            {m.data.name_en}
                          </span>
                        </span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
        </div>
        <p id="alumni-empty" hidden class="mt-6 text-sm text-gray-500">
          無符合條件的校友。
        </p>
        <p class="mt-8 text-sm text-gray-500">
          名單如有遺漏，敬請畢業學生與指導老師許書涵聯絡（<a
            href="mailto:bookhsu@ntut.edu.tw"
            class="text-accent-600 underline hover:text-accent-700"
            >bookhsu@ntut.edu.tw</a
          >）。
        </p>
      </section>
    )
  }

  {
    awards.length > 0 && (
      <section class="mt-16">
        <p class="ribbon text-xs uppercase tracking-[0.3em] text-brand-500">
          Honors
        </p>
        <h2 class="mt-2 text-2xl font-semibold text-brand-900">榮譽</h2>
        <div class="mt-6 space-y-4">
          {awards.map((a) => (
            <article class="rounded-lg border border-brand-100 p-5">
              <p class="text-sm">
                <span class="rounded bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent-700">
                  {a.data.award_zh}
                </span>
                <span class="ml-2 font-mono text-brand-500">{a.data.date}</span>
              </p>
              <h3 class="mt-2 text-lg font-semibold text-brand-900">
                {a.data.title_zh}
              </h3>
              <p class="mt-1 text-sm text-brand-600">{a.data.event_zh}</p>
              {a.data.recipients.length > 0 && (
                <p class="mt-1 text-sm text-gray-700">
                  {a.data.recipients.join("、")}
                  {a.data.advisor && `（指導：${a.data.advisor}）`}
                </p>
              )}
              <div class="mt-2 flex flex-wrap gap-4 text-xs">
                {a.data.url && (
                  <a
                    href={a.data.url}
                    target="_blank"
                    rel="noopener"
                    class="text-accent-600 underline hover:text-accent-700"
                  >
                    得獎報導 ↗
                  </a>
                )}
                {a.data.related_pub && pubMap.get(a.data.related_pub) && (
                  <a
                    href="/publications/"
                    class="text-accent-600 underline hover:text-accent-700"
                  >
                    相關論文
                  </a>
                )}
              </div>
              {a.data.images.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-3">
                  {a.data.images.map((img) => (
                    <img
                      src={img.src}
                      alt={img.alt ?? a.data.title_zh}
                      class="max-h-64 w-auto rounded-lg border border-brand-100 object-contain"
                      loading="lazy"
                    />
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  const groups = document.querySelectorAll<HTMLElement>("[data-alumni-filter]");
  const cards = document.querySelectorAll<HTMLElement>(
    "#alumni-list [data-year][data-degree]",
  );
  const yearGroups =
    document.querySelectorAll<HTMLElement>("#alumni-list [data-year-group]");
  const empty = document.getElementById("alumni-empty") as HTMLElement | null;
  const state: Record<string, string> = { year: "all", degree: "all" };

  groups.forEach((g) => {
    g.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(
        "[data-filter-value]",
      );
      if (!btn) return;
      const group = g.dataset.alumniFilter!;
      state[group] = btn.dataset.filterValue!;
      g.querySelectorAll<HTMLElement>("[data-filter-value]").forEach((b) =>
        b.setAttribute("data-active", String(b === btn)),
      );
      apply();
    });
  });

  function apply() {
    let visible = 0;
    cards.forEach((c) => {
      const match =
        (state.year === "all" || state.year === c.dataset.year) &&
        (state.degree === "all" || state.degree === c.dataset.degree);
      c.hidden = !match;
      if (match) visible++;
    });
    yearGroups.forEach((yg) => {
      yg.hidden =
        yg.querySelectorAll<HTMLElement>("[data-year]:not([hidden])").length === 0;
    });
    if (empty) empty.hidden = visible > 0;
  }
</script>
