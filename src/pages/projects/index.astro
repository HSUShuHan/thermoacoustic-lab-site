---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const all = await getCollection("projects");
const sorted = all.sort((a, b) =>
  (b.data.period_start || "").localeCompare(a.data.period_start || ""),
);

const active = sorted.filter((p) => p.data.active);
const completed = sorted.filter((p) => !p.data.active);
---

<BaseLayout
  title="計畫"
  description="熱聲實驗室主持與參與之研究計畫（科技部 / 國科會等）。"
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Projects</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">計畫</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
    <p class="mt-4 text-sm text-gray-500">
      最新計畫清單請參考 PI 在 NSTC 學術研發服務網的
      <a
        href="https://wrs.nstc.gov.tw/modules/talentSearch/talentSearch.do?action=initRsm17new&rsNo=54dd1397f8ea4f919455e0fa4b43f2c6&LANG=chi"
        class="text-accent-600 underline hover:text-accent-700"
        target="_blank"
        rel="noopener"
        >talent search 頁面</a
      >。
    </p>
  </section>

  {
    active.length > 0 && (
      <section class="mt-8">
        <h2 class="text-2xl font-semibold text-brand-900">進行中</h2>
        <div class="mt-4 space-y-4">
          {active.map((p) => (
            <article class="rounded-lg border border-brand-100 p-5 transition hover:border-brand-300">
              <p class="text-sm">
                <span class="rounded bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent-700">
                  {p.data.funder}
                </span>
                <span class="ml-2 text-brand-500">
                  {p.data.period_start} ~ {p.data.period_end}
                </span>
              </p>
              <h3 class="mt-2 text-lg font-semibold text-brand-900">
                {p.data.title_zh}
              </h3>
              {p.data.title_en && (
                <p class="mt-1 text-sm italic text-brand-500">
                  {p.data.title_en}
                </p>
              )}
              <p class="mt-3 text-gray-700">{p.data.summary}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    completed.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-semibold text-brand-900">已完成</h2>
        <div class="mt-4 space-y-4">
          {completed.map((p) => (
            <article class="rounded-lg border border-brand-100 p-5 transition hover:border-brand-300">
              <p class="text-sm">
                <span class="rounded bg-brand-100 px-2 py-0.5 text-xs font-medium text-brand-800">
                  {p.data.funder}
                </span>
                <span class="ml-2 text-brand-500">
                  {p.data.period_start} ~ {p.data.period_end}
                </span>
              </p>
              <h3 class="mt-2 text-lg font-semibold text-brand-900">
                {p.data.title_zh}
              </h3>
              {p.data.title_en && (
                <p class="mt-1 text-sm italic text-brand-500">
                  {p.data.title_en}
                </p>
              )}
              <p class="mt-3 text-gray-700">{p.data.summary}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
