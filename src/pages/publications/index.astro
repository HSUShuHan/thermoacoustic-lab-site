---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const all = await getCollection("publications");
const sorted = all.sort((a, b) => b.data.year - a.data.year);

// Map publication slug → first associated video (for ▶ badge)
const allVideos = await getCollection("videos");
const videoBySlug = new Map(
  allVideos
    .filter((v) => v.data.related_pub)
    .map((v) => [v.data.related_pub!, v]),
);

const years = ["All", ...Array.from(new Set(sorted.map((p) => p.data.year))).sort((a, b) => b - a)];
const typeOrder = ["journal", "conference", "thesis", "preprint"];
const presentTypes = typeOrder.filter((t) =>
  sorted.some((p) => p.data.type === t),
);
const typeFilters = ["all", ...presentTypes];

const typeLabel: Record<string, string> = {
  all: "全部",
  journal: "期刊",
  conference: "研討會",
  thesis: "學位論文",
  preprint: "Preprint",
};

// Quartile-based color coding for ranking badge.
function quartileColor(ranking: string | undefined): string {
  if (!ranking) return "bg-gray-100 text-gray-700";
  if (ranking.startsWith("Q1")) return "bg-emerald-50 text-emerald-700";
  if (ranking.startsWith("Q2")) return "bg-sky-50 text-sky-700";
  if (ranking.startsWith("Q3")) return "bg-amber-50 text-amber-700";
  return "bg-gray-100 text-gray-700";
}

// Lab members to bold-mark
const LAB_AUTHORS = new Set([
  "許書涵",
  "Shu-Han Hsu",
  "Shu-Han HSU",
  "Shu Han Hsu",
  "Shu Hsu",
]);
---

<BaseLayout
  title="發表"
  description="熱聲實驗室學術發表清單，含期刊論文、研討會論文、學位論文。"
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Publications</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">發表</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
    <p class="mt-4 text-sm text-gray-500">
      最新最完整的版本請參考 PI 的
      <a
        href="https://orcid.org/0000-0002-3014-2013"
        class="text-accent-600 underline hover:text-accent-700"
        target="_blank"
        rel="noopener"
        >ORCID</a
      >。
    </p>
  </section>

  <!-- Filters -->
  <div class="mt-2 flex flex-wrap items-center gap-x-6 gap-y-3">
    <div class="flex items-center gap-2">
      <span class="font-mono text-xs uppercase tracking-widest text-gray-500">年份</span>
      <div class="flex flex-wrap gap-1" data-filter-group="year">
        {years.map((y, i) => (
          <button class="filter-btn" data-filter-value={y === "All" ? "all" : String(y)} data-active={i === 0 ? "true" : "false"}>
            {y === "All" ? "全部" : y}
          </button>
        ))}
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="font-mono text-xs uppercase tracking-widest text-gray-500">類型</span>
      <div class="flex flex-wrap gap-1" data-filter-group="type">
        {typeFilters.map((t, i) => (
          <button class="filter-btn" data-filter-value={t} data-active={i === 0 ? "true" : "false"}>
            {typeLabel[t]}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- List -->
  <ul class="mt-6 border-t border-brand-100" id="pub-list">
    {sorted.map((p) => {
      const journalUrl =
        p.data.url ||
        (p.data.doi ? `https://doi.org/${p.data.doi}` : null);
      const q = p.data.ranking ?? "";
      return (
        <li
          data-year={p.data.year}
          data-type={p.data.type}
          class="grid grid-cols-[56px_1fr_64px] items-start gap-3 border-b border-brand-100 py-5 md:grid-cols-[80px_1fr_90px] md:gap-6"
        >
          <span class="font-mono text-sm font-medium text-brand-800">
            {p.data.year}
          </span>
          <div class="min-w-0">
            {journalUrl ? (
              <a
                href={journalUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block font-medium leading-snug text-brand-900 transition hover:text-accent-600"
              >
                {p.data.title}
                <span class="ml-0.5 inline-block text-xs text-brand-400">↗</span>
              </a>
            ) : (
              <span class="block font-medium leading-snug text-brand-900">{p.data.title}</span>
            )}
            <p class="mt-1 text-sm text-gray-700">
              {p.data.authors.map((a, i) => (
                <>
                  {i > 0 && "、"}
                  {LAB_AUTHORS.has(a) ? <strong>{a}</strong> : a}
                </>
              ))}
            </p>
            <p class="mt-0.5 font-mono text-xs italic text-gray-500">{p.data.venue}</p>
            {p.data.type === "journal" && (
              <div class="mt-1.5 flex flex-wrap items-center gap-2 text-xs">
                {p.data.impact_factor !== undefined && (
                  <span class="rounded bg-brand-50 px-2 py-0.5 font-medium text-brand-700">
                    IF {p.data.impact_factor}
                  </span>
                )}
                {p.data.ranking && (
                  <span class:list={["rounded px-2 py-0.5 font-medium", quartileColor(p.data.ranking)]}>
                    {p.data.ranking}
                  </span>
                )}
                {p.data.not_indexed && (
                  <span class="rounded bg-gray-100 px-2 py-0.5 font-medium text-gray-600">
                    無 IF（not indexed）
                  </span>
                )}
              </div>
            )}
            {(p.data.doi || videoBySlug.get(p.slug)) && (
              <div class="mt-1.5 flex flex-wrap gap-3 text-xs">
                {p.data.doi && (
                  <a
                    href={`https://doi.org/${p.data.doi}`}
                    target="_blank"
                    rel="noopener"
                    class="text-accent-600 underline hover:text-accent-700"
                  >
                    DOI: {p.data.doi}
                  </a>
                )}
                {videoBySlug.get(p.slug) && (
                  <a
                    href={`/media#${videoBySlug.get(p.slug)!.slug}`}
                    class="rounded bg-red-50 px-2 py-0.5 font-medium text-red-700 hover:bg-red-100"
                  >
                    ▶ 實驗影片
                  </a>
                )}
              </div>
            )}
          </div>
          <span class="text-right font-mono text-xs uppercase tracking-wide text-gray-500">
            {typeLabel[p.data.type] ?? p.data.type}
          </span>
        </li>
      );
    })}
  </ul>

  <p id="pub-empty" hidden class="mt-6 text-sm text-gray-500">無符合條件的發表。</p>
</BaseLayout>

<script>
  const items = document.querySelectorAll<HTMLElement>("#pub-list li");
  const groups = document.querySelectorAll<HTMLElement>("[data-filter-group]");
  const empty = document.getElementById("pub-empty") as HTMLElement;
  const state: Record<string, string> = { year: "all", type: "all" };

  groups.forEach((g) => {
    g.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLElement>("[data-filter-value]");
      if (!btn) return;
      const group = g.dataset.filterGroup!;
      state[group] = btn.dataset.filterValue!;
      g.querySelectorAll<HTMLElement>("[data-filter-value]").forEach((b) =>
        b.setAttribute("data-active", String(b === btn)),
      );
      apply();
    });
  });

  function apply() {
    let visible = 0;
    items.forEach((li) => {
      const year = li.dataset.year!;
      const type = li.dataset.type!;
      const match =
        (state.year === "all" || state.year === year) &&
        (state.type === "all" || state.type === type);
      li.hidden = !match;
      if (match) visible++;
    });
    empty.hidden = visible > 0;
  }
</script>
