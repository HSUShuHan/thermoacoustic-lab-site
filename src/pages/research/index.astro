---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const all = await getCollection("research");
const active = all
  .filter((r) => r.data.active)
  .sort((a, b) => a.data.order - b.data.order);
const archived = all
  .filter((r) => !r.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="研究"
  description="熱聲實驗室研究主題：熱聲效應、熱聲引擎、熱聲製冷、非線性熱聲動力學。"
>
  <section class="py-8">
    <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Research</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-brand-900">研究</h1>
    <div class="mt-3 h-1 w-16 bg-accent-500" aria-hidden="true"></div>
  </section>

  <section class="mt-8 grid gap-6 md:grid-cols-2">
    {
      active.map((r) => (
        <a
          href={`/research/${r.slug}`}
          class="block rounded-lg border border-brand-100 p-6 transition hover:border-brand-800 hover:shadow-md"
        >
          <h2 class="text-xl font-semibold text-brand-900">
            {r.data.title_zh}
          </h2>
          <p class="mt-1 text-sm text-brand-500">{r.data.title_en}</p>
          <p class="mt-3 text-gray-700">{r.data.summary}</p>
        </a>
      ))
    }

    <a
      href="/research/animations/standing-wave"
      class="block rounded-lg border border-brand-100 p-6 transition hover:border-brand-800 hover:shadow-md"
    >
      <p>
        <span
          class="rounded bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent-700"
        >
          互動動畫
        </span>
      </p>
      <h2 class="mt-2 text-xl font-semibold text-brand-900">熱聲機制動畫</h2>
      <p class="mt-1 text-sm text-brand-500">
        Thermoacoustic Mechanism Animation
      </p>
      <p class="mt-3 text-gray-700">
        氣塊振盪、PV 軌跡、T—x 軌跡同步顯示；可切換 3 種壁溫梯度模式（均溫、製冷、引擎），看裝置從「無作用」變成製冷機、再到引擎的全過程。
      </p>
    </a>
  </section>

  {
    archived.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-semibold text-brand-900">歷年研究</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {archived.map((r) => (
            <a
              href={`/research/${r.slug}`}
              class="block rounded-lg border border-brand-100 p-4 text-gray-600 transition hover:border-brand-300 hover:text-brand-800"
            >
              <h3 class="font-medium">{r.data.title_zh}</h3>
              <p class="mt-1 text-sm">{r.data.summary}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
